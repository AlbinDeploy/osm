.chat_region {
    position: absolute;
    /* Sized in % of WorldUI's notch-adjusted body (not vw). vw ignored the notch and let the
       box cover the menu buttons on notched phones; on desktop %==vw, so it looks the same. */
    left: 10%;
    top: 8dp;
    padding: 0dp;
    z-index: 10;

    display: flex;
    flex-direction: column;
    gap: 0dp;

    width: 80%;
    height: 170dp;

    min-width: 80%;
    max-width: 80%;
    min-height: 110dp;
    max-height: 260dp;
}

.hide #chat_window {
    display: none;
}

.full-hide #chat_window {
    display: none;
}

.crazy_jim_panel {
    display: flex;
    flex-direction: row;
    gap: 4dp;
    align-items: flex-start;
    width: 100%;
}

    #image {
        min-width: 48dp;
        width: 48dp;
        height: 48dp;
        decorator: image(interface/tutorial/tut_npc.rttex);
    }

    #text {
    }


.input-panel {
    background-color: rgba(39,125,159,225);
    box-sizing: border-box;                /* border drawn inside so the bar keeps its size */
    border: 2dp rgba(135, 184, 204, 245);  /* light-blue outline */
    border-radius: 6dp;                    /* rounded box */
    width: auto;
    left: 7dp;                             /* pulled in so the blue stops eating the left border */
    right: -4dp;                           /* and reaches the right border to match */
    height: 39dp;                          /* with bottom:8 the top sits at 47, flush with the log */
    padding: 0dp;
    display: flex;
    flex-direction: row;
    position: absolute;
    bottom: 8dp;
    z-index: 50;
    overflow: hidden;
}

    #input-content {
        padding: 0dp;
        display: flex;
        flex-direction: row;
        position: relative;
        background-color: rgba(0,0,0,0);
        margin: 0dp;
        height: 100%;
    }

    #input-text {
        display: block;
        vertical-align: middle;
        align-self: center;                /* center the field in the bar */
        decorator: none;
        background-color: rgba(0,0,0,0);
        border: 0dp;
        border-radius: 0dp;
        font-weight: bold;
        line-height: 30dp;                 /* drives the caret height (shorter "|") */
        flex: 1 1 0dp;
        width: 0dp;
        min-width: 0dp;
        height: 30dp;                      /* match line-height */
        color: #fff;
        padding: 2dp 10dp 2dp 10dp;
        font-size: 0.74rem;
        font-effect: shadow(1dp 1dp #000);
    }

    #input-info {
        display: block;
        box-sizing: border-box;
        align-self: center;                         /* float the pill centered in the bar */
        text-align: center;
        line-height: 24dp;                          /* center "0/120" in the pill */
        background-color: rgba(200, 232, 246, 72);  /* light, translucent layer behind 0/120 */
        border: 1dp rgba(232, 248, 255, 95);        /* faint edge */
        border-radius: 7dp;
        flex: 0 0 60dp;
        width: 60dp;
        min-width: 60dp;
        height: 26dp;                               /* shorter than the bar -> floats as a pill */
        margin-right: 7dp;                          /* inset from the right edge */
        font-size: 0.66rem;
    }

.message-hint-panel {
    width: 100%;
    padding: 0dp;
    display: block;
    position: absolute;
    bottom: 18dp;
    left: 16dp;
    z-index: 65;                /* above the input bar so the hint isn't buried */
    font-size: 0.68rem;
    color: rgba(255,255,255,235);
    font-effect: shadow(1dp 1dp #000);
    pointer-events: none;
}

.preview-panel {
    border-radius: 4pt;
    border: 2dp rgba(135, 184, 204, 104);
    width: 100%;
    padding: 0dp;
    display: flex;
    flex-direction: row;
    background-color: rgba(39,125,159,224);
    margin-bottom: 2dp;
    margin-top: -4dp;

    position: absolute;
    bottom: 50dp;
    left: 3dp;
    z-index: 40;
}

    #preview-content {
        padding: 0dp;
        position: relative;
    }

    #preview-text {
        display: block;
        vertical-align: middle;
        border-radius: 7dp;
        font-weight: bold;
        line-height: 30dp;
        width: 100%;
        color: #fff;
        font-size: 0.75rem;
        padding: 3dp;
    }

.log-panel {
     decorator: tiled-box( window_border_sprite_tl, window_border_sprite_t, window_border_sprite_tr, window_border_sprite_cl, window_border_sprite_c, window_border_sprite_cr, window_border_sprite_bl, window_border_sprite_b, window_border_sprite_br );
     image-color: rgba(85, 174, 200, 235);
     position: relative;
     height: 100%;
     width: 100%;
     padding: 8dp 8dp 44dp 6dp;
     z-index: 10;
}

    #log-content {
        background-color: rgba(39,125,159,225);
        border-radius: 6dp 6dp 0dp 0dp;    /* round only the top (bottom meets the input bar) */

        position: absolute;
        left: 7dp;
        right: 10dp;
        top: 8dp;
        bottom: 47dp;                      /* meet the input bar's top so the two blue layers stay flush */
        width: auto;
        height: auto;

        overflow-y: auto;
        color: rgb(255, 252, 197);
        font-size: 0.68rem;
        line-height: 1.06em;
        font-effect: shadow(1dp 1dp black);
        padding-left: 2dp;
    }

    #log-content scrollbarvertical {
        display: none;
        width: 0dp;
        margin-left: 0dp;
        margin-right: 0dp;
    }

    #log-content slidertrack {
        display: none;
    }

    #log-content sliderbar {
        display: none;
    }

    #log-lines {
        width: 100%;
        min-height: 100%;
        display: flex;
        flex-direction: column-reverse;
        justify-content: flex-start;
    }

    #text-line {
        padding: 1dp 6dp 1dp 6dp;
    }

#pull_down_button {
    position: absolute;
    left: 50%;
    bottom: -22dp;
    margin-left: -22dp;
    width: 44dp;
    height: 24dp;
    padding: 0dp;
    z-index: 40;
    background-color: rgba(135,184,204,230);
    border-radius: 0dp 0dp 6dp 6dp;
    border: 2dp rgb(43,83,100);
    cursor: ns-resize;
    sound-on-click: true;
}

#pull_down_button:active {
    filter: brightness(0.85);
}

    #pull_down_icon {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2dp;
        width: 100%;
        height: 100%;
        pointer-events: none;
    }

    .pull_line {
        width: 24dp;
        height: 3dp;
        border-radius: 3dp;
        background-color: rgb(230,249,255);
        pointer-events: none;
    }

.chat_padding {
    padding: 1dp;
    background-color: rgba(255,255,255, 0);
}

    .chat_padding.alternate {
        display: block;
        padding-top: 1dp;
        background-color: rgba(0, 0, 0, 0);
    }

/* Filter tabs: an always-shown strip hanging just below the input bar (no size-gating, no
   Lua -- pure CSS). Colours + sizes are the stock console's; only the placement differs.
   All dp, so phone and desktop match; the settings popup is capped to the chat box. */

#filter {
    display: flex;
    flex-direction: row;
    gap: 4dp;
    position: absolute;
    left: 6dp;
    bottom: -40dp;              /* hang just below the input bar */
    z-index: 70;                /* in front of the log */
    opacity: 1.0;
}

#filter input[type="radio"] {
    display: none;              /* hide the native radio circle */
}

.filter_name {
    position: relative;
    padding: 4dp;
    top: -2dp;
    font-size: 0.75rem;
    font-effect: shadow(1dp 1dp #000);
}

/* Per-tab tints (stock colours, full opacity) */
.filter_all_clr     { background-color: rgba(135, 184, 204, 255); }
.filter_world_clr   { background-color: rgba(254, 186, 70, 255); }
.filter_private_clr { background-color: rgba(75, 255, 255, 255); }
.filter_system_clr  { background-color: rgba(166, 166, 166, 255); }
.filter_custom_clr  { background-color: rgba(210, 154, 212, 255); }

/* Tab icons (stock textures) */
.filter_all     { decorator: image(interface/large/gui_chat_all.rttex); }
.filter_world   { decorator: image(interface/large/gui_chat_world.rttex); }
.filter_private { decorator: image(interface/large/gui_chat_private.rttex); }
.filter_system  { decorator: image(interface/large/gui_chat_system.rttex); }
.filter_custom  { decorator: image(interface/large/gui_chat_custom.rttex); }

#filter label.filter_btn {
    display: flex;
    opacity: 1.0;
    sound-on-click: true;
    align-items: center;
    justify-content: center;
    padding: 4dp;
    border-radius: 0dp 0dp 6dp 6dp;    /* rounded bottom -- the strip hangs below the input */
    border: 1dp rgb(136, 184, 203);
}

#filter .icon {
    width: 32dp;
    height: 32dp;
    display: block;
}

/* Selected tab shows at full opacity */
#filter input[type="radio"]:checked + label {
    opacity: 1.0;
}

/* Custom-tab settings gear */
.chat_settings {
    background-color: rgba(210, 154, 212, 255);
    padding: 4dp;
    border-radius: 0dp 0dp 6dp 6dp;    /* match the tabs */
    border: 1dp rgb(136, 184, 203);
}

.chat_settings:active {
    filter: brightness(0.85);
    transform: scale(0.95);
}

#chat_image {
    width: 32dp;
    height: 32dp;
    decorator: image(interface/large/chat_settings.rttex);
    align-self: center;
    position: relative;
}

/* Custom-tab settings popup */
@spritesheet checkbox_sprites {
    src: interface/checkbox.rttex;
    resolution: 1x;
    checkbox_off_icon: 0px 0px 32px 32px;
    checkbox_on_icon: 32px 0px 32px 32px;
}

.popup {
    position: absolute;
    bottom: 52dp;               /* opens upward over the log, above the input bar */
    left: 6dp;
    width: 280dp;
    max-width: 96%;             /* never spills past the chat box */
    background-color: rgba(60, 137, 166, 204);
    border-radius: 4pt;
    border: 2dp rgb(136, 184, 203);
    padding: 0dp;
    z-index: 100;
    font-size: 0.75rem;
}

.checkbox-group {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: auto;
    gap: 5dp;
    padding: 10dp;
}

.checkbox-group .label {
    padding-left: 0dp;
    vertical-align: middle;
    text-align: left;
}

.checkbox-row {
    display: flex;
    align-items: center;
    gap: 8dp;
    sound-on-click: true;
}

.checkbox {
    height: 16dp;
    width: 16dp;
    display: inline-block;
    padding: 5dp;
    text-align: center;
    vertical-align: middle;
    align-items: center;
    justify-content: center;
    sound-on-click: true;
    decorator: image(checkbox_off_icon);
}

    .checkbox:checked {
        decorator: image(checkbox_on_icon);
    }
<template name="Console">
	<head>
		<title>Console</title>
		<link type="text/rcss" href="../../BaseStyles.rcss" />
		<link type="text/template" href="../Base/BasePopup.rml" />
		<link type="text/rcss" href="Console.rcss" />
		<script lang="text/lua">
			-- Keep the log scrolled to the newest line. Runs from the on* handlers below
			-- (data-rml can't call Lua here). The heights can be nil before layout, so guard them.
			function ConsoleScrollToBottom(document, element)
				if not document then return '' end
				local lc = document:GetElementById('log-content')
				if lc and lc.scroll_height and lc.client_height then
					lc.scroll_top = lc.scroll_height + lc.client_height + 1000000
				end
				return ''
			end

			-- (Filter tabs are always shown via CSS now -- see #filter in Console.rcss.)

			-- Enter on an empty box closes the chat (the old pre-5.48 feel). The catch: the
			-- Enter that OPENED the chat mustn't also close it, so the opening Enter only ARMS
			-- the flag and the NEXT empty Enter closes. Typing arms it too; it clears on close
			-- and on blur. It lives in keyup because onshow/onfocus aren't reliable here.
			function MaybeCloseChatOnEnter(event, document)
				if not document then return '' end
				local params = event and event.parameters
				if not params then return '' end

				if params['key_identifier'] ~= 72 then   -- 72 = Enter; anything else means typing
					gEnterArmed = true
					return ''
				end

				-- Empty box only -- if there's text, Enter is a send (handled by HandleInput).
				local hp = document:GetElementById('msg-hint-panel')
				local isEmpty = hp and not hp:IsClassSet('hidden')
				if not isEmpty then
					gEnterArmed = true
					return ''
				end

				if gEnterArmed then
					OnEvent(event, 'on-chat')   -- empty Enter on an open chat -> close it
					gEnterArmed = false
				else
					gEnterArmed = true          -- this Enter just opened the chat -> keep it open
				end

				return ''
			end

			function ResetConsoleEnterArm()
				gEnterArmed = false
				return ''
			end
		</script>
	</head>
	<!-- Keep the body element free of an onshow: this template is injected into WorldUI's
	     body, and a body onshow clashes with WorldUI's own onShowUI (the notch fix), shoving
	     the whole UI right on notched phones. The on* handlers below already cover auto-scroll. -->
	<body>
		<div id="chat_window" class="chat_region" data-model="ConsoleModel" data-class-hidden="!ConsoleModel.IsShown" onshow="ConsoleScrollToBottom(document, element)">

			<!-- Special-characters preview -->
			<div class="preview-panel" data-class-hidden="!ConsoleModel.InputSpecialChars">
				<div id="preview-content">
					<div id="preview-text" data-rml="ToRMLText(ConsoleModel.PreviewText)"/>
				</div>
			</div>

			<!-- Filter tabs: an always-shown strip below the input (placed by the .rcss).
			     Markup is verbatim from the stock console so the original filtering works. -->
			<form id="filter" name="duration" data-value="ConsoleModel.Filter" onclick="OnEvent(event, 'Console.OnFilter') ConsoleScrollToBottom(document, element)">
				<input type="radio" id="filter_all" value="0" data-checked="ConsoleModel.Filter" data-disabled="ConsoleModel.AccountAgeType == 3"/>
				<label for="filter_all" class="filter_btn filter_all_clr">
					<span class="icon filter_all"></span>
					<div class="filter_name" data-class-hidden="ConsoleModel.Filter != 0">All</div>
				</label>

				<input type="radio" id="filter_world" value="1" data-checked="ConsoleModel.Filter" data-disabled="ConsoleModel.AccountAgeType == 3"/>
				<label for="filter_world" class="filter_btn filter_world_clr">
					<span class="icon filter_world"></span>
					<div class="filter_name" data-class-hidden="ConsoleModel.Filter != 1">World</div>
				</label>

				<input type="radio" id="filter_private" value="2" data-checked="ConsoleModel.Filter" />
				<label for="filter_private" class="filter_btn filter_private_clr">
					<span class="icon filter_private"></span>
					<div class="filter_name" data-class-hidden="ConsoleModel.Filter != 2">Private</div>
				</label>

				<input type="radio" id="filter_system" value="3" data-checked="ConsoleModel.Filter" />
				<label for="filter_system" class="filter_btn filter_system_clr">
					<span class="icon filter_system"></span>
					<div class="filter_name" data-class-hidden="ConsoleModel.Filter != 3">System</div>
				</label>

				<input type="radio" id="filter_custom" value="4" data-checked="ConsoleModel.Filter" data-disabled="ConsoleModel.AccountAgeType == 3"/>
				<label for="filter_custom" class="filter_btn filter_custom_clr">
					<span class="icon filter_custom"></span>
					<div class="filter_name" data-class-hidden="ConsoleModel.Filter != 4">Custom</div>
				</label>

				<div class="chat_settings" data-class-hidden="ConsoleModel.Filter != 4" onclick="OnEvent(element, 'Console.OnClickCustomSettings')">
					<div id="chat_image"/>
				</div>
			</form>

			<!-- Custom-tab settings popup -->
			<div id="custom-settings-popup" class="popup hidden">
				<div style="padding: 8dp;">Select the content to be shown on the Custom tab</div>
				<form id="custom-settings" class="checkbox-group" onchange="OnEvent(event, 'Console.OnCustomSettingsChange')">
					<label class="checkbox-row">
						<input type="checkbox" filter-type="Global" value="0" data-checked="ConsoleModel.GlobalMessages"/>
						<span class="label">Global Messages</span>
					</label>
					<label class="checkbox-row">
						<input type="checkbox" filter-type="Global" value="1" data-checked="ConsoleModel.WorldMessages"/>
						<span class="label">World Messages</span>
					</label>
					<label class="checkbox-row">
						<input type="checkbox" filter-type="Global" value="2" data-checked="ConsoleModel.PrivateMessages"/>
						<span class="label">Private Messages</span>
					</label>
					<label class="checkbox-row">
						<input type="checkbox" filter-type="Global" value="3" data-checked="ConsoleModel.FriendMessages"/>
						<span class="label">Friend Messages</span>
					</label>
					<label class="checkbox-row">
						<input type="checkbox" filter-type="Global" value="4" data-checked="ConsoleModel.GuildMessages"/>
						<span class="label">Guild Messages</span>
					</label>
					<label class="checkbox-row">
						<input type="checkbox" filter-type="Global" value="5" data-checked="ConsoleModel.SystemMessages"/>
						<span class="label">Game/System Messages</span>
					</label>
				</form>
			</div>

			<!-- Log panel -->
			<div class="log-panel" id="log-top">
				<div class="show-scrollbar wondow-content-full wondow-content-horizontal" id="log-content" onshow="ConsoleScrollToBottom(document, element)">
					<div id="log-lines">
						<div data-for="Line : ConsoleModel.ShowLogLines" onlistupdated="ConsoleScrollToBottom(document, element)">
							<div class="chat_padding" data-class-alternate="IsOdd(Line)">
								<div id="text-line" data-rml="ToRMLText(ConsoleLogText(Line))" data-class-hidden="ConsoleLogDisplayType(Line) != 0"/>
								<div class="crazy_jim_panel" data-class-hidden="ConsoleLogDisplayType(Line) != 1">
									<div id="image" />
									<div id="text" data-rml="ToRMLText(ConsoleLogText(Line))" />
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Input bar -->
			<div class="input-panel">
				<div id="input-content" style="width:100%;">
					<input id="input-text" type="text" maxlength="120" data-value="ConsoleModel.InputText"
							onkeyup="MaybeCloseChatOnEnter(event, document) OnEvent(event, 'Console.HandleInput')"
							onblur="ResetConsoleEnterArm() OnEvent(event, 'Console.HandleInputFocusEnd')"
							onfocus="ConsoleScrollToBottom(document, element) OnEvent(event, 'Console.HandleInputFocusBegin')"/>
					<div id="input-info" data-rml="len(ConsoleModel.InputText)+'/120'"/>
				</div>
			</div>

			<!-- Empty-box hint -->
			<div id="msg-hint-panel" class="message-hint-panel" data-class-hidden="len(ConsoleModel.InputText) > 0">
				<div id="message-hint-text">Enter Message Here</div>
			</div>

			<!-- Drag-to-resize handle -->
			<customhandle id="pull_down_button" size_target="chat_window" edge_margin="10dp 20dp 10dp 10dp">
				<div id="pull_down_icon">
					<div class="pull_line"/>
					<div class="pull_line"/>
					<div class="pull_line"/>
				</div>
			</customhandle>

		</div>
	</body>
</template>
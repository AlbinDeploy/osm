<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
		<Sprite name="sprite" fileName="game/godzila.rttex" textureSize="128"/>
		<Sprite name="punch" fileName="game/godzila.rttex" textureSize="128"/>
		<Sprite name="malesps" fileName="game/godzila_icons.rttex" textureSize="32" frame="1,0"/>
		<Sprite name="md_eff" fileName="game/particles_large13.rttex" textureSize="64"/>
		<Sprite name="md_eff4" fileName="game/particles_large12.rttex" textureSize="64" frame="0,5"/>
		<StateMachines>
		<StateMachine name="Motion">
			<States>
				<State name="Idle" />
				<State name="Move" />
				<State name="Jump" />
				<State name="Fall" />
				<State name="Punch"/>
				<State name="Respawn"/>
			</States>
			<Transitions>
				<Transition to="Idle" from="Fall|Move|Jump|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">true</IsVariableBool>
						<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						<IsVariableBool name="isAttacking">false</IsVariableBool>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Move" from="Jump|Fall|Idle|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">true</IsVariableBool>
						<IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Jump" from="Idle|Move|Fall|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">false</IsVariableBool>
						<IsVariableFloat name="speed.y" operator="Less">-0.1</IsVariableFloat>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Fall" from="Jump|Idle|Move|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">false</IsVariableBool>
						<IsVariableFloat name="speed.y" operator="Greater">0.1</IsVariableFloat>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Punch" from="Idle|Move|Jump|Fall">
					<Condition type="and">
						<IsAction>PUNCH</IsAction>
					</Condition>
				</Transition>
			</Transitions>
		</StateMachine>
		</StateMachines>
		<Animations>
			<SpriteAnimation name="ge_eff" sprite="md_eff" animTime="500" isLoop="true" playOnState="Motion.Punch|Motion.Idle|Motion.Move|Motion.Jump|Motion.Fall">
				<Frame>7,4</Frame>
				<Frame>8,4</Frame>
				<Frame>9,4</Frame>
				<Frame>10,4</Frame>
				<Frame>11,4</Frame>
				</SpriteAnimation>
			<SpriteAnimation name="ge_eff2" sprite="md_eff4" animTime="800" isLoop="true" playOnState="Motion.Punch|Motion.Idle|Motion.Move|Motion.Jump|Motion.Fall">
				<Frame>1,5</Frame>
				<Frame>2,5</Frame>
				<Frame>3,5</Frame>
				<Frame>4,5</Frame>
				<Frame>5,5</Frame>
				<Frame>6,5</Frame>
				<Frame>7,5</Frame>
				<Frame>8,5</Frame>
				<Frame>9,5</Frame>
				<Frame>10,5</Frame>
				<Frame>11,5</Frame>
				<Frame>12,5</Frame>
				<Frame>13,5</Frame>
				<Frame>14,5</Frame>
				<Frame>15,5</Frame>
				<Frame>0,6</Frame>
				<Frame>1,6</Frame>
				<Frame>2,6</Frame>
				<Frame>3,6</Frame>
				</SpriteAnimation>
			<SpriteAnimation name="ge_punch_eff" sprite="punch" animTime="100" playOnState="Motion.Punch" isLoop="false">
			<Frame>0,4</Frame>
			<Frame>1,4</Frame>
			<Frame>2,4</Frame>
			<Frame>3,4</Frame>
			<Frame>4,4</Frame>
			<Frame>5,4</Frame>
			<Frame>6,4</Frame>
			<Frame>7,4</Frame>
			<Frame>8,4</Frame>
			<Frame>9,4</Frame>
			<Frame>10,4</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="gigi_Idle_Animation" playOnState="Motion.Idle" sprite="sprite" animTime="1000" isLoop="true">
			<Frame>0,0</Frame>
			<Frame>1,0</Frame>
			<Frame>2,0</Frame>
			<Frame>3,0</Frame>
			<Frame>4,0</Frame>
			<Frame>5,0</Frame>
			<Frame>6,0</Frame>
			<Frame>7,0</Frame>
			<Frame>8,0</Frame>
			<Frame>9,0</Frame>
			<Frame>10,0</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="gigi_Punch_Animation" playOnState="Motion.Punch" sprite="sprite" animTime="700" isLoop="false">
			<Frame>0,3</Frame>
			<Frame>1,3</Frame>
			<Frame>2,3</Frame>
			<Frame>3,3</Frame>
			<Frame>4,3</Frame>
			<Frame>5,3</Frame>
			<Frame>6,3</Frame>
			<Frame>7,3</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="gigi_Jump_Animation" playOnState="Motion.Jump" sprite="sprite" animTime="600">
				<Frame>5,1</Frame>
				<Frame>6,1</Frame>
				<Frame>7,1</Frame>
				<Frame>8,1</Frame>
				<Frame>9,1</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="gigi_Fall_Animation" playOnState="Motion.Fall" sprite="sprite" animTime="700">
				<Frame>0,1</Frame>
				<Frame>1,1</Frame>
				<Frame>2,1</Frame>
				<Frame>3,1</Frame>
				<Frame>4,1</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="gigi_Walk_Animation" playOnState="Motion.Move" sprite="sprite" animTime="1000" isLoop="true">
				<Frame>0,2</Frame>
				<Frame>1,2</Frame>
				<Frame>2,2</Frame>
				<Frame>3,2</Frame>
				<Frame>4,2</Frame>
				<Frame>5,2</Frame>
				<Frame>6,2</Frame>
			</SpriteAnimation>
		</Animations>
		
		<ParticleSystems>
		<ParticleSystem name="tile_hit_particle" updateStage="OnDamagedTile">
				<Emitter>
					<Set name="lifeTime">1</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">malesps</Set>
					<Random name="offset" min="-4, -4" max="4, 4"/>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>0.6, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 0.4, 0.4</KeyFrame>
						<KeyFrame>1, 1, 1</KeyFrame>
					</Curve>
					<Set name="lifeTime">0.8</Set>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="double_jump_particle">
				<Emitter>
          			<Set name="offset">0,-10150</Set>
					<Set name="particlesPerEmission">30</Set>
					<Set name="infParticles">true</Set>
          			<Set name="infLifeTime">true</Set>
					<Set name="delayTimer">0</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">malesps</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="isBackgroundParticle">true</Set>
					<Set name="relativeToEmitter">false</Set>
					<Set name="rotateWithVelocity">false</Set>
          			<Set name="interpolateScale">true</Set>
					<Set name="interpolateAlpha">true</Set>
					<Random name="lifeTime" min="0.75" max="2"/>
					<Set name="initialScale">0.75,0.75</Set>
          			<Set name="finalScale">3,3</Set>
          			<RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="80,160"/>
				</Particle>
			</ParticleSystem>
		</ParticleSystems>
		
		<RenderOptions>
			<Default>
				<Set name="JumpEndStateRange">100</Set>
				<Set name="ClothingOffsetFromShoes">10000</Set>
				<Set name="IsRidingBird">true</Set>
				<Set name="IsVehicle">true</Set>
				<Set name="UserNameOffset">100</Set>
				<Set name="RenderShoesWithMermaidTail">true</Set>
				<Set name="ShoesHidesBodyLegs">true</Set>
				<Set name="IsToRenderPants">false</Set>
			</Default>
		</RenderOptions>
	</Data>
	<RenderRules>
		<RenderInFront>
			<StopIf>
				<IsVariableBool name="isMannequin">true</IsVariableBool>
				<IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
			</StopIf>
			<SpriteRender name="PunchLaser" offset="10,-10179" onState="Motion.Punch" blend="ADDITIVE" stretchToTarget="true" alignmentLeft="LEFT_CENTER" alignmentRight="RIGHT_CENTER" drawShadow="false" flip="1,0"/>
			<SpriteRender name="md_eff4" offset="20,-10120" tintOverride="50,50,200,255" drawShadow="false" scale="6,6" onState="Motion.Move|Motion.Idle|Motion.Punch|Motion.Jump"/>
			<SpriteRender name="sprite" offset="-20,-10175" drawShadow="true" scale="3,3" onState="Motion.Idle|Motion.Move|Motion.Jump|Motion.Fall"/>
			<SpriteRender name="sprite" offset="-20,-10177" drawShadow="true" scale="3,3" onState="Motion.Punch"/>
			<SpriteRender name="md_eff" offset="10,-10115" tintOverride="50,50,200,255" drawShadow="false" scale="3,3" onState="Motion.Idle|Motion.Punch|Motion.Move"/>
			<SpriteRender name="md_eff4" offset="20,-10120" tintOverride="0,0,255,255" drawShadow="false" scale="6,6" onState="Motion.Move|Motion.Idle|Motion.Punch"/>
		</RenderInFront>
		<RenderShoes>
			<StopIf>
				<IsSitting>true</IsSitting>
				<IsSleepingOnaBed>true</IsSleepingOnaBed>
				<IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
			</StopIf>
		</RenderShoes>
		<AddClothingParticles>
			<ParticleSystemUpdate name="double_jump_particle" onAction="JUMPDOUBLE" drawShadow="false"/>
			<ParticleSystemUpdate name="evil_particle" drawShadow="false"/>
		</AddClothingParticles>
		<SwitchOffClothingParticles>
			<ParticleSystemOff name="double_jump_particle"/>
			<ParticleSystemOff name="evil_particle"/>
			<ParticleSystemOff name="tile_hit_particle"/>
		</SwitchOffClothingParticles>
	</RenderRules>
</ItemRenderer>
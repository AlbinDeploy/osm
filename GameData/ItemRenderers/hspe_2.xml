<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
  <Data>
    <Sprite name="s_item" fileName="game/lci_1.rttex" textureSize="64,32" frame="1,13" />
    <Sprite name="s_punch" fileName="game/gtfy_wn.rttex" textureSize="64" frame="7,2" />

    <Sprite name="Lightning" fileName="game/gtfy_wn.rttex" textureSize="64" frame="0,22" />

    <Animations>
      <SpriteAnimation name="anim_item" playOnAction="JUMP|FALL|IDLE|WALK|JUMPSTART|DANCE"
        sprite="s_item" animTime="600" autoPlay="true" isLoop="true">
        <Frame>1,13</Frame>
        <Frame>2,13</Frame>
        <Frame>3,13</Frame>
        <Frame>4,13</Frame>
      </SpriteAnimation>

      <SpriteAnimation name="Lightning_Anim" playOnAction="IDLE|WALK|JUMP|FALL"
        sprite="Lightning" autoPlay="true" animTime="910" isLoop="true">
        <Frame>0,22</Frame>
        <Frame>1,22</Frame>
        <Frame>2,22</Frame>
        <Frame>3,22</Frame>
        <Frame>4,22</Frame>
        <Frame>5,22</Frame>
        <Frame>6,22</Frame>
        <Frame>7,22</Frame>
        <Frame>8,22</Frame>
        <Frame>9,22</Frame>
        <Frame>10,22</Frame>
        <Frame>11,22</Frame>
        <Frame>4,22</Frame>
      </SpriteAnimation>

    </Animations>

    <ParticleSystems>
      <ParticleSystem name="ps_punch">
        <Emitter>
          <Set name="offset">3,-16</Set>
          <Set name="emissionInterval">0.25</Set>
          <Set name="lifeTime">0.25</Set>
          <Set name="particlesPerEmission">1</Set>
          <Set name="particlesToEmit">1</Set>
        </Emitter>
        <Particle>
          <Set name="sprite">s_punch</Set>
          <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          <Set name="lifeTime">0.4</Set>
          <Set name="rotateWithVelocity">true</Set>
          <Set name="interpolateAlpha">false</Set>
          <Set name="initialAlpha">1</Set>
          <Set name="finalAlpha">1</Set>
          <Set name="interpolateVelocity">true</Set>
          <Set name="initialScale">2,2</Set>
          <VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="1" angle="0" />
          <VectorTo name="finalVelocity" source="targetPos" duration="lifeTime" x="1" angle="0" />
        </Particle>
      </ParticleSystem>
    </ParticleSystems>

    <RenderOptions>
      <Default>
        <Set name="HideParticlesOnTransform">false</Set>
        <Set name="PunchSoundOverride">HAND</Set>
        <Set name="DefaultRenderMannequinHandItem">false</Set>
      </Default>
    </RenderOptions>
  </Data>

  <RenderRules>
    <RenderHandItem>
      <SpriteRender name="s_item" offset="8,8" rotateOffset="true" useFixedRotation="true"
        blend="PREMULTIPLIED_ALPHA" onAction="IDLE|WALK|JUMP|JUMPSTART|FALL|DANCE" />
      <SpriteRender name="s_item" offset="8,8" rotateOffset="true" rotateToTarget="true"
        blend="PREMULTIPLIED_ALPHA" onAction="PUNCH" />
    </RenderHandItem>

    
		<RenderInFront>
			<StopIf>
				<IsZombified>true</IsZombified>
			</StopIf>
			<SpriteRender name="Lightning" alignment="DOWN_CENTER"
				onAction="IDLE|PUNCH|WALK|JUMP|FALL" drawShadow="false" />
		</RenderInFront>


    <OnPunchStart>
      <ParticleSystemUpdate name="ps_punch" />
    </OnPunchStart>

    <OnPunchUpdate>
      <AvatarTransform class="Face">
        <Set name="face">MAD</Set>
      </AvatarTransform>
      <AvatarTransform class="ArmAngle">
        <Set name="armName">arm2Angle</Set>
        <Set name="armAngle">1080</Set>
        <Set name="isAdditive">true</Set>
      </AvatarTransform>
    </OnPunchUpdate>

    <SwitchOffClothingParticles>
      <ParticleSystemOff name="ps_punch" />
    </SwitchOffClothingParticles>

  </RenderRules>
</ItemRenderer>
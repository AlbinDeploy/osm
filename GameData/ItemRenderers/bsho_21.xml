<?xml version="1.0"?>
<ItemRenderer>
	<Data>
		<Sprite name="s_foot1" fileName="game/gtfy_wn.rttex" textureSize="64" frame="8,7" />
		<Sprite name="s_foot2" fileName="game/gtfy_wn.rttex" textureSize="64" frame="8,8" />


		<Sprite name="s_punch" fileName="game/ci_n1.rttex" textureSize="32" frame="8,1" />
		<Sprite name="s_punch2" fileName="game/ci_n1.rttex" textureSize="32" frame="8,2" />
		<Sprite name="s_fire" fileName="game/ci_n1.rttex" textureSize="32" frame="17,1" />
		<Sprite name="s_lightning" fileName="game/ci_n1.rttex" textureSize="32" frame="9,1" />
		<Sprite name="s_trail" fileName="game/ci_n1.rttex" textureSize="32" frame="8,3" />
		<Sprite name="s_crack" fileName="game/ci_n1.rttex" textureSize="32" frame="8,0" />

		<VariableMap>
			<Set name="leftFootYPos">0,0,0</Set>
			<Set name="rightFootYPos">0,0,0</Set>
		</VariableMap>

		<Animations>
			<SpriteAnimation name="foot1_anim" playOnAction="JUMP|FALL|IDLE|WALK|PUNCH"
				sprite="s_foot1" animTime="800" autoPlay="true" isLoop="true">
				<Frame>8,7</Frame>
				<Frame>9,7</Frame>
				<Frame>10,7</Frame>
				<Frame>11,7</Frame>
				<Frame>12,7</Frame>
				<Frame>13,7</Frame>
				<Frame>14,7</Frame>
				<Frame>15,7</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="foot2_anim" playOnAction="JUMP|FALL|IDLE|WALK|PUNCH"
				sprite="s_foot2" animTime="800" autoPlay="true" isLoop="true">
				<Frame>8,8</Frame>
				<Frame>9,8</Frame>
				<Frame>10,8</Frame>
				<Frame>11,8</Frame>
				<Frame>12,8</Frame>
				<Frame>13,8</Frame>
				<Frame>14,8</Frame>
				<Frame>15,8</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="lightning_anim" playOnAction="JUMP|FALL|IDLE|WALK|PUNCH"
				sprite="s_lightning" animTime="800" isLoop="true">
				<Frame>9,1</Frame>
				<Frame>10,1</Frame>
				<Frame>11,1</Frame>
				<Frame>12,1</Frame>
				<Frame>13,1</Frame>
				<Frame>14,1</Frame>
				<Frame>15,1</Frame>
				<Frame>16,1</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="punch2_anim" playOnAction="PUNCH" sprite="s_punch2"
				animTime="400" isLoop="true">
				<Frame>8,2</Frame>
				<Frame>9,2</Frame>
				<Frame>10,2</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="trail_anim" sprite="s_trail" animTime="800">
				<Frame>8,3</Frame>
				<Frame>9,3</Frame>
				<Frame>10,3</Frame>
				<Frame>11,3</Frame>
				<Frame>12,3</Frame>
				<Frame>13,3</Frame>
				<Frame>14,3</Frame>
				<Frame>15,3</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="crack_anim" sprite="s_crack" animTime="900" autoPlay="false">
				<Frame>8,0</Frame>
				<Frame>9,0</Frame>
				<Frame>10,0</Frame>
				<Frame>11,0</Frame>
				<Frame>12,0</Frame>
				<Frame>13,0</Frame>
				<Frame>14,0</Frame>
				<Frame>15,0</Frame>
				<Frame>16,0</Frame>
				<Frame>17,0</Frame>
			</SpriteAnimation>
		</Animations>

		<ParticleSystems>
			<ParticleSystem name="punch_particle">
				<Emitter>
					<Set name="offset">0,-18</Set>
					<Set name="emissionInterval">0.25</Set>
					<Set name="lifeTime">0.25</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_punch</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.4</Set>
					<Set name="rotateWithVelocity">true</Set>
					<Set name="interpolateAlpha">false</Set>
					<Set name="initialAlpha">1</Set>
					<Set name="finalAlpha">1</Set>
					<Set name="interpolateVelocity">true</Set>
					<Set name="initialScale">1,1</Set>
					<VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="1"
						angle="0" />
					<VectorTo name="finalVelocity" source="targetPos" duration="lifeTime" x="1"
						angle="0" />
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="particle_fire" updateStage="AddClothingParticles">
				<Emitter>
					<Set name="offset">0, -8</Set>
					<Set name="offsetFacing">false</Set>
					<Random name="emissionInterval" min="0.2" max="0.4" />
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">6</Set>
				</Emitter>
				<Particle usePlayerFacing="true">
					<Set name="sprite">s_fire</Set>
					<Set name="relativeToEmitter">true</Set>
					<Random name="offset" min="-18, -8" max="18, -8" />
					<Set name="inSpecificOrder">true</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>0.1, 0.8</KeyFrame>
						<KeyFrame>0.5, 0.8</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 1, 1</KeyFrame>
						<KeyFrame>0.5, 1, 1.9</KeyFrame>
						<KeyFrame>1, 1, 2.5</KeyFrame>
					</Curve>
					<Random name="lifeTime" min="0.8" max="1" />
					<Set name="initialVelocity">0, -30</Set>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="particle_trail">
				<Emitter>
					<Set name="offset">0,-16</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="infParticles">true</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="emissionInterval">0.15</Set>
				</Emitter>
				<Particle angleRelativeToPlayerSpeed="true">
					<Set name="sprite">s_trail</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.6</Set>
					<Set name="isBackgroundParticle">true</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 0.8, 1</KeyFrame>
						<KeyFrame>1, 2, 1</KeyFrame>
					</Curve>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="crack_particle">
				<Emitter>
					<Set name="infLifeTime">true</Set>
					<Set name="infParticles">true</Set>
					<Set name="particlesToEmit">1</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="randomizeInterval">false</Set>
					<Set name="intervalMin">0.5</Set>
					<Set name="intervalMax">0.5</Set>
					<Set name="offset">0,5</Set>
				</Emitter>
				<Particle>
					<Random name="offset" min="15,10" max="15,10" />
					<Set name="sprite">s_crack</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.8</Set>
					<Set name="initialScale">1,1</Set>
					<Select name="finalAlpha" input="randomNumber">
						<Item>1</Item>
						<Item>0</Item>
						<Item>0</Item>
					</Select>
					<Set name="initialAlpha">0</Set>
					<Set name="interpolateAlpha">true</Set>
				</Particle>
			</ParticleSystem>
		</ParticleSystems>

		<RenderOptions>
			<Default>
				<Set name="HideParticlesOnTransform">true</Set>
				<Set name="RenderShoesWithMermaidTail">false</Set>
			</Default>
		</RenderOptions>
	</Data>

	<RenderRules>
		<RenderShoes>
			<StopIf type="or">
				<IsWearing slot="PANTS">ITEM_ID_RAPTOR_LEGS</IsWearing>
				<IsRenderObjectFlag>RENDER_OBJECT_FLAG_NO_FEET</IsRenderObjectFlag>
				<IsVariableBool name="isInvisible">true</IsVariableBool>
			</StopIf>
			<Group>
				<Translate>leftFootYPos</Translate>
				<SpriteRender name="s_foot1" scale="0.5,0.5" alignment="DOWN_CENTER" />
			</Group>
			<Group>
				<Translate>rightFootYPos</Translate>
				<SpriteRender name="s_foot2" scale="0.5,0.5" alignment="DOWN_CENTER" />
			</Group>
			<SpriteRender name="s_punch2" offset="0,-18" onAction="PUNCH" blend="ADDITIVE"
				stretchToTarget="true" alignmentLeft="LEFT_CENTER" alignmentRight="RIGHT_CENTER"
				drawShadow="false" flip="1,0" />
		</RenderShoes>

		<OnPunchUpdate>
			<AvatarTransform class="Face">
				<Set name="face">MAD</Set>
			</AvatarTransform>
			<AvatarTransform class="ArmAngle">
				<Set name="armName">arm2Angle</Set>
				<Set name="armAngle">1100</Set>
				<Set name="isAdditive">true</Set>
				<Set name="pointTowardsPunchTarget">false</Set>
			</AvatarTransform>
		</OnPunchUpdate>

		<OnPunchStart>
			<ParticleSystemUpdate name="punch_particle" />
		</OnPunchStart>

		<RenderInFront>
			<SpriteRender name="s_lightning" alignment="DOWN_CENTER"
				onAction="JUMP|FALL|IDLE|WALK|PUNCH" drawShadow="false" />
		</RenderInFront>

		<RenderBehind>
			<ParticleSystemRender name="particle_trail" />
			<ParticleSystemRender name="particle_fire" />
		</RenderBehind>

		<AddClothingParticles>
			<ParticleSystemUpdate name="particle_trail" onAction="WALK|JUMP|FALL" />
			<ParticleSystemUpdate name="crack_particle" onAction="WALK" />
		</AddClothingParticles>

		<SwitchOffClothingParticles>
			<ParticleSystemOff name="punch_particle" />
			<ParticleSystemOff name="particle_trail" />
			<ParticleSystemOff name="crack_particle" />
		</SwitchOffClothingParticles>
	</RenderRules>
</ItemRenderer>
    
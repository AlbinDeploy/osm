<?xml version="1.0"?>
//XML MADE BY HENN
<ItemRenderer>
  <Data>
		<StateMachines>
			<StateMachine name="playerState">
				<States>
					<State name="Idle"/>
					<State name="Move"/>
					<State name="Fall"/>
					<State name="Jump"/>
					<State name="DoubleJump"/>
					<State name="SpiritGuide"/>
				</States>
				<Transitions>
					<Transition from="SpiritGuide|Jump|Fall|Move|DoubleJump" to="Idle" >
						<Condition>
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Jump|Fall|Idle|DoubleJump" to="Move">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>WALK</IsAction>
						</Condition>
					</Transition>				
					<Transition from="Move|Jump|Fall|Idle|DoubleJump" to="SpiritGuide">
						<Condition type="and">
							<IsWearing slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0</IsVariableFloat>
							<IsAction operatorType="NotEqual">FALL</IsAction>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Fall|Move|Idle" to="Jump">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>JUMP</IsAction>
						</Condition>
					</Transition>
					<Transition from="Jump|Fall" to="DoubleJump">
						<Condition>
							<IsAction>JUMPDOUBLE</IsAction>
						</Condition>
					</Transition>
					<Transition from="DoubleJump|SpiritGuide|Jump|Idle|Move" to="Fall">
						<Condition type="and">
							<IsVariableFloat name="speed.y" operator="Greater" abs="false">0.01</IsVariableFloat>
							<IsAction>FALL</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>

    <Sprite name="s_cloakBack" fileName="game/c_96x64.rttex" textureSize="96,64"/>
    <Sprite name="s_cloakFront" fileName="game/gtfy_wn.rttex" textureSize="64" frame="0,18"/>
	
	<Sprite name="trail_Sprite" fileName="game/particles.rttex" textureSize="32" frame="3,0"/>
	<Sprite name="HitSpark_Sprite" fileName="game/particles.rttex" textureSize="32"/>
	<Sprite name="crack_sprite" fileName="game/particles11.rttex" textureSize="32" frame="24,1"/>
	
    <Sprite name="s_sparkle" fileName="game/gtfy_wn.rttex" textureSize="64"/>
    <Sprite name="s_particles" fileName="game/gtfy_wn.rttex" textureSize="64" frame="0,16"/>
    <Sprite name="Hit_fx_Sprite" fileName="game/gtfy_wn.rttex" textureSize="64"/>
    <Sprite name="Hit_fire" fileName="game/gtfy_wn.rttex" textureSize="64" frame="5,17"/>    
        
    <Animations>
      <SpriteAnimation name="a_cloakback" sprite="s_cloakBack" playOnState="playerState.Idle|playerState.Fall|playerState.Jump|playerState.DoubleJump|playerState.Move" animTime="600" autoPlay="true" isLoop="true">
        <Frame>0,0</Frame>
        <Frame>1,0</Frame>
        <Frame>2,0</Frame>
        <Frame>3,0</Frame>
        <Frame>4,0</Frame>
      </SpriteAnimation>
      <SpriteAnimation name="a_cloakfront" sprite="s_cloakFront" playOnState="playerState.Idle|playerState.Fall|playerState.Jump|playerState.DoubleJump" animTime="600" autoPlay="true" isLoop="true">
        <Frame>0,18</Frame>
        <Frame>1,18</Frame>
        <Frame>2,18</Frame>
        <Frame>3,18</Frame>
        <Frame>4,18</Frame>
        <Frame>5,18</Frame>
      </SpriteAnimation>
      <SpriteAnimation name="a_cloakfront1" sprite="s_cloakFront" playOnState="playerState.Move" animTime="100" isLoop="false">
        <Frame>0,19</Frame>
      </SpriteAnimation>
      <SpriteAnimation name="a_particles" sprite="s_particles" playOnState="playerState.Idle|playerState.Fall|playerState.Jump|playerState.DoubleJump|playerState.Move" animTime="600" autoPlay="true" isLoop="true">
        <Frame>0,16</Frame>
        <Frame>1,16</Frame>
        <Frame>2,16</Frame>
        <Frame>3,16</Frame>
        <Frame>4,16</Frame>
        <Frame>5,16</Frame>
        <Frame>6,16</Frame>
        <Frame>7,16</Frame>        
      </SpriteAnimation>
      <SpriteAnimation name="a_Sparkles" sprite="s_sparkle" animTime="300" autoPlay="true" isLoop="true">
        <Frame>0,17</Frame>
        <Frame>1,17</Frame>
        <Frame>2,17</Frame>
      </SpriteAnimation>
	  <SpriteAnimation name="trail_anim" autoPlay="true" sprite="trail_Sprite" animTime="1200">
    	<Frame>3,0</Frame>
	    <Frame>4,0</Frame>
	  </SpriteAnimation>
  	<SpriteAnimation name="HitSpark_Anim" autoPlay="false" isLoop="false" sprite="HitSpark_Sprite"  animTime="200">
		<Frame>7,5</Frame>
		<Frame>8,5</Frame>
		<Frame>9,5</Frame>        
  	</SpriteAnimation>
      <SpriteAnimation name="hit_fx_Sprites" autoPlay="false" sprite="Hit_fx_Sprite">
        <Frame>3,17</Frame>
        <Frame>4,17</Frame>
      </SpriteAnimation>                                      
    </Animations>
    
    <ParticleSystems>    
      <ParticleSystem name="ps_SparklesTrail">
        <Emitter>
          <Set name="offset">0,0</Set>
          <Set name="offsetFacing">true</Set>
          <Set name="emissionInterval">0.1</Set>
          <Set name="infParticles">true</Set>
          <Set name="infLifeTime">true</Set>
          <Set name="particlesPerEmission">2</Set>
          <Set name="particlesToEmit">2</Set>
        </Emitter>
        <Particle>
          <Set name="sprite">s_sparkle</Set>
          <Random name="offset" min="-28, -16" max="28, 0" />
          <Set name="inSpecificOrder">true</Set>
          <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          <Curve name="initialAlpha">
            <KeyFrame>0, 1</KeyFrame>
            <KeyFrame>0.8, 1</KeyFrame>
            <KeyFrame>1, 0</KeyFrame>
          </Curve>

          <Select name="lifeTime" input="randomNumber">
            <Item>0.3</Item>
            <Item>0.6</Item>
          </Select>
          <Random name="initialScale" min="0.5" max="0.8" />
          <Random name="initialAngle" min="0" max="360" />
        </Particle>
      </ParticleSystem>
			<ParticleSystem name="hitSpark_particle" secondary="trail_particle">
				<Emitter>
					<Set name="particlesPerEmission">8</Set>
					<Set name="lifeTime">2</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">HitSpark_Sprite</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
				    <Set name="initalRGB">80, 30, 255</Set>                    
					<Set name="useGravity">true</Set>
					<Set name="interpolateScale">true</Set>
					<Set name="initialScale">2,2</Set>
					<Random name="finalScale" min="0.1, 0.1" max="0.4, 0.4"/>
					<Set name="lifeTime">1</Set>
					<RandomRadial name="initialVelocity" angleRange="30,330" radiusRange="80,200"/>
					<Set name="gravityVector">0, 100</Set>
					<Random name="initialRotationRate" min="-300" max="300"/>
					<Random name="posOffset" min="0.1, 0" max="16.1, 16.3"/>
				</Particle>
			</ParticleSystem>      
			<ParticleSystem name="trail_particle">
				<Emitter>
					<Set name="lifeTime">1</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">80</Set>
					<Set name="emissionInterval">0.2</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">trail_Sprite</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">1.2</Set>
					<Set name="initialRotationRate">150</Set>
					<Curve name="initialScale">
						<KeyFrame>0, 0, 0</KeyFrame>
						<KeyFrame>0.4, 1, 1</KeyFrame>
						<KeyFrame>0.8, 0.3, 0.3</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0.5</KeyFrame>
						<KeyFrame>0.8, 0</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="initialVelocity">0,0</Set>
				</Particle>
			</ParticleSystem>
      <ParticleSystem name="hit_particle">
        <Emitter>
          <Set name="lifeTime">0.3</Set>
          <Set name="particlesPerEmission">1</Set>
          <Set name="particlesToEmit">1</Set>
          <Set name="emissionInterval">0.2</Set>
          <Set name="infParticles">true</Set>
        </Emitter>
        <Particle randomSpriteFrame="true">
          <Set name="sprite">Hit_fx_Sprite</Set>
          <Set name="blendingMode">ADDITIVE</Set>
		  <Set name="initalRGB">80, 30, 255</Set>          
          <Set name="lifeTime">1</Set>
          <Random name="initialAngle" min="-75" max="75"/>
          <Curve name="initialAlpha">
            <KeyFrame>0, 1</KeyFrame>
            <KeyFrame>0.5, 1</KeyFrame>
            <KeyFrame>1, 0</KeyFrame>
          </Curve>
          <Curve name="initialScale">
            <KeyFrame>0, 0.75,0.75</KeyFrame>
            <KeyFrame>0.5, 1.25,1.25</KeyFrame>
            <KeyFrame>1, 1.25,1.25</KeyFrame>
          </Curve>
        </Particle>
      </ParticleSystem>
			<ParticleSystem name="hitFire_particle">
				<Emitter>
					<Set name="particlesPerEmission">8</Set>
					<Set name="lifeTime">2</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">Hit_fire</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Set name="useGravity">true</Set>
					<Set name="interpolateScale">true</Set>
					<Set name="initialScale">1,1</Set>
					<Random name="finalScale" min="0.1, 0.1" max="0.4, 0.4"/>
					<Set name="lifeTime">1</Set>
					<RandomRadial name="initialVelocity" angleRange="30,330" radiusRange="80,200"/>
					<Set name="gravityVector">0, 100</Set>
					<Random name="initialRotationRate" min="-300" max="300"/>
					<Random name="posOffset" min="0.1, 0" max="20.1, 20.3"/>
				</Particle>
			</ParticleSystem>                        
    </ParticleSystems>
    
    	<TileStampData>
      		<Set name="FileName">game/particles11.rttex</Set>
      		<Set name="EndFrame">27,1</Set>
      		<Set name="FrameCount">4</Set>
    	</TileStampData>    
    
    <RenderOptions>
      <Default>
        <Set name="ShouldHover">true</Set>
        <Set name="UserNameOffset">6</Set>
      </Default>
    </RenderOptions>
    
  </Data>
  <RenderRules>
    <RenderBackpack>
      <SpriteRender name="s_cloakBack" offset="-15,-20" alignment="CENTER"/>
     <AvatarSilhouetteRender color="255,255,255,255" emissionInterval="0.35" onState="playerState.Move|playerState.Jump|playerState.Fall"/>
      <ParticleSystemRender name="ps_SparklesTrail"/> 
      <StopIf> 
        <IsZombified>true</IsZombified> 
      </StopIf>     
     </RenderBackpack>

    <RenderInFront>
      <SpriteRender name="s_cloakFront" offset="0,12" alignment="DOWN_CENTER"/>
      <SpriteRender name="s_particles" offset="0,12" alignment="DOWN_CENTER"/>      
    </RenderInFront>
    
    <AddClothingParticles>
      <ParticleSystemUpdate name="ps_SparklesTrail" onState="playerState.Move|playerState.Idle|playerState.Jump|playerState.Fall"/>
    </AddClothingParticles>
        
    <OnDamagedTile>
      <ParticleSystemUpdate name="hit_particle"/>
    </OnDamagedTile>
    
		<OnDestroyedTile>
		  <ParticleSystemUpdate name="hitSpark_particle"/>
		  <ParticleSystemUpdate name="hitFire_particle"/>          
		</OnDestroyedTile>    
        
		<SwitchOffClothingParticles>
			<ParticleSystemOff name="hitSpark_particle"/>
			<ParticleSystemOff name="hit_particle"/> 
			<ParticleSystemOff name="hitFire_particle"/>                       
		</SwitchOffClothingParticles>                
  </RenderRules>
</ItemRenderer>
    
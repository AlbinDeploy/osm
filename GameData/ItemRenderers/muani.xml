<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
  <Data>

    <Sprite name="s_bow_effect" fileName="game/server_1812/muani_effect.rttex" textureSize="256"/>
    <Sprite name="s_arrow" fileName="game/server_1812/muani_effect.rttex" textureSize="256" frame="1,2"/>
    <Sprite name="s_tileArrow" fileName="game/server_1812/muani_effect.rttex" textureSize="256"/>
    <Sprite name="s_ember" fileName="game/server_1812/particles11.rttex" textureSize="32"/>

    <StateMachines>
      <StateMachine name="Punch">
        <States>
          <State name="True"/>
          <State name="False"/>
        </States>

        <Transitions>
          <Transition from="False" to="True">
            <Condition type="and">
              <IsAction>PUNCH</IsAction>
              <IsZombified>false</IsZombified>
            </Condition>
          </Transition>

          <Transition from="True" to="False">
            <Condition>
              <IsAction operatorType="NotEqual">PUNCH</IsAction>
            </Condition>
          </Transition>
        </Transitions>
      </StateMachine>
    </StateMachines>

    <Animations>
      <SpriteAnimation
        name="a_bow_effect"
        sprite="s_bow_effect"
        animTime="200"
        autoPlay="true"
        playOnAction="PUNCH"
        isLoop="true">
        <Frame>0,0</Frame>
        <Frame>1,0</Frame>
        <Frame>2,0</Frame>
      </SpriteAnimation>

      <SpriteAnimation name="a_tileArrow" sprite="s_tileArrow" animTime="500">
        <Frame>0,2</Frame>
        <Frame>0,1</Frame>
        <Frame>1,1</Frame>
        <Frame>2,1</Frame>
      </SpriteAnimation>

      <SpriteAnimation name="a_ember" sprite="s_ember">
        <Frame>5,26</Frame>
        <Frame>6,26</Frame>
      </SpriteAnimation>
    </Animations>

    <VariableMap>
      <Set name="projectile_offset">0, 0</Set>
      <Set name="projectile_angle">0</Set>
    </VariableMap>

    <ParticleSystems>

      <ParticleSystem name="ps_punchProjectile" updateStage="RenderBackHandItem" updateState="Punch.True">
        <Emitter attachment="handspotRoot">
          <Set name="offset">-3, 0</Set>
          <Set name="lifeTime">0.3</Set>
          <Set name="emissionInterval">0.05</Set>
          <Set name="infParticles">true</Set>
          <Set name="checkParticleNumToEmit">true</Set>
          <Set name="particlesPerEmission">1</Set>
          <Set name="particlesToEmit">1</Set>
        </Emitter>

        <Particle randomSpriteFrame="true">
          <Set name="sprite">s_arrow</Set>
          <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          <Set name="lifeTime">0.2</Set>
          <Set name="initialScale">0.4,0.4</Set>

          <Random name="targetPosOffset" min="-12,-11" max="12,11"/>
          <VectorTo name="initialVelocity" source="targetPos" offset="targetPosOffset" duration="lifeTime" x="1" angleOutVar="projectile_angle"/>

          <Set name="rotateWithVelocity">true</Set>
          <SetVar name="projectile_offset" source="targetPosOffset"/>
        </Particle>
      </ParticleSystem>

      <ParticleSystem name="ps_tileArrow">
        <Emitter>
          <Set name="infParticles">true</Set>
          <Set name="checkParticleNumToEmit">true</Set>
          <Set name="particlesPerEmission">1</Set>
          <Set name="particlesToEmit">1</Set>
        </Emitter>

        <Particle>
          <Set name="sprite">s_tileArrow</Set>
          <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          <Set name="lifeTime">0.5</Set>
          <Set name="initialScale">0.4,0.4</Set>
          <Set name="offset" source="projectile_offset"/>
          <Set name="initialAngle" source="projectile_angle"/>
        </Particle>
      </ParticleSystem>

      <ParticleSystem name="ps_hitEmbers">
        <Emitter>
          <Set name="lifeTime">0.25</Set>
          <Set name="particlesPerEmission">8</Set>
          <Set name="particlesToEmit">1</Set>
        </Emitter>

        <Particle randomSpriteFrame="true">
          <Set name="sprite">s_ember</Set>
          <Set name="blendingMode">ADDITIVE</Set>
          <Set name="lifeTime">1</Set>
          <Curve name="initialAlpha">
            <KeyFrame>0, 1</KeyFrame>
            <KeyFrame>1, 0</KeyFrame>
          </Curve>
          <Curve name="initialScale">
            <KeyFrame>0, 1,1</KeyFrame>
            <KeyFrame>1, 0.25,0.25</KeyFrame>
          </Curve>
          <Random name="initialRotationRate" min="5" max="15" />
          <Random name="offset" min="-4,-3" max="4,3" />
          <Set name="useGravity">true</Set>
          <Set name="gravityVector">0, 100</Set>
          <RandomRadial name="initialVelocity" angleRange="45,315" radiusRange="80,200" />
        </Particle>
      </ParticleSystem>

    </ParticleSystems>

    <RenderOptions>
      <Default>
        <Set name="PunchSoundOverride">HAND</Set>
        <Set name="DefaultPunchSound">audio/bow_ferry_punch.wav</Set>
        <Set name="PlayDefaultPunchAudio">true</Set>

        <Set name="IgnoreDefaultDamagedTileEffect">true</Set>
        <Set name="IncludeAllActions">true</Set>
        <Set name="HideParticlesOnTransform">true</Set>
      </Default>
    </RenderOptions>

  </Data>

  <RenderRules>

    <RenderBackHandItem>

      <StopIf>
        <IsAction>BUILD</IsAction>
      </StopIf>

      <StopIf type="and">
        <IsZombified>true</IsZombified>
        <IsAction>PUNCH</IsAction>
      </StopIf>

      <SpriteRender
        name="s_bow_effect"
        offset="-5,-7"
        alignment="CENTER"
        rotateOffset="true"
        rotateToTarget="true"
        drawShadow="false"
        blend="PREMULTIPLIED_ALPHA"
        scale="0.4,0.4"
        onAction="PUNCH"/>
    </RenderBackHandItem>

    <OnPunchUpdate>
      <AvatarTransform class="Face">
        <Set name="face">MAD</Set>
      </AvatarTransform>

      <AvatarTransform class="ArmAngle">
        <Set name="armName">arm1Angle</Set>
        <Set name="pointTowardsPunchTarget">true</Set>
      </AvatarTransform>

      <AvatarTransform class="ArmAngle">
        <Set name="armName">arm2Angle</Set>
        <Set name="armAngle">1500</Set>
        <Set name="isAdditive">true</Set>
      </AvatarTransform>
    </OnPunchUpdate>

    <OnDamagedTile>
      <ParticleSystemUpdate name="ps_tileArrow" />
      <ParticleSystemUpdate name="ps_hitEmbers" />
    </OnDamagedTile>

  </RenderRules>
</ItemRenderer>
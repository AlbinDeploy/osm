<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
		<StateMachines>
			<StateMachine name="playerState">
				<States>
					<State name="Idle"/>
					<State name="Punch"/>
					<State name="ZombiePunch"/>
				</States>
				<Transitions>
					<Transition from="ZombiePunch|Punch" to="Idle" >
						<Condition>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition from="ZombiePunch|Idle" to="Punch">
						<Condition type="and">
							<IsAction>PUNCH</IsAction>
							<IsZombified>false</IsZombified>
						</Condition>
					</Transition>
					<Transition from="Idle|Punch" to="ZombiePunch">
						<Condition type="and">
							<IsAction>PUNCH</IsAction>
							<IsZombified>true</IsZombified>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>

		<Sprite name="sword_sprite" fileName="game/scythe23.rttex" textureSize="64,32" frame="0,0"/>
		<Sprite name="sword_slash_Sprite" fileName="game/particles.rttex" textureSize="32" frame="3,3"/>

		<ParticleSystems>
			 <ParticleSystem name="slash_particle" updateStage="OnPunchStart">
				<Emitter>
					<Set name="offset">0,-18</Set>
					<Set name="emissionInterval">0.25</Set>
					<Set name="lifeTime">0.25</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">sword_slash_Sprite</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.4</Set>
					<Set name="interpolateScale">true</Set>
					<Set name="rotateWithVelocity">true</Set>
					<Set name="finalScale">4.3,4.3</Set>
					<Set name="interpolateVelocity">true</Set>
					<VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="1" angle="0"/>
					<VectorTo name="finalVelocity" source="targetPos" duration="lifeTime" x="1" angle="0"/>
					<Random name="flipX" min="false" max="true"/>
					<Random name="flipY" min="false" max="true"/>
				</Particle>
			</ParticleSystem>
		</ParticleSystems>
		
		<RenderOptions>
			<Default>
				<Set name="DefaultRenderMannequinHandItem">false</Set>
				<Set name="HideParticlesOnTransform">false</Set>
				<Set name="PunchSoundOverride">HAND</Set>
				<Set name="RenderBackArmBuild">false</Set>
				<Set name="RenderFrontArmInfected">true</Set>
				<Set name="RenderBackArmInfected">true</Set>
			</Default>
		</RenderOptions>
	</Data>

	<RenderRules>
        <Update>
            <StopIf>
                <IsZombified>true</IsZombified>
            </StopIf>
            <AvatarTransform class="ArmAngle" onAction="IDLE|WALK|JUMP|JUMPSTART|FALL|DANCE">
                <Set name="armName">arm1Angle</Set>
                <Set name="armAngle">-130</Set>
            </AvatarTransform>
        </Update>
		<RenderBackHandItem>
			<SpriteRender name="sword_sprite" offset="-1, 5" rotationPoint="0,1" alignment="CENTER" rotateOffset="true" scale="5.5,5.5" blend="PREMULTIPLIED_ALPHA"/>
		</RenderBackHandItem>
		<OnPunchUpdate>
			<AvatarTransform class="Face">
				<Set name="face">MAD</Set>
			</AvatarTransform>
            <AvatarTransform class="ArmAngle">
				<Set name="armName">arm1Angle</Set>
				<Set name="armAngle">1080</Set>
				<Set name="isAdditive">true</Set>
			</AvatarTransform>
		</OnPunchUpdate>
	</RenderRules>
</ItemRenderer>
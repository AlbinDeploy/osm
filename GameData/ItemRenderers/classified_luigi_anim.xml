<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
		<Sprite name="mario_idle" fileName="game/classified_luigi_p1.rttex" textureSize="256,450"/>
		<Sprite name="mario_walk" fileName="game/classified_luigi_p2.rttex" textureSize="256,278"/>
		<Sprite name="mario_jump" fileName="game/classified_luigi_p2.rttex" textureSize="256,278"/>
		<Sprite name="mario_fall" fileName="game/classified_luigi_p2.rttex" textureSize="256,278"/>
		<StateMachines>
			<StateMachine name="Motion">
				<States>
				<State name="Idle" />
				<State name="Move" />
				<State name="Jump" />
				<State name="Fall" />
			</States>
			<Transitions>
			
				<Transition to="Idle" from="Fall|Move|Jump" >
					<Condition type="and">
						<IsVariableBool name="onGround">true</IsVariableBool>
						<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						<IsVariableBool name="isAttacking">false</IsVariableBool>
					</Condition>
				</Transition>
				<Transition to="Move" from="Jump|Fall|Idle" >
					<Condition type="and">
						<IsVariableBool name="onGround">true</IsVariableBool>
						<IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
					</Condition>
				</Transition>
				<Transition to="Jump" from="Idle|Move|Fall" >
					<Condition type="and">
						<IsVariableBool name="onGround">false</IsVariableBool>
						<IsVariableFloat name="speed.y" operator="Less">-0.1</IsVariableFloat>
					</Condition>
				</Transition>
				<Transition to="Fall" from="Jump|Idle|Move" >
					<Condition type="and">
						<IsVariableBool name="onGround">false</IsVariableBool>
						<IsVariableFloat name="speed.y" operator="Greater">0.1</IsVariableFloat>
					</Condition>
				</Transition>
				
			</Transitions>
			</StateMachine>
		</StateMachines>
		<Animations>
			<SpriteAnimation name="mario_Idle_Animation" playOnState="Motion.Idle" sprite="mario_idle" animTime="550" isLoop="true">
				<Frame>0,0</Frame><Frame>1,0</Frame><Frame>2,0</Frame><Frame>3,0</Frame><Frame>4,0</Frame><Frame>5,0</Frame><Frame>6,0</Frame><Frame>7,0</Frame>
				<Frame>8,0</Frame><Frame>9,0</Frame><Frame>10,0</Frame><Frame>11,0</Frame><Frame>12,0</Frame><Frame>13,0</Frame><Frame>14,0</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="mario_Jump_Animation" playOnState="Motion.Jump" sprite="mario_jump" animTime="350">
				<Frame>0,4</Frame><Frame>1,4</Frame><Frame>2,4</Frame><Frame>3,4</Frame><Frame>4,4</Frame><Frame>5,4</Frame><Frame>6,4</Frame><Frame>7,4</Frame>
				<Frame>8,4</Frame><Frame>9,4</Frame><Frame>10,4</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="mario_Fall_Animation" playOnState="Motion.Fall" sprite="mario_fall" animTime="250">
				<Frame>0,2</Frame><Frame>1,2</Frame><Frame>2,2</Frame><Frame>3,2</Frame><Frame>4,2</Frame><Frame>5,2</Frame><Frame>6,2</Frame><Frame>7,2</Frame>
				<Frame>8,2</Frame><Frame>9,2</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="mario_Walk_Animation" playOnState="Motion.Move" sprite="mario_walk" animTime="350">
				<Frame>0,3</Frame><Frame>1,3</Frame><Frame>2,3</Frame><Frame>3,3</Frame><Frame>4,3</Frame><Frame>5,3</Frame><Frame>6,3</Frame><Frame>7,3</Frame>
				<Frame>8,3</Frame><Frame>9,3</Frame>
				
			</SpriteAnimation>
		</Animations>
		<ParticleSystems>
		</ParticleSystems>
		<RenderOptions>
			<Default>
				<Set name="JumpEndStateRange">100</Set>
				<Set name="ClothingOffsetFromShoes">10</Set>
				<Set name="UserNameOffset">40</Set>
				<Set name="IncludeAllActions">true</Set>
				<Set name="IgnoreDefaultDamagedTileEffect">true</Set>
				<Set name="IgnoreDefaultDestroyedTileEffect">true</Set>
			</Default>

		</RenderOptions>
	</Data>
	<RenderRules>
		<RenderTransform>
			<StopIf>
				<IsVariableBool name="isMannequin">true</IsVariableBool>
				<IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
			</StopIf>
			<SpriteRender name="mario_idle" offset="0,-20" drawShadow="true" onState="Motion.Idle" scale="0.2,0.2"/>
			<SpriteRender name="mario_walk" offset="0,-20" drawShadow="true" onState="Motion.Move" scale="0.35,0.35"/>
			<SpriteRender name="mario_jump" offset="0,-20" drawShadow="true" onState="Motion.Jump" scale="0.35,0.35"/>
			<SpriteRender name="mario_fall" offset="0,-20" drawShadow="true" onState="Motion.Fall" scale="0.35,0.35"/>
		</RenderTransform>
		<RenderShoes>
			<StopIf>
				<IsSitting>true</IsSitting>
				<IsSleepingOnaBed>true</IsSleepingOnaBed>
				<IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
			</StopIf>
		</RenderShoes>
	</RenderRules>
</ItemRenderer>
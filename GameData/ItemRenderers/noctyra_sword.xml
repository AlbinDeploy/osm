<?xml version="1.0"?>
<ItemRenderer>
	<Data>
		<Sprite name="s_scythe" fileName="game/noctyra_sword.rttex" textureSize="208"/>
		<Sprite name="s_punch_eff" fileName="game/noctyra_punch.rttex" textureSize="336"/>
		<Sprite name="s_punchCurve" fileName="game/noctyra_particle.rttex" textureSize="32"/>
		<Sprite name="s_sparkle" fileName="game/particles9.rttex" textureSize="32"/>
		<Sprite name="s_DestroyImpact" fileName="game/noctyra_punch.rttex" textureSize="336"/>
		<Sprite name="s_breakflame" fileName="game/noctyra_particle.rttex" textureSize="32"/>
		<Animations>
			<SpriteAnimation name="a_Attack_particle" sprite="s_punchCurve" animTime="700" isLoop="true">
				<Frame>2,4</Frame>
				<Frame>3,4</Frame>
				<Frame>4,4</Frame>
				<Frame>5,4</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="a_hell_punch" sprite="s_punch_eff" animTime="400" autoPlay="true" playOnAction="PUNCH" isLoop="true">
				<Frame>2,1</Frame>
				<Frame>3,1</Frame>
				<Frame>0,2</Frame>
				<Frame>1,2</Frame>
				<Frame>2,2</Frame>
				<Frame>3,2</Frame>
				<Frame>0,3</Frame>
				<Frame>1,3</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="a_snowflakes" sprite="s_breakflame" animTime="300" >
				<Frame>4,2</Frame>
				<Frame>5,2</Frame>
				<Frame>0,3</Frame>
				<Frame>1,3</Frame>
				<Frame>2,3</Frame>
				<Frame>3,3</Frame>
				<Frame>4,3</Frame>
				<Frame>5,3</Frame>
				<Frame>0,4</Frame>
				<Frame>1,4</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="a_snowflakesHit" sprite="s_DestroyImpact" animTime="400" >
				<Frame>0,0</Frame>
				<Frame>1,0</Frame>
				<Frame>2,0</Frame>
				<Frame>3,0</Frame>
				<Frame>0,1</Frame>
				<Frame>1,1</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="a_Sparkles" sprite="s_sparkle" animTime="300" autoPlay="true" isLoop="true">
				<Frame>8,8</Frame>
				<Frame>9,8</Frame>
				<Frame>10,8</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="a_hell_after" sprite="s_scythe" animTime="1000" isLoop="true" autoPlay="true" >
				<Frame>0,0</Frame>
				<Frame>1,0</Frame>
				<Frame>2,0</Frame>
				<Frame>0,1</Frame>
				<Frame>1,1</Frame>
				<Frame>2,1</Frame>
				<Frame>0,2</Frame>
				<Frame>1,2</Frame>
			</SpriteAnimation>
			<InterpolationVec4Animation name="SwordProxy" variableName="Sword_rotation" targetValue="45, 0, 0, 1" animTime="2000" playOnState="Punch.False"/>
		</Animations>
			<ParticleSystems>
				<ParticleSystem name="ps_SparklesTrail" updateState="Motion.Move" updateStage="AddClothingParticles" renderStage="RenderInFront">
					<Emitter>
						<Set name="offset">0,0</Set>
						<Set name="offsetFacing">true</Set>
						<Set name="emissionInterval">0.1</Set>
						<Set name="infParticles">true</Set>
						<Set name="infLifeTime">true</Set>
						<Set name="particlesPerEmission">2</Set>
						<Set name="particlesToEmit">2</Set>
					</Emitter>
					<Particle>
						<Set name="sprite">s_sparkle</Set>
						<Random name="offset" min="-28, -16" max="28, 0" />
						<Set name="inSpecificOrder">true</Set>
						<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
						<Curve name="initialAlpha">
							<KeyFrame>0, 1</KeyFrame>
							<KeyFrame>0.8, 1</KeyFrame>
							<KeyFrame>1, 0</KeyFrame>
						</Curve>

						<Select name="lifeTime" input="randomNumber">
							<Item>0.3</Item>
							<Item>0.6</Item>
						</Select>
						<Random name="initialScale" min="0.5" max="0.8" />
						<Random name="initialAngle" min="0" max="360" />
					</Particle>
				</ParticleSystem>

				<ParticleSystem name="ps_breakflame" updateStage="OnDamagedTile">
					<Emitter>
						<Set name="particlesPerEmission">1</Set>
						<Set name="offset">0,0</Set>
						<Set name="emissionInterval">0.5</Set>
						<Set name="infParticles">true</Set>
						<Set name="particlesPerEmission">1</Set>
					</Emitter>
					<Particle>
						<Set name="sprite">s_breakflame</Set>
						<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
						<Curve name="initialScale">
							<KeyFrame>0, 1,1</KeyFrame>
							<KeyFrame>1, 1,1</KeyFrame>
						</Curve>
						<Curve name="initialAlpha">
							<KeyFrame>0, 1</KeyFrame>
							<KeyFrame>0.65, 1</KeyFrame>
							<KeyFrame>1, 0</KeyFrame>
						</Curve>
						<Set name="lifeTime">0.3</Set>
						<Random name="initialAngle" min="0" max="0" />
					</Particle>
				</ParticleSystem>
				<ParticleSystem name="ps_destroyImpact">
					<Emitter>
						<Set name="particlesPerEmission">1</Set>
					</Emitter>
					<Particle>
						<Set name="sprite">s_DestroyImpact</Set>
						<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
						<Set name="lifeTime">0.3</Set>
						<Random name="initialAngle" min="0" max="0" />
						<Curve name="initialScale">
							<KeyFrame>0, 1,1</KeyFrame>
							<KeyFrame>1, 1,1</KeyFrame>
						</Curve>
					</Particle>
				</ParticleSystem>
				<ParticleSystem name="ps_punchCurved" updateStage="OnPunchStart">
				<Emitter attachment="contextRotation">"
					<Set name="offset">0,-18</Set>
					<Set name="emissionInterval">0.25</Set>
					<Set name="lifeTime">0.25</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_punchCurve</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.2</Set>
					<Set name="rotateWithVelocity">true</Set>
					<Set name="interpolateAlpha">false</Set>
					<Set name="initialAlpha">1</Set>
					<Set name="finalAlpha">1</Set>
					<Set name="interpolateVelocity">true</Set>
					<Set name="initialScale">0.8,0.8</Set>
					<VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="1" angle="0"/>
					<VectorTo name="finalVelocity" source="targetPos" duration="lifeTime" x="1" angle="0"/>
				</Particle>
			</ParticleSystem>
		</ParticleSystems>
		<StateMachines>
			<StateMachine name="Motion">
				<States>
					<State name="Idle" />
					<State name="Move" />
					<State name="Jump" />
					<State name="Fall" />
					<State name="Punch"/>
				</States>
				<Transitions>
					<Transition to="Idle" from="Fall|Move|Jump|Punch" >
						<Condition type="and">
							<IsVariableBool name="onGround">true</IsVariableBool>
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
							<IsVariableBool name="isAttacking">false</IsVariableBool>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition to="Move" from="Jump|Fall|Idle|Punch" >
						<Condition type="and">
							<IsVariableBool name="onGround">true</IsVariableBool>
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition to="Jump" from="Idle|Move|Fall|Punch" >
						<Condition type="and">
							<IsVariableBool name="onGround">false</IsVariableBool>
							<IsVariableFloat name="speed.y" operator="Less">-0.1</IsVariableFloat>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition to="Fall" from="Jump|Idle|Move|Punch" >
						<Condition type="and">
							<IsVariableBool name="onGround">false</IsVariableBool>
							<IsVariableFloat name="speed.y" operator="Greater">0.1</IsVariableFloat>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition to="Punch" from="Idle|Move|Jump|Fall">
						<Condition type="and">
							<IsAction>PUNCH</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
			<StateMachine name="Punch">
				<States>
					<State name="False" />
					<State name="True" />
				</States>
				<Transitions>
					<Transition from="False" to="True">
						<Condition>
							<IsAction>PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition from="True" to="False">
						<Condition>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>
		<VariableMap>
			<Set name="Sword_rotation">0, 0, 0, 1</Set>
		</VariableMap>
		<RenderOptions>
			<Default>
				<Set name="IncludeAllActions">true</Set>
				<Set name="DefaultRenderMannequinHandItem">false</Set>
				<Set name="RenderBackArmBuild">false</Set>
				<Set name="RenderFrontArmInfected">true</Set>
				<Set name="RenderBackArmInfected">true</Set>
				<Set name="UserNameOffset">0</Set>
				<Set name="IgnoreDefaultDamagedTileEffect">true</Set>
				<Set name="IgnoreDefaultDestroyedTileEffect">true</Set>
			</Default>
		</RenderOptions>
		<TileStampData>
			<Set name="FileName">game/noctyra_particle.rttex</Set>
			<Set name="EndFrame">3,0</Set>
			<Set name="FrameCount">4</Set>
		</TileStampData>
	</Data>
	<RenderRules>
		<Update>
		</Update>
		<RenderInFront>
			<SpriteRender name="s_punch_eff" offset="10,-20" alignment="CENTER" rotateOffset="true" rotateToTarget="true" drawShadow="false" blend="PREMULTIPLIED_ALPHA" scale="0.8,0.8" onAction="PUNCH" />
		</RenderInFront>
		<RenderBehind>
			<StopIf >
				<IsZombified>true</IsZombified>
				<IsAction>PUNCH</IsAction>
			</StopIf>
			<Group>
				<Rotate>Sword_rotation</Rotate>
				<SpriteRender name="s_scythe" offset="7,5" alignment="CENTER" rotateOffset="true" blend="PREMULTIPLIED_ALPHA" scale="0.5,0.5" />
			</Group>
		</RenderBehind>
		<RenderBackHandItem>
				<SpriteRender name="s_scythe" offset="33,3" alignment="CENTER" rotateOffset="true" blend="PREMULTIPLIED_ALPHA" scale="0.5,0.5" onAction="PUNCH" />
		</RenderBackHandItem>
		<OnPunchUpdate>
			<StopIf>
				<IsZombified>true</IsZombified>
			</StopIf>
			<AvatarTransform class="Face">
				<Set name="face">MAD</Set>
			</AvatarTransform>
			<AvatarTransform class="ArmAngle">
				<Set name="armName">arm1Angle</Set>
				<Set name="armAngle">1200</Set>
				<Set name="isAdditive">true</Set>
				<Set name="pointTowardsPunchTarget">false</Set>
			</AvatarTransform>
		</OnPunchUpdate>
		<OnDamagedTile>
		</OnDamagedTile>
		<OnDestroyedTile>
			<ParticleSystemUpdate name="ps_destroyImpact" />
		</OnDestroyedTile>
	</RenderRules>
</ItemRenderer>

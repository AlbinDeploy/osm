<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
  <Data>
    
    <StateMachines>
      <StateMachine name="playerState">
        <States>
          <State name="Idle"/>
          <State name="Punch"/>
        </States>
        <Transitions>
          <Transition from="Punch" to="Idle" >
            <Condition>
              <IsAction operatorType="NotEqual">PUNCH</IsAction>
            </Condition>
          </Transition>
          <Transition from="Idle" to="Punch">
            <Condition>
              <IsAction>PUNCH</IsAction>
            </Condition>
          </Transition>
        </Transitions>
      </StateMachine>
    </StateMachines>


        <Sprite name="spiritSprite" fileName="game/gtfy_wn.rttex" textureSize="64" frame="4,6" />
		<Sprite name="meteor" fileName="game/gtfy_wn.rttex" textureSize="64" frame="4,5"/>
		<Sprite name="fire" fileName="game/particles11.rttex" textureSize="32" frame="24,19"/>

		
    <Animations>
      <SpriteSinPulseAnimation name="foot1_Stretch"  autoPlay="true" isLoop="true"
        sprite="spiritSprite">
        <Parameter name="scale.x">
          <Set name="offset">1</Set>
          <Set name="period">2500</Set>
          <Set name="scale">0.07</Set>
        </Parameter>
      </SpriteSinPulseAnimation>
      <SpriteSinPulseAnimation name="foot2_Stretch" autoPlay="true" isLoop="true"
        sprite="spiritSprite">
        <Parameter name="scale.y">
          <Set name="offset">1</Set>
          <Set name="period">2750</Set>
          <Set name="scale">0.07</Set>
        </Parameter>
      </SpriteSinPulseAnimation>
    </Animations>    

	
	<RenderOptions>
		<Default>
			<Set name="IncludeAllActions">true</Set>
			<Set name="UserNameOffset">15</Set>
			<Set name="HideParticlesOnTransform">false</Set>
			<Set name="PlayDefaultPunchAudio">true</Set>
		</Default>
	</RenderOptions>


    <ParticleSystems>      
      <ParticleSystem name="fire_particle">
				<Emitter attachment="targetPos">
					<Set name="infParticles">true</Set>
					<Set name="offset">0,-38</Set>
					<Set name="lifeTime">0.3</Set>
					<Set name="emissionInterval">0.08</Set>
					<Set name="particlesPerEmission">4</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">fire</Set>
					<Select name="offset" input="punchCount">
						<Item>-40, -36</Item>
						<Item>40, -36</Item>
						<Item>0, -46</Item>
					</Select>
					<Set name="blendingMode">ADDITIVE</Set>
					<Set name="rotateWithVelocity">true</Set>
					<Set name="initialAlpha">0.5</Set>
					<Set name="finalAlpha">0.1</Set>
					<Set name="interpolateAlpha">true</Set>
					<Random name="lifeTime" min="0.3" max="0.5"/>
					<Set name="interpolateScale">true</Set>
					<Set name="initialScale">1.5,1.5</Set>
					<Set name="finalScale">0.5,1.0</Set>
					<VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="1"/>
				</Particle>
			</ParticleSystem>	
			<ParticleSystem name="meteor_particle">
				<Emitter attachment="targetPos">
					<Set name="offset">0,-28</Set>
					<Set name="lifeTime">0.4</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">meteor</Set>
					<Select name="offset" input="punchCount">
						<Item>-40, -32</Item>
						<Item>40, -32</Item>
						<Item>0, -42</Item>
					</Select>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="rotateWithVelocity">true</Set>
					<Set name="lifeTime">0.4</Set>
					<VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="1"/>
				</Particle>
			</ParticleSystem>
    </ParticleSystems>
	
    <TileStampData>
		<Set name="FileName">game/particles11.rttex</Set>
		<Set name="EndFrame">27,1</Set>
		<Set name="FrameCount">4</Set>
	  </TileStampData>
  </Data>

  <RenderRules>
		<OnPunchUpdate>
			<AvatarTransform class="Face">
				<Set name="face">MAD</Set>
			</AvatarTransform>
			<AvatarTransform class="ArmAngle">
				<Set name="armName">arm1Angle</Set>
				<Set name="pointTowardsPunchTarget">true</Set>
			</AvatarTransform>
		</OnPunchUpdate>
		<OnPunchStart>
			<ParticleSystemUpdate name="fire_particle"/>
			<ParticleSystemUpdate name="meteor_particle"/>
		</OnPunchStart>
    <RenderBehind>
      <SpriteRender name="spiritSprite" rotateOffset="true" alignment="CENTER" offset="1,-41"
        scale="1.45,1.4" blend="PREMULTIPLIED_ALPHA" />
    </RenderBehind>
    <SwitchOffClothingParticles>
			<ParticleSystemOff name="fire_particle"/>
			<ParticleSystemOff name="meteor_particle"/>
    </SwitchOffClothingParticles>
  </RenderRules>
</ItemRenderer>
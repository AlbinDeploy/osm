<?xml version="1.0"?>

<ItemRenderer>
	<Data>
		<StateMachines>
			<StateMachine name="Motion">
				<States>
					<State name="Idle" />
					<State name="Move" />
					<State name="Punch" />
				</States>
				<Transitions>
					<Transition to="Idle" from="Move|Punch">
						<Condition type="and">
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition to="Move" from="Idle|Punch">
						<Condition type="and">
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition to="Punch" from="Idle|Move">
						<Condition>
							<IsAction>PUNCH</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
			<StateMachine name="Motion2">
				<States>
					<State name="Idle" />
					<State name="Move" />
					<State name="Punch" />
				</States>
				<Transitions>
					<Transition to="Idle" from="Move|Punch">
						<Condition type="and">
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition to="Move" from="Idle|Punch">
						<Condition type="and">
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition to="Punch" from="Idle|Move">
						<Condition>
							<IsAction>PUNCH</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>

		<Sprite name="s_Pet" fileName="game/mons_sprite.rttex" textureSize="128" frame="0,0"/>
		<Sprite name="p_Pet" fileName="game/mons_sprite.rttex" textureSize="128" frame="0,0"/>
		<Sprite name="hand" fileName="game/ci_n1.rttex" textureSize="32" frame="8,4" />

		<Sprite name="s_laser" fileName="game/ci_n1.rttex" textureSize="32" frame="8,5" />
		<Sprite name="s_laser2" fileName="game/ci_n1.rttex" textureSize="32" frame="9,5" />
		<Sprite name="s_trail1" fileName="game/ci_n1.rttex" textureSize="32" frame="10,5" />
		<Sprite name="s_trail2" fileName="game/ci_n1.rttex" textureSize="32" frame="10,5" />
		<Sprite name="HitSpark_Sprite" fileName="game/ci_n1.rttex" textureSize="32" />
		<Sprite name="crack_sprite" fileName="game/ci_n1.rttex" textureSize="32" frame="11,5" />
		<Sprite name="trail_Sprite" fileName="game/particles.rttex" textureSize="32" frame="3,0" />
		
		<Sprite name="Hit_fx_Sprite" fileName="game/gtfy_wn.rttex" textureSize="64" />

		<Animations>
			<SpriteCurveAnimation name="laser_anim" isLoop="true" playOnState="Motion.Punch"
				sprite="s_laser" animTime="225">
				<Curve name="alpha">
					<KeyFrame>0.f, 0.f</KeyFrame>
					<KeyFrame>0.286f, 0.40f </KeyFrame>
					<KeyFrame>0.4286f, 0.65f</KeyFrame>
					<KeyFrame>0.6142f, 1.f</KeyFrame>
					<KeyFrame>0.8263f, 1.f</KeyFrame>
					<KeyFrame>1.f, 0.45f</KeyFrame>
				</Curve>
			</SpriteCurveAnimation>
			<SpriteAnimation name="a_pet" sprite="s_Pet" animTime="800" isLoop="true"
				autoPlay="true">
				<Frame>0,0</Frame>
				<Frame>1,0</Frame>
				<Frame>2,0</Frame>
				<Frame>3,0</Frame>
				<Frame>4,0</Frame>
				<Frame>5,0</Frame>
				<Frame>6,0</Frame>
				<Frame>7,0</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="a_pet_punch" sprite="p_Pet" animTime="800" isLoop="true"
				playOnAction="PUNCH" autoPlay="true">
				<Frame>0,0</Frame>
				<Frame>1,0</Frame>
				<Frame>2,0</Frame>
				<Frame>3,0</Frame>
				<Frame>4,0</Frame>
				<Frame>5,0</Frame>
				<Frame>6,0</Frame>
				<Frame>7,0</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="a_hand" sprite="hand" animTime="800" isLoop="true"
				autoPlay="true">
				<Frame>8,4</Frame>
				<Frame>9,4</Frame>
				<Frame>10,4</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="trail_anim" autoPlay="true" sprite="trail_Sprite" animTime="1200">
				<Frame>3,0</Frame>
				<Frame>4,0</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="HitSpark_Anim" autoPlay="false" isLoop="false"
				sprite="HitSpark_Sprite" animTime="200">
				<Frame>15,5</Frame>
				<Frame>16,5</Frame>
				<Frame>17,5</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="hit_fx_Sprites" autoPlay="false" sprite="Hit_fx_Sprite">
				<Frame>8,9</Frame>
				<Frame>9,9</Frame>
			</SpriteAnimation>
		</Animations>

		<ParticleSystems>
			<ParticleSystem name="ps_Trail1" updateStage="RenderPet">
				<Emitter>
					<Random name="offset" min="0, -13" max="-30, -50" />
					<Set name="emissionInterval">0.05</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">4</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_trail1</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>0.2, 1</KeyFrame>
						<KeyFrame>0.6, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="inSpecificOrder">true</Set>
					<Curve name="initialScale">
						<KeyFrame>0, 0.3, 0.3</KeyFrame>
						<KeyFrame>1, 0.5, 0.5</KeyFrame>
					</Curve>
					<Set name="lifeTime">1.5</Set>
					<Random name="initialAngle" min="-180" max="180" />
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="ps_Trail2" updateStage="RenderPet">
				<Emitter>
					<Random name="offset" min="0, -13" max="-30, -50" />
					<Set name="emissionInterval">0.2</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">3</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_trail2</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>0.2, 1</KeyFrame>
						<KeyFrame>0.6, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="inSpecificOrder">true</Set>
					<Curve name="initialScale">
						<KeyFrame>0, 0.3, 0.3</KeyFrame>
						<KeyFrame>1, 0.5, 0.5</KeyFrame>
					</Curve>
					<Set name="lifeTime">1.5</Set>
					<Random name="initialAngle" min="-180" max="180" />
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="Laserpunch2" updateStage="RenderPet" updateState="Motion2.Punch">
				<Emitter>
					<Set name="offset">4, -19</Set>
					<Set name="lifeTime">0.072</Set>
					<Set name="infParticles">true</Set>
					<Set name="checkParticleNumToEmit">true</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">1</Set>
				</Emitter>
				<Particle usePlayerFacing="true">
					<Set name="sprite">s_laser2</Set>
					<Set name="relativeToEmitter">true</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Curve name="initialScale">
						<KeyFrame>0, 1.3, 1.3</KeyFrame>
						<KeyFrame>1, 1.5, 1.5</KeyFrame>
					</Curve>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="lifeTime">0.15</Set>
					<Set name="initialRotationRate">360</Set>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="hitSpark_particle" secondary="trail_particle">
				<Emitter>
					<Set name="particlesPerEmission">8</Set>
					<Set name="lifeTime">2</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">HitSpark_Sprite</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="useGravity">true</Set>
					<Set name="interpolateScale">true</Set>
					<Set name="initialScale">1,1</Set>
					<Random name="finalScale" min="0.1, 0.1" max="0.4, 0.4" />
					<Set name="lifeTime">1</Set>
					<RandomRadial name="initialVelocity" angleRange="30,330" radiusRange="80,200" />
					<Set name="gravityVector">0, 100</Set>
					<Random name="initialRotationRate" min="-300" max="300" />
					<Random name="posOffset" min="0.1, 0" max="16.1, 16.3" />
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="trail_particle">
				<Emitter>
					<Set name="lifeTime">1</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">80</Set>
					<Set name="emissionInterval">0.2</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">trail_Sprite</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">1.2</Set>
					<Set name="initialRotationRate">150</Set>
					<Curve name="initialScale">
						<KeyFrame>0, 0, 0</KeyFrame>
						<KeyFrame>0.4, 1, 1</KeyFrame>
						<KeyFrame>0.8, 0.3, 0.3</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0.5</KeyFrame>
						<KeyFrame>0.8, 0</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="initialVelocity">0,0</Set>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="hit_particle">
				<Emitter>
					<Set name="lifeTime">0.3</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">1</Set>
					<Set name="emissionInterval">0.2</Set>
					<Set name="infParticles">true</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">Hit_fx_Sprite</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Set name="initalRGB">80, 30, 255</Set>
					<Set name="lifeTime">1</Set>
					<Random name="initialAngle" min="-75" max="75" />
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>0.5, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 0.75,0.75</KeyFrame>
						<KeyFrame>0.5, 1.25,1.25</KeyFrame>
						<KeyFrame>1, 1.25,1.25</KeyFrame>
					</Curve>
				</Particle>
			</ParticleSystem>
		</ParticleSystems>

		<VariableMap>
			<Set name="projectile_offset">0, 0</Set>
			<Set name="projectile_angle">0</Set>
		</VariableMap>

		<TileStampData>
			<Set name="FileName">game/ci_n1.rttex</Set>
			<Set name="EndFrame">14,5</Set>
			<Set name="FrameCount">4</Set>
		</TileStampData>

		<RenderOptions>
			<Default>
				<Set name="NeedRenderPet">true</Set>
				<Set name="PetOffsetDuplication">0,0</Set>
				<Set name="IgnoreDefaultDamagedTileEffect">true</Set>
				<Set name="IgnoreDefaultDestroyedTileEffect">true</Set>
				<Set name="HideParticlesOnTransform">false</Set>
				<Set name="PunchSoundOverride">HAND</Set>
				<Set name="PlayDefaultPunchAudio">false</Set>
			</Default>
		</RenderOptions>
	</Data>

	<RenderRules>
		<RenderHandItem>
			<MusicSource onAction="PUNCH">
				<Set name="MusicFile">audio/laser.wav</Set>
				<Set name="FadeOutTimeMs">25</Set>
			</MusicSource>
			<SpriteRender name="hand" rotateOffset="true" offset="0,44" scale="1.5,1.5"
				alignment="DOWN_CENTER" blend="PREMULTIPLIED_ALPHA" />
		</RenderHandItem>

		<Update>
			<AvatarTransform class="ArmAngle" onAction="PUNCH">
				<Set name="armName">arm2Angle</Set>
				<Set name="armAngle">1700</Set>
				<Set name="isAdditive">true</Set>
				<Set name="pointTowardsPunchTarget">true</Set>
			</AvatarTransform>
		</Update>

		<OnPunchUpdate>
			<AvatarTransform class="Emotion">
				<Set name="emotion">ANGRY</Set>
			</AvatarTransform>
		</OnPunchUpdate>

		<RenderPet>
			<ParticleSystemRender name="ps_Trail1" />
			<ParticleSystemRender name="ps_Trail2" />
			<SpriteRender name="s_Pet" scale="0.5,0.5" alignment="DOWN_CENTER"
				onAction="IDLE|WALK|JUMP|JUMPSTART|FALL" offset="-5,10" />
			<SpriteRender name="p_Pet" scale="0.5,0.5" alignment="DOWN_CENTER" onAction="PUNCH"
				offset="-5,10" />
			<ParticleSystemRender name="Laserpunch2" />
			<SpriteRender name="s_laser" offset="0,-19" scale="1,0.7" onAction="PUNCH"
				blend="ADDITIVE" stretchToTarget="true" alignmentLeft="LEFT_CENTER"
				alignmentRight="RIGHT_CENTER" drawShadow="false" flip="1,0" />
		</RenderPet>

		<OnDamagedTile>
			<ParticleSystemUpdate name="hit_particle" />
		</OnDamagedTile>

		<OnDestroyedTile>
			<ParticleSystemUpdate name="hitSpark_particle" />
		</OnDestroyedTile>

		<SwitchOffClothingParticles>
			<ParticleSystemOff name="hitSpark_particle" />
			<ParticleSystemOff name="hit_particle" />
		</SwitchOffClothingParticles>
	</RenderRules>
</ItemRenderer>
    
<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer item="ITEM_ID_TRICKY_MARIO">
  <Data>
    <Sprite name="mario_idle" fileName="game/tricky_idle.rttex" textureSize="431,600" />
    <Sprite name="mario_walk" fileName="game/tricky_walk.rttex" textureSize="500,549" />
    <Sprite name="mario_jump" fileName="game/tricky_jump.rttex" textureSize="500,573" />
    <Sprite name="mario_fall" fileName="game/tricky_fall.rttex" textureSize="500,539" />

    <StateMachines>
      <StateMachine name="Motion">
        <States>
          <State name="Idle" />
          <State name="Move" />
          <State name="Jump" />
          <State name="Fall" />
          <State name="Punch" />
        </States>
        <Transitions>
          <Transition to="Idle" from="Fall|Move|Jump|Punch">
            <Condition type="and">
              <IsVariableBool name="onGround">true</IsVariableBool>
              <IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
              <IsVariableBool name="isAttacking">false</IsVariableBool>
              <IsAction operatorType="NotEqual">PUNCH</IsAction>
            </Condition>
          </Transition>
          <Transition to="Move" from="Jump|Fall|Idle|Punch">
            <Condition type="and">
              <IsVariableBool name="onGround">true</IsVariableBool>
              <IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
              <IsAction operatorType="NotEqual">PUNCH</IsAction>
            </Condition>
          </Transition>
          <Transition to="Jump" from="Idle|Move|Fall|Punch">
            <Condition type="and">
              <IsVariableBool name="onGround">false</IsVariableBool>
              <IsVariableFloat name="speed.y" operator="Less">-0.1</IsVariableFloat>
              <IsAction operatorType="NotEqual">PUNCH</IsAction>
            </Condition>
          </Transition>
          <Transition to="Fall" from="Jump|Idle|Move|Punch">
            <Condition type="and">
              <IsVariableBool name="onGround">false</IsVariableBool>
              <IsVariableFloat name="speed.y" operator="Greater">0.1</IsVariableFloat>
              <IsAction operatorType="NotEqual">PUNCH</IsAction>
            </Condition>
          </Transition>
          <Transition to="Punch" from="Idle|Move|Jump|Fall">
            <Condition>
              <IsAction>PUNCH</IsAction>
            </Condition>
          </Transition>
        </Transitions>
      </StateMachine>
    </StateMachines>

    <Animations>
      <SpriteAnimation name="mario_Idle_Animation" playOnState="Motion.Idle" sprite="mario_idle" animTime="500" isLoop="true">
        <Frame>0,0</Frame><Frame>1,0</Frame><Frame>2,0</Frame><Frame>3,0</Frame><Frame>4,0</Frame>
        <Frame>0,1</Frame><Frame>1,1</Frame><Frame>2,1</Frame><Frame>3,1</Frame><Frame>4,1</Frame>
        <Frame>0,2</Frame><Frame>1,2</Frame><Frame>2,2</Frame><Frame>3,2</Frame><Frame>4,2</Frame>
        <Frame>0,3</Frame><Frame>1,3</Frame><Frame>2,3</Frame><Frame>3,3</Frame><Frame>4,3</Frame>
        <Frame>0,4</Frame><Frame>1,4</Frame>
      </SpriteAnimation>

      <SpriteAnimation name="mario_Jump_Animation" playOnState="Motion.Jump" sprite="mario_jump" animTime="250" isLoop="true">
        <Frame>0,0</Frame><Frame>1,0</Frame><Frame>2,0</Frame><Frame>3,0</Frame><Frame>4,0</Frame>
        <Frame>0,1</Frame>
      </SpriteAnimation>

      <SpriteAnimation name="mario_Fall_Animation" playOnState="Motion.Fall" sprite="mario_fall" animTime="250" isLoop="true">
        <Frame>0,0</Frame><Frame>1,0</Frame><Frame>2,0</Frame><Frame>3,0</Frame><Frame>4,0</Frame>
        <Frame>0,1</Frame>
      </SpriteAnimation>

      <SpriteAnimation name="mario_Walk_Animation" playOnState="Motion.Move" sprite="mario_walk" animTime="250" isLoop="true">
        <Frame>0,0</Frame><Frame>1,0</Frame><Frame>2,0</Frame><Frame>3,0</Frame><Frame>4,0</Frame>
        <Frame>0,1</Frame>
      </SpriteAnimation>
    </Animations>

    <TileStampData>
      <Set name="FileName">game/particles9.rttex</Set>
      <Set name="EndFrame">28,17</Set>
      <Set name="FrameCount">4</Set>
    </TileStampData>

    <RenderOptions>
      <Default>
        <Set name="JumpEndStateRange">100</Set>
        <Set name="ClothingOffsetFromShoes">10000</Set>
        <Set name="IsRidingBird">true</Set>
        <Set name="IsVehicle">true</Set>
        <Set name="UserNameOffset">75</Set>
        <Set name="IncludeAllActions">true</Set>
        <Set name="IgnoreDefaultDamagedTileEffect">true</Set>
        <Set name="IgnoreDefaultDestroyedTileEffect">true</Set>
      </Default>
    </RenderOptions>
  </Data>

  <RenderRules>
    <RenderInFront>
      <StopIf>
        <IsVariableBool name="isMannequin">true</IsVariableBool>
        <IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
      </StopIf>

      <SpriteRender name="mario_idle" offset="0,-10075" drawShadow="true" onState="Motion.Idle|Motion.Punch" scale="0.27,0.27" />
      <SpriteRender name="mario_walk" offset="0,-10075" drawShadow="true" onState="Motion.Move" scale="0.27,0.27" />
      <SpriteRender name="mario_jump" offset="4,-10075" drawShadow="true" onState="Motion.Jump" scale="0.27,0.27" />
      <SpriteRender name="mario_fall" offset="0,-10075" drawShadow="true" onState="Motion.Fall" scale="0.27,0.27" />
    </RenderInFront>

    <RenderShoes>
      <StopIf>
        <IsSitting>true</IsSitting>
        <IsSleepingOnaBed>true</IsSleepingOnaBed>
        <IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
      </StopIf>
    </RenderShoes>
  </RenderRules>
</ItemRenderer>
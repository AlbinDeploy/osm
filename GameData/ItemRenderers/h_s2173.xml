<?xml version="1.0"?>
<ItemRenderer>
	<Data>
		<Sprite name="wyskee_h_scy" fileName="game/c_96x64.rttex" textureSize="96,64" frame="0,2" />
		
		<Sprite name="wyskee_rb_scy" fileName="game/ci_n1.rttex" textureSize="32" frame="1,33" />
		
		<Sprite name="wyskee_sh_scy" fileName="game/gtfy_wn.rttex" textureSize="64" frame="5,12" />
		<Sprite name="wyskee_s_scy" fileName="game/gtfy_wn.rttex" textureSize="64" frame="5,13" />
		<Sprite name="wyskee_a_scy" fileName="game/gtfy_wn.rttex" textureSize="64" frame="5,14" />
		<Animations>
			<SpriteAnimation name="wyskee_a1" sprite="wyskee_h_scy" animTime="800" isLoop="true"
				playOnState="WYSKEE.KEE|WYSKEE.WYS">
				<Frame>0,1</Frame>
				<Frame>1,1</Frame>
				<Frame>0,2</Frame><!--WYSKEE-->
				<Frame>1,2</Frame>
				<Frame>0,3</Frame>
				<Frame>1,3</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="wyskee_a4" sprite="wyskee_rb_scy" animTime="300">
				<Frame>1,33</Frame>
				<Frame>1,34</Frame><!--WYSKEE-->
				<Frame>2,33</Frame>
				<Frame>2,34</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="wyskee_a5" sprite="wyskee_sh_scy" animTime="800" isLoop="true">
				<Frame>5,12</Frame>
				<Frame>6,12</Frame>
				<Frame>7,12</Frame><!--WYSKEE-->
				<Frame>8,12</Frame>
				<Frame>9,12</Frame>
				<Frame>10,12</Frame>
				<Frame>11,12</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="wyskee_a2" sprite="wyskee_s_scy" animTime="300" isLoop="true"
				playOnState="WYSKEE.WYS">
				<Frame>5,13</Frame>
				<Frame>6,13</Frame>
				<Frame>7,13</Frame>
				<Frame>8,13</Frame><!--WYSKEE-->
				<Frame>9,13</Frame>
				<Frame>10,13</Frame>
				<Frame>11,13</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="wyskee_a3" sprite="wyskee_a_scy" animTime="800" isLoop="true"
				playOnState="WYSKEE.KEE|WYSKEE.WYS">
				<Frame>5,14</Frame>
				<Frame>6,14</Frame>
				<Frame>7,14</Frame><!--WYSKEE-->
				<Frame>8,14</Frame>
				<Frame>9,14</Frame>
				<Frame>10,14</Frame>
			</SpriteAnimation>
		</Animations>
		<RenderOptions>
			<Default>
				<Set name="PunchSoundOverride">HAND</Set>
				<Set name="DefaultRenderMannequinHandItem">false</Set>
				<Set name="RenderBackArmBuild">false</Set><!--WYS.KEE-->
				<Set name="RenderBackArmInfected">true</Set>
				<Set name="UserNameOffset">15</Set>
			</Default>
		</RenderOptions>
		<StateMachines>
			<StateMachine name="WYSKEE">
				<States>
					<State name="WYS" />
					<State name="KEE" />
				</States>
				<Transitions>
					<Transition from="KEE" to="WYS"><!--WYS_KEE-->
						<Condition>
							<IsAction>PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition from="WYS" to="KEE"><!--WYS_KEE-->
						<Condition>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>
		<ParticleSystems>
			<ParticleSystem name="wyskee_rbdp" updateStage="AddClothingParticles"
				updateState="WYSKEE.KEE" renderStage="RenderBackHandItem">
				<Emitter>
					<Set name="offset">-32, -34</Set>
					<Random name="emissionInterval" min="0.4" max="1.5" />
					<Set name="forceXScaling">true</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle velocityRelativeToPlayerSpeed="true" randomSpriteFrame="true"><!--WYS
					KEE-->
					<Set name="sprite">wyskee_rb_scy</Set>
					<Random name="offset" min="-6, -8" max="6, 0" />
					<Set name="inSpecificOrder">true</Set>
					<Set name="rotateWithVelocity">true</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>0.8, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="useGravity">true</Set>
					<Curve name="initialScale">
						<KeyFrame>0, 0.155, 0.155</KeyFrame>
						<KeyFrame>1, 0.35, 0.35</KeyFrame>
					</Curve>
					<Random name="lifeTime" min="0.8" max="1.5" />
					<Random name="initialVelocity" min="-20, -40" max="-40, -60" />
					<Set name="gravityVector">0, 100</Set>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="wyskee_psp">
				<Emitter>
					<Set name="offset">0,-16</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">1</Set>
				</Emitter>
				<Particle><!--WYS
					KEE-->
					<Set name="sprite">wyskee_sh_scy</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.8</Set>
					<Set name="interpolateScale">true</Set>
					<Set name="rotateWithVelocity">true</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>0.25, 0.3</KeyFrame>
						<KeyFrame>0.5, 1</KeyFrame>
						<KeyFrame>0.75, 0.5</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="initialScale">0.3,0.3</Set>
					<Set name="finalScale">2,2.5</Set>
					<Set name="interpolateVelocity">true</Set>
					<VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="1"
						angle="0" />
					<VectorTo name="finalVelocity" source="targetPos" duration="lifeTime" x="1"
						angle="0" />
				</Particle>
			</ParticleSystem>
		</ParticleSystems>
	</Data>
	<RenderRules><!--#WYSKEE-->
		<Update>
			<StopIf>
				<IsZombified>true</IsZombified>
			</StopIf>
			<AvatarTransform class="ArmAngle" onState="WYSKEE.KEE">
				<Set name="armName">arm1Angle</Set><!--#WYS
				KEE-->
				<Set name="armAngle">215</Set>
			</AvatarTransform>
		</Update>
		<RenderBackHandItem>
			<StopIf type="and">
				<IsZombified>true</IsZombified>
				<IsAction>PUNCH</IsAction>
			</StopIf>
			<SpriteRender name="wyskee_a_scy" offset="32,14" rotationPoint="0,1" flip="0,0"
				alignment="CENTER" rotateOffset="true" blend="PREMULTIPLIED_ALPHA" /><!--#WYS
			KEE-->
			<SpriteRender name="wyskee_h_scy" offset="16,14" rotationPoint="0,1" flip="0,0"
				alignment="CENTER" rotateOffset="true" blend="PREMULTIPLIED_ALPHA" />
		</RenderBackHandItem>
		<RenderInFront>
			<StopIf>
				<IsZombified>true</IsZombified>
			</StopIf><!--#WYS
			KEE-->
			<SpriteRender name="wyskee_s_scy" offset="12,-16" scale="1.5,1.5" alignment="CENTER"
				rotateOffset="true" blend="PREMULTIPLIED_ALPHA" onState="WYSKEE.WYS"
				drawShadow="false" tintOverride="255,255,255,255" />
		</RenderInFront>
		<AddClothingParticles>
			<StopIf type="or">
				<IsZombified>true</IsZombified>
				<IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing><!--#WYS
				KEE-->
				<IsWearing slot="SHOES">ITEM_ID_STAR_FIGHTER_REBEL_RAIDER</IsWearing>
				<IsWearing slot="SHOES">ITEM_ID_STAR_FIGHTER_IMPERIAL_ENFORCER</IsWearing>
			</StopIf>
		</AddClothingParticles>
		<OnPunchUpdate>
			<StopIf>
				<IsZombified>true</IsZombified>
			</StopIf>
			<AvatarTransform class="Face">
				<Set name="face">MAD</Set>
			</AvatarTransform>
			<AvatarTransform class="ArmAngle">
				<Set name="armName">arm1Angle</Set>
				<Set name="animTime">300</Set><!--#WYS
				KEE-->
				<Set name="Curve">
					<KeyFrame>0.0, 215</KeyFrame>
					<KeyFrame>0.2, 360</KeyFrame>
					<KeyFrame>0.6, 400</KeyFrame>
					<KeyFrame>0.8, 445</KeyFrame>
					<KeyFrame>1, 215</KeyFrame>
				</Set>
			</AvatarTransform>
		</OnPunchUpdate>
		<OnPunchStart>
			<StopIf>
				<IsZombified>true</IsZombified>
			</StopIf><!--#WYS
			KEE-->
			<ParticleSystemUpdate name="wyskee_psp" />
		</OnPunchStart>
	</RenderRules>
</ItemRenderer>
<?xml version="1.0"?>
<ItemRenderer>
	<Data>
		<Sprite name="s_Pet_head" fileName="game/ender_head.rttex" textureSize="64" frame="1,0" />
		<Sprite name="s_Pet_back" fileName="game/ender_back.rttex" textureSize="64" frame="0,0" />
		<Sprite name="hand" fileName="game/enderhand.rttex" textureSize="32" frame="0,0" />
		<Sprite name="PunchFireSprite" fileName="game/particles11.rttex" textureSize="32" frame="26,22" />
        
		<Animations>
			<SpriteAnimation name="a_dragon_head" sprite="s_Pet_head" animTime="1000" isLoop="true" playOnAction="JUMP|FALL|IDLE|WALK" autoPlay="true" >
				<Frame>1,0</Frame>
				<Frame>3,0</Frame>
				<Frame>5,0</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="a_dragon_back" sprite="s_Pet_back" animTime="1000" isLoop="true" playOnAction="JUMP|FALL|IDLE|WALK" autoPlay="true" >
				<Frame>0,0</Frame>
				<Frame>2,0</Frame>
				<Frame>4,0</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="a_dragon_punch_head" sprite="s_Pet_head" animTime="1000" isLoop="true" playOnAction="PUNCH" autoPlay="true" >
				<Frame>1,1</Frame>
				<Frame>3,1</Frame>
				<Frame>5,1</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="a_dragon_punch_back" sprite="s_Pet_back" animTime="1000" isLoop="true" playOnAction="PUNCH" autoPlay="true" >
				<Frame>0,1</Frame>
				<Frame>2,1</Frame>
				<Frame>4,1</Frame>
			</SpriteAnimation>
		</Animations>
        
		<ParticleSystems>
			<ParticleSystem name="PunchFire">
				<Emitter>
					<Set name="offset">10, -20</Set>
					<Random name="emissionInterval" min="0.001" max="0.005" />
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle autoLifeTimeToTarget="true">
					<Set name="sprite">PunchFireSprite</Set>
					<Set name="relativeToEmitter">true</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Set name="rotateWithVelocity">false</Set>
					<SetVar name="projectile_offset" source="targetPosOffset"/>
					<Random name="targetPosOffset" min="-8.1,-8.3" max="8.2,8.8"/>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>0.8, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 1, 0.3</KeyFrame>
						<KeyFrame>1, 1.5, 2</KeyFrame>
					</Curve>
					<RandomRadial name="initialVelocity" angleRange="-5,5" radiusRange="150,200" baseAnglePosition="targetPos" baseOffset="0,16" offset="targetPosOffset"  />
				</Particle>
			</ParticleSystem>
		</ParticleSystems>
        
		<VariableMap>
			<Set name="projectile_offset">0, 0</Set>
			<Set name="projectile_angle">0</Set>
		</VariableMap>
        
		<RenderOptions>
			<Default>
				<Set name="IgnorePunchTypeCheck">false</Set>
				<Set name="NeedRenderPet">true</Set>
				<Set name="PetOffsetDuplication">-32,0</Set>
				<Set name="UsePetForceFaceTime">false</Set>
			</Default>
		</RenderOptions>
	</Data>
    
	<RenderRules>
		<RenderHandItem>
			<SpriteRender name="hand" rotateOffset="true" offset="0,32" alignment="DOWN_CENTER" blend="PREMULTIPLIED_ALPHA"/>
		</RenderHandItem>
        
		<Update>
			<AvatarTransform class="ArmAngle" onAction="PUNCH">
				<Set name="armName">arm2Angle</Set>
				<Set name="armAngle">1700</Set>
				<Set name="isAdditive">true</Set>
				<Set name="pointTowardsPunchTarget">true</Set>
			</AvatarTransform>
		</Update>
        
		<OnPunchUpdate>
			<AvatarTransform class="Face">
				<Set name="face">MAD</Set>
			</AvatarTransform>
		</OnPunchUpdate>
        
		<RenderPet>
			<SpriteRender name="s_Pet_head" alignment="DOWN_CENTER" offset="0,10"/>
			<SpriteRender name="s_Pet_back" alignment="DOWN_CENTER" offset="-63.5,10"/>
			<StopIf>
				<IsTrnsformed>true</IsTrnsformed>
			</StopIf>
		</RenderPet>
        
		<UpdatePet>
			<ParticleSystemUpdate name="PunchFire" onAction="PUNCH"/>
		</UpdatePet>
	</RenderRules>
</ItemRenderer>

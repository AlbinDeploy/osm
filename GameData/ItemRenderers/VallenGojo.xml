<?xml version="1.0" encoding="utf-8"?>
//XML MADE BY HENN
<ItemRenderer>
  <Data>
    <Sprite name="s_frontFist" fileName="game/fistmray.rttex" textureSize="32" frame="0,0"/>
    <Sprite name="s_backFist" fileName="game/fistmray.rttex" textureSize="32" frame="1,0"/>
    <Sprite name="s_Pet" fileName="game/Gojoman.rttex" textureSize="32"/>
    <Sprite name="s_punch" fileName="game/punchmray.rttex" textureSize="64,32" frame="0,0"/>
    <Sprite name="s_eletric1" fileName="game/pmray.rttex" textureSize="32" frame="0,0"/>
    <Sprite name="s_eletric2" fileName="game/pmray.rttex" textureSize="32" frame="1,0"/>
	<Sprite name="trail_Sprite" fileName="game/particles.rttex" textureSize="32" frame="3,0"/>
	<Sprite name="HitSpark_Sprite" fileName="game/particles.rttex" textureSize="32"/>    

    <Animations>
      <SpriteAnimation name="a_Attack" sprite="s_Pet" playOnAction="PUNCH" animTime="300" isLoop="true">
        <Frame>0,0</Frame>
        <Frame>1,0</Frame>
        <Frame>2,0</Frame>
      </SpriteAnimation>
      <SpriteAnimation name="a_Fall" sprite="s_Pet" playOnAction="FALL" animTime="100" isLoop="false">
        <Frame>7,0</Frame>
      </SpriteAnimation>
      <SpriteAnimation name="a_Idle" sprite="s_Pet" playOnAction="IDLE" animTime="300" isLoop="true">
        <Frame>0,0</Frame>
        <Frame>1,0</Frame>
        <Frame>2,0</Frame>
      </SpriteAnimation>
      <SpriteAnimation name="a_Jump" sprite="s_Pet" playOnAction="JUMP" animTime="100" isLoop="false">
        <Frame>6,0</Frame>
      </SpriteAnimation>
      <SpriteAnimation name="a_Move" sprite="s_Pet" playOnAction="WALK" animTime="300" isLoop="true">
        <Frame>3,0</Frame>
        <Frame>4,0</Frame>
        <Frame>5,0</Frame>
      </SpriteAnimation>
	  <SpriteAnimation name="trail_anim" autoPlay="true" sprite="trail_Sprite" animTime="1200">
    	<Frame>3,0</Frame>
	    <Frame>4,0</Frame>
	  </SpriteAnimation>
  	<SpriteAnimation name="HitSpark_Anim" autoPlay="false" isLoop="false" sprite="HitSpark_Sprite"  animTime="200">
		<Frame>7,5</Frame>
		<Frame>8,5</Frame>
		<Frame>9,5</Frame>        
  	</SpriteAnimation>      
    </Animations>

    <ParticleSystems>
		<ParticleSystem name="punch_rayman">
			<Emitter>
				<Set name="offset">0,-18</Set>
				<Set name="emissionInterval">0.45</Set>
				<Set name="lifeTime">0.45</Set>
				<Set name="particlesPerEmission">1</Set>
				<Set name="particlesToEmit">1</Set>
			</Emitter>
			<Particle>
				<Set name="sprite">s_punch</Set>
				<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
				<Set name="lifeTime">0.4</Set>
				<Set name="rotateWithVelocity">true</Set>
				<Set name="interpolateAlpha">false</Set>
				<Set name="initialAlpha">1</Set>
				<Set name="finalAlpha">1</Set>
				<Set name="interpolateVelocity">true</Set>
				<VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="1" angle="0"/>
				<VectorTo name="finalVelocity" source="targetPos" duration="lifeTime" x="1" angle="0"/>
			</Particle>
		</ParticleSystem>
			<ParticleSystem name="ps_eletric1" updateStage="RenderPet">
				<Emitter>
					<Set name="offset">0, -16</Set>
					<Set name="emissionInterval">0.05</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_eletric1</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>0.2, 1</KeyFrame>
						<KeyFrame>0.6, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="inSpecificOrder">true</Set>
					<Curve name="initialScale">
						<KeyFrame>0, 0.2, 0.2</KeyFrame>
						<KeyFrame>1, 1, 1</KeyFrame>
					</Curve>
					<Set name="lifeTime">1.5</Set>
					<Random name="initialAngle" min="-180" max="180" />
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="ps_eletric2" updateStage="RenderPet">
				<Emitter>
					<Set name="offset">0, -16</Set>
					<Set name="emissionInterval">0.2</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_eletric2</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>0.2, 1</KeyFrame>
						<KeyFrame>0.6, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="inSpecificOrder">true</Set>
					<Curve name="initialScale">
						<KeyFrame>0, 0.2, 0.2</KeyFrame>
						<KeyFrame>1, 1, 1</KeyFrame>
					</Curve>
					<Set name="lifeTime">1.5</Set>
					<Random name="initialAngle" min="-180" max="180" />
				</Particle>
			</ParticleSystem> 
			<ParticleSystem name="hitSpark_particle" secondary="trail_particle">
				<Emitter>
					<Set name="particlesPerEmission">8</Set>
					<Set name="lifeTime">2</Set>
					<Set name="useTargetTileColorForTint">true</Set>                    
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">HitSpark_Sprite</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="useGravity">true</Set>
					<Set name="interpolateScale">true</Set>
					<Set name="initialScale">2,2</Set>
					<Random name="finalScale" min="0.1, 0.1" max="0.4, 0.4"/>
					<Set name="lifeTime">1</Set>
					<RandomRadial name="initialVelocity" angleRange="30,330" radiusRange="80,200"/>
					<Set name="gravityVector">0, 100</Set>
					<Random name="initialRotationRate" min="-300" max="300"/>
					<Random name="posOffset" min="0.1, 0" max="16.1, 16.3"/>
				</Particle>
			</ParticleSystem>      
			<ParticleSystem name="trail_particle">
				<Emitter>
					<Set name="lifeTime">1</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">80</Set>
					<Set name="emissionInterval">0.2</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">trail_Sprite</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">1.2</Set>
					<Set name="initialRotationRate">150</Set>
					<Curve name="initialScale">
						<KeyFrame>0, 0, 0</KeyFrame>
						<KeyFrame>0.4, 1, 1</KeyFrame>
						<KeyFrame>0.8, 0.3, 0.3</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0.5</KeyFrame>
						<KeyFrame>0.8, 0</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="initialVelocity">0,0</Set>
				</Particle>
			</ParticleSystem>                 
    </ParticleSystems>

    <RenderOptions>
      <Default>
  	<Set name="NeedRenderPet">true</Set>
  	<Set name="PetOffsetDuplication">0,0</Set>
  	<Set name="UsePetForceFaceTime">true</Set>
      <Set name="RenderFrontArmInfected">true</Set>
      <Set name="RenderBackArmInfected">true</Set>
      <Set name="RenderBackArmBuild">false</Set>
      <Set name="DefaultRenderMannequinHandItem">false</Set>
      <Set name="RenderBackArmInTheFront">false</Set>      
  	<Set name="HideParticlesOnTransform">false</Set>
  	<Set name="IgnorePunchTypeCheck">false</Set>
      </Default>
    </RenderOptions>
  </Data>

  <RenderRules>
    <RenderBackHandItem>
      <SpriteRender name="s_backFist" offset="-4,5" rotationPoint="0,1" alignment="CENTER" rotateOffset="true" blend="PREMULTIPLIED_ALPHA"/>
    </RenderBackHandItem>
    
    <RenderHandItem>
      <SpriteRender name="s_frontFist" offset="0,0.5" alignment="UPPER_CENTER" blend="PREMULTIPLIED_ALPHA"/>
    </RenderHandItem>
    
    <RenderPet>
  	<ParticleSystemRender name="ps_eletric1" />
  	<ParticleSystemRender name="ps_eletric2" />    
      <SpriteRender name="s_Pet" offset="0,0" alignment="DOWN_CENTER"/>
    </RenderPet>
    
    <OnPunchUpdate>
      <StopIf>
        <IsZombified>true</IsZombified>
      </StopIf>
      <AvatarTransform class="Face">
        <Set name="face">MAD</Set>
      </AvatarTransform>
      <AvatarTransform class="ArmAngle">
        <Set name="armName">arm2Angle</Set>
		<Set name="isAdditive">true</Set>        
		<Set name="pointTowardsPunchTarget">true</Set>
      </AvatarTransform>
      <AvatarTransform class="ArmAngle">
        <Set name="armName">arm1Angle</Set>
        <Set name="animTime">400</Set>
        <Set name="Curve">
          <KeyFrame>0.0, 253</KeyFrame>
          <KeyFrame>0.3, 255</KeyFrame>
          <KeyFrame>0.5, 259</KeyFrame>
          <KeyFrame>0.6, 265</KeyFrame>
          <KeyFrame>0.7, 259</KeyFrame>
          <KeyFrame>0.9, 255</KeyFrame>
          <KeyFrame>1, 253</KeyFrame>
        </Set>
      </AvatarTransform>      
    </OnPunchUpdate>    
    
    <OnPunchStart>
      <ParticleSystemUpdate name="punch_rayman"/>
    </OnPunchStart>
    
		<OnDestroyedTile>
		  <ParticleSystemUpdate name="hitSpark_particle"/>
		</OnDestroyedTile>    
    
	<SwitchOffClothingParticles>
		<ParticleSystemOff name="hitSpark_particle"/>    
		<ParticleSystemOff name="punch_rayman"/>
	</SwitchOffClothingParticles>    
  </RenderRules>
</ItemRenderer>
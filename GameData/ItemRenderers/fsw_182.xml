<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
  <Data>
	<StateMachines>
		<StateMachine name="playerState">
			<States>
				<State name="Idle"/>
				<State name="Punch"/>
				<State name="ZombiePunch"/>
			</States>
			<Transitions>
				<Transition from="ZombiePunch|Punch" to="Idle" >
					<Condition>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition from="ZombiePunch|Idle" to="Punch">
					<Condition type="and">
						<IsAction>PUNCH</IsAction>
						<IsZombified>false</IsZombified>
					</Condition>
				</Transition>
				<Transition from="Idle|Punch" to="ZombiePunch">
					<Condition type="and">
						<IsAction>PUNCH</IsAction>
						<IsZombified>true</IsZombified>
					</Condition>
				</Transition>
			</Transitions>
		</StateMachine>
	</StateMachines>
	<Sprite name="item_Sprite" fileName="game/gtfy_wn.rttex" textureSize="64" frame="8,3"/>
	
	<Sprite name="sword_slash_sprite" fileName="game/gtfy_wn.rttex" textureSize="64" frame="10,3"/>
	<Sprite name="s_hit" fileName="game/ci_n1.rttex" textureSize="32" frame="6,21"/>
	<Sprite name="s_flakes" fileName="game/ci_n1.rttex" textureSize="32" frame="5,22"/>        
        
	<Animations>
		<SpriteAnimation name="item_Sprite" playOnAction="JUMP|FALL|IDLE|WALK" sprite="item_Sprite" animTime="500" autoPlay="true" isLoop="true">
			<Frame>8,3</Frame>
			<Frame>9,3</Frame>
		</SpriteAnimation>    
    	<SpriteAnimation name="sword_slash_frame" autoPlay="false" sprite="sword_slash_sprite">
			<Frame>10,3</Frame>
			<Frame>11,3</Frame>
		</SpriteAnimation>
		<SpriteAnimation name="a_flakes" sprite="s_flakes">
			<Frame>5,22</Frame>
			<Frame>6,22</Frame>
        	<Frame>7,22</Frame>
        </SpriteAnimation>        
    </Animations>
    
	<ParticleSystems>
			<ParticleSystem name="slash_particle">
				<Emitter>
					<Set name="offset">9,-18</Set>
					<Set name="emissionInterval">0.25</Set>
					<Set name="lifeTime">0.25</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">1</Set>
				</Emitter>
				<Particle alternateSpriteFrameWithPunch="true">
					<Set name="sprite">sword_slash_sprite</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.4</Set>
					<Set name="rotateWithVelocity">true</Set>
					<Set name="interpolateAlpha">false</Set>
					<Set name="initialScale">2,2</Set>
					<Set name="initialAlpha">1</Set>
					<Set name="finalAlpha">1</Set>
					<Set name="interpolateVelocity">true</Set>
					<VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="0.8" angle="0"/>
					<VectorTo name="finalVelocity" source="targetPos" duration="lifeTime" x="0.8" angle="0"/>
				</Particle>
			</ParticleSystem>
     <ParticleSystem name="ps_break">
        <Emitter>
          <Set name="lifeTime">1</Set>
          <Set name="infParticles">true</Set>
          <Set name="checkParticleNumToEmit">true</Set>
          <Set name="particlesPerEmission">24</Set>
          <Set name="particlesToEmit">1</Set>
        </Emitter>
        <Particle>
          <Set name="sprite">s_hit</Set>
          <Random name="offset" min="-30, -20" max="30, 20" />
          <Set name="renderAlignment">CENTER</Set>
          <Set name="blendingMode">ADDITIVE</Set>
          <Curve name="initialAlpha">
            <KeyFrame>0, 1</KeyFrame>
            <KeyFrame>0.5, 1</KeyFrame>
            <KeyFrame>1, 0</KeyFrame>
          </Curve>
          <Curve name="initialScale">
            <KeyFrame>0, 1, 1</KeyFrame>
            <KeyFrame>1, 0.25, 0.25</KeyFrame>
          </Curve>
          <Set name="lifeTime">1</Set>
          <RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="25,50" />
        </Particle>
      </ParticleSystem>
      <ParticleSystem name="ps_hitSpark">
        <Emitter>
          <Set name="lifeTime">0.25</Set>
          <Set name="particlesPerEmission">8</Set>
          <Set name="particlesToEmit">1</Set>
        </Emitter>
        <Particle randomSpriteFrame="true">
          <Set name="sprite">s_hit</Set>
          <Set name="blendingMode">ADDITIVE</Set>
          <Set name="lifeTime">1</Set>
          <Curve name="initialAlpha">
            <KeyFrame>0, 1</KeyFrame>
            <KeyFrame>1, 0</KeyFrame>
          </Curve>
          <Curve name="initialScale">
            <KeyFrame>0, 1,1</KeyFrame>
            <KeyFrame>1, 0.25,0.25</KeyFrame>
          </Curve>
          <Random name="initialRotationRate" min="5" max="15" />
          <Random name="offset" min="0" max="16" />
          <Set name="useGravity">true</Set>
          <Set name="gravityVector">0, 100</Set>
          <RandomRadial name="initialVelocity" angleRange="45,315" radiusRange="40,100" />
        </Particle>
      </ParticleSystem>
      <ParticleSystem name="ps_breakSpark">
        <Emitter>
          <Set name="lifeTime">0.25</Set>
          <Set name="particlesPerEmission">16</Set>
          <Set name="particlesToEmit">1</Set>
        </Emitter>
        <Particle randomSpriteFrame="true">
          <Set name="sprite">s_hit</Set>
          <Set name="blendingMode">ADDITIVE</Set>
          <Set name="lifeTime">1</Set>
          <Curve name="initialAlpha">
            <KeyFrame>0, 1</KeyFrame>
            <KeyFrame>1, 0</KeyFrame>
          </Curve>
          <Curve name="initialScale">
            <KeyFrame>0, 1,1</KeyFrame>
            <KeyFrame>1, 0.25,0.25</KeyFrame>
          </Curve>
          <Random name="initialRotationRate" min="5" max="15" />
          <Random name="offset" min="0" max="16" />
          <Set name="useGravity">true</Set>
          <Set name="gravityVector">0, 100</Set>
          <RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="40,100" />
        </Particle>
      </ParticleSystem>
			<ParticleSystem name="ps_frontHand" updateStage="AddClothingParticles" renderStage="RenderHandItem">
				<Emitter attachment="handspotRoot">
					<Set name="offset">0, 8</Set>
					<Random name="emissionInterval" min="0.07" max="0.14" />
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">s_flakes</Set>
					<Random name="offset" min="13, -3" max="35, 1" />
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                <Set name="inSpecificOrder">true</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0.8</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Random name="initialScale" min="1" max="1.75" />
					<Set name="lifeTime">1</Set>
					<Random name="initialVelocity" min="0, -30" max="0, -20" />
					<Random name="initialAngle" min="0" max="360" />
				</Particle>
			</ParticleSystem>                                          
	</ParticleSystems>
  <RenderOptions>
      <Default>
        <Set name="DefaultRenderMannequinHandItem">false</Set>
      </Default>
    </RenderOptions>
  </Data>

  <RenderRules>
    <RenderHandItem>
	  <SpriteRender name="item_Sprite" rotateOffset="true" offset="18,4" alignment="CENTER"/>
    </RenderHandItem>
	<OnPunchUpdate>
		<AvatarTransform class="Face">
			<Set name="face">MAD</Set>
		</AvatarTransform>
		<AvatarTransform class="ArmAngle">
			<Set name="armName">arm2Angle</Set>
			<Set name="armAngle">1400</Set>
			<Set name="isAdditive">true</Set>
			<Set name="pointTowardsPunchTarget">false</Set>
		</AvatarTransform>
	</OnPunchUpdate>
    
	<OnPunchStart>
		<ParticleSystemUpdate name="slash_particle"/>
	</OnPunchStart>
    
    <OnDamagedTile>
      <ParticleSystemUpdate name="ps_hitSpark" />
    </OnDamagedTile>
    
    <OnDestroyedTile>
      <ParticleSystemUpdate name="ps_breakSpark"/>
      <ParticleSystemUpdate name="ps_break"/>
    </OnDestroyedTile>
            
	<SwitchOffClothingParticles>
		<ParticleSystemOff name="slash_particle"/>
        <ParticleSystemOff name="ps_breakSpark"/>
        <ParticleSystemOff name="ps_break"/>
        <ParticleSystemOff name="ps_hitSpark" />                
	</SwitchOffClothingParticles>
  </RenderRules>
</ItemRenderer>
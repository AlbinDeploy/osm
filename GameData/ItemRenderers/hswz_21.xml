<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
		<StateMachines>
			<StateMachine name="playerState">
				<States>
					<State name="Idle" />
					<State name="Punch" />
					<State name="ZombiePunch" />
				</States>
				<Transitions>
					<Transition from="ZombiePunch|Punch" to="Idle">
						<Condition>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition from="ZombiePunch|Idle" to="Punch">
						<Condition type="and">
							<IsAction>PUNCH</IsAction>
							<IsZombified>false</IsZombified>
						</Condition>
					</Transition>
					<Transition from="Idle|Punch" to="ZombiePunch">
						<Condition type="and">
							<IsAction>PUNCH</IsAction>
							<IsZombified>true</IsZombified>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>
		<Sprite name="item_Sprite" fileName="game/gtfy_wn.rttex" textureSize="64" frame="7,6" />

		<Sprite name="sword_slash_sprite" fileName="game/gtfy_wn.rttex" textureSize="64"
			frame="6,6" />
		<Sprite name="Lightning" fileName="game/gtfy_wn.rttex" textureSize="64" frame="0,22" />
		<Animations>
			<SpriteAnimation name="item_Sprite" playOnAction="JUMP|FALL|IDLE|WALK"
				sprite="item_Sprite" animTime="500" autoPlay="true" isLoop="true">
				<Frame>7,6</Frame>
				<Frame>8,6</Frame>
				<Frame>9,6</Frame>
				<Frame>10,6</Frame>
				<Frame>11,6</Frame>
				<Frame>12,6</Frame>
				<Frame>13,6</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="sword_slash_frame" autoPlay="false" sprite="sword_slash_sprite">
				<Frame>6,6</Frame>
			</SpriteAnimation>

			<SpriteAnimation name="Lightning_Anim" playOnAction="IDLE|WALK|JUMP|FALL"
				sprite="Lightning" autoPlay="true" animTime="910" isLoop="true">
				<Frame>0,22</Frame>
				<Frame>1,22</Frame>
				<Frame>2,22</Frame>
				<Frame>3,22</Frame>
				<Frame>4,22</Frame>
				<Frame>5,22</Frame>
				<Frame>6,22</Frame>
				<Frame>7,22</Frame>
				<Frame>8,22</Frame>
				<Frame>9,22</Frame>
				<Frame>10,22</Frame>
				<Frame>11,22</Frame>
				<Frame>4,22</Frame>
			</SpriteAnimation>
		</Animations>

		<ParticleSystems>
			<ParticleSystem name="slash_particle">
				<Emitter>
					<Set name="offset">9,-18</Set>
					<Set name="emissionInterval">0.25</Set>
					<Set name="lifeTime">0.25</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">1</Set>
				</Emitter>
				<Particle alternateSpriteFrameWithPunch="true">
					<Set name="sprite">sword_slash_sprite</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.4</Set>
					<Set name="rotateWithVelocity">true</Set>
					<Set name="interpolateAlpha">false</Set>
					<Set name="initialScale">2,2</Set>
					<Set name="initialAlpha">1</Set>
					<Set name="finalAlpha">1</Set>
					<Set name="interpolateVelocity">true</Set>
					<VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="0.8"
						angle="0" />
					<VectorTo name="finalVelocity" source="targetPos" duration="lifeTime" x="0.8"
						angle="0" />
				</Particle>
			</ParticleSystem>
		</ParticleSystems>
		<RenderOptions>
			<Default>
				<Set name="DefaultRenderMannequinHandItem">false</Set>
			</Default>
		</RenderOptions>
	</Data>

	<RenderRules>
		<RenderHandItem>
			<SpriteRender name="item_Sprite" rotateOffset="true" offset="18,4" alignment="CENTER" />
		</RenderHandItem>

		<RenderInFront>
			<StopIf>
				<IsZombified>true</IsZombified>
			</StopIf>
			<SpriteRender name="Lightning" alignment="DOWN_CENTER"
				onAction="IDLE|PUNCH|WALK|JUMP|FALL" drawShadow="false" />
		</RenderInFront>
		<OnPunchUpdate>
			<AvatarTransform class="Face">
				<Set name="face">MAD</Set>
			</AvatarTransform>
			<AvatarTransform class="ArmAngle">
				<Set name="armName">arm2Angle</Set>
				<Set name="armAngle">1400</Set>
				<Set name="isAdditive">true</Set>
				<Set name="pointTowardsPunchTarget">false</Set>
			</AvatarTransform>
		</OnPunchUpdate>

		<OnPunchStart>
			<ParticleSystemUpdate name="slash_particle" />
		</OnPunchStart>

		<OnDamagedTile>
			<ParticleSystemUpdate name="ps_hitSpark" />
		</OnDamagedTile>

		<SwitchOffClothingParticles>
			<ParticleSystemOff name="slash_particle" />
			<ParticleSystemOff name="ps_hitSpark" />
		</SwitchOffClothingParticles>
	</RenderRules>
</ItemRenderer>
	<RenderRules>
		<RenderInFront>
			<StopIf>
				<IsVariableBool name="isMannequin">true</IsVariableBool>
				<IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
			</StopIf>
			<SpriteRender name="sprite" offset="0,-10140" drawShadow="true" scale="1,1" onState="Motion.Idle|Motion.Move|Motion.Jump|Motion.Fall|Motion.Punch"/>
			<ParticleSystemUpdate name="Petir" onAction="PUNCH"/>
		</RenderInFront>
		<RenderShoes>

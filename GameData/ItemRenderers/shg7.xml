<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
		<Sprite name="sonic_sprite" fileName="game/x128.rttex" textureSize="128" />
		<Sprite name="sonic_punch" fileName="game/gtfy_wn.rttex" textureSize="64" />
		<Sprite name="sonic_eff" fileName="game/gtfy_wn.rttex" textureSize="64" frame="20,29" />
		<StateMachines>
			<StateMachine name="Motion">
				<States>
					<State name="Idle" />
					<State name="Move" />
					<State name="Jump" />
					<State name="Fall" />
					<State name="Punch" />
					<State name="Respawn" />
				</States>
				<Transitions>
					<Transition to="Idle" from="Fall|Move|Jump|Punch">
						<Condition type="and">
							<IsVariableBool name="onGround">true</IsVariableBool>
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
							<IsVariableBool name="isAttacking">false</IsVariableBool>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition to="Move" from="Jump|Fall|Idle|Punch">
						<Condition type="and">
							<IsVariableBool name="onGround">true</IsVariableBool>
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition to="Jump" from="Idle|Move|Fall|Punch">
						<Condition type="and">
							<IsVariableBool name="onGround">false</IsVariableBool>
							<IsVariableFloat name="speed.y" operator="Less">-0.1</IsVariableFloat>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition to="Fall" from="Jump|Idle|Move|Punch">
						<Condition type="and">
							<IsVariableBool name="onGround">false</IsVariableBool>
							<IsVariableFloat name="speed.y" operator="Greater">0.1</IsVariableFloat>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition to="Punch" from="Idle|Move|Jump|Fall">
						<Condition type="and">
							<IsAction>PUNCH</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>
		<Animations>
			<SpriteAnimation name="sonic_eff" sprite="sonic_eff" animTime="400" isLoop="true"
				playOnState="Motion.Punch|Motion.Idle|Motion.Move|Motion.Jump|Motion.Fall">
				<Frame>20,29</Frame>
				<Frame>21,29</Frame>
				<Frame>22,29</Frame>
				<Frame>23,29</Frame>
				<Frame>24,29</Frame>
				<Frame>25,29</Frame>
				<Frame>26,29</Frame>
				<Frame>27,29</Frame>
				<Frame>28,29</Frame>
				<Frame>29,29</Frame>
				<Frame>30,29</Frame>
				<Frame>31,29</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="sonic_Idle_Animation" playOnState="Motion.Idle"
				sprite="sonic_sprite" animTime="5000" isLoop="true">
				<Frame>0,7</Frame>
				<Frame>1,7</Frame>
				<Frame>2,7</Frame>
				<Frame>3,7</Frame>
				<Frame>4,7</Frame>
				<Frame>5,7</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="sonic_Punch_Animation" playOnState="Motion.Punch"
				sprite="sonic_sprite" animTime="300" isLoop="true">
				<Frame>0,9</Frame>
				<Frame>1,9</Frame>
				<Frame>2,9</Frame>
				<Frame>3,9</Frame>
				<Frame>4,9</Frame>
				<Frame>5,9</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="sonic_Jump_Animation" playOnState="Motion.Jump"
				sprite="sonic_sprite" animTime="400">
				<Frame>4,8</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="sonic_Fall_Animation" playOnState="Motion.Fall"
				sprite="sonic_sprite" animTime="400">
				<Frame>5,8</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="sonic_Walk_Animation" playOnState="Motion.Move"
				sprite="sonic_sprite" animTime="400" isLoop="true">
				<Frame>0,8</Frame>
				<Frame>1,8</Frame>
				<Frame>2,8</Frame>
				<Frame>3,8</Frame>

			</SpriteAnimation>			
            <SpriteAnimation name="punch" isLoop="true" playOnState="Motion.Punch" sprite="sonic_punch" animTime="500">
                <Frame>24,17</Frame>
                <Frame>25,17</Frame>
                <Frame>26,17</Frame>
                <Frame>27,17</Frame>                
            </SpriteAnimation>  
		</Animations>
		<ParticleSystems>
			<ParticleSystem name="punch_projectile" updateStage="OnPunchStart">
				<Emitter>
					<Set name="offset">30,-10030</Set>
					<Set name="emissionInterval">0.25</Set>
					<Set name="lifeTime">0.25</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">sonic_punch</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.4</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>0.5, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="rotateWithVelocity">true</Set>
					<Set name="interpolateAlpha">false</Set>
					<Set name="initialAlpha">1</Set>
					<Set name="finalAlpha">1</Set>
					<Set name="interpolateVelocity">true</Set>
					<Set name="initialScale">1,1</Set>
					<VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="4"
						angle="0" />
					<VectorTo name="finalVelocity" source="targetPos" duration="lifeTime" x="4"
						angle="0" />
				</Particle>
			</ParticleSystem>
		</ParticleSystems>
		<RenderOptions>
			<Default>
				<Set name="JumpEndStateRange">100</Set>
				<Set name="ClothingOffsetFromShoes">10000</Set>
				<Set name="IsRidingBird">true</Set>
				<Set name="IsVehicle">true</Set>
				<Set name="UserNameOffset">30</Set>
				<Set name="RenderShoesWithMermaidTail">true</Set>
				<Set name="ShoesHidesBodyLegs">true</Set>
				<Set name="IsToRenderPants">false</Set>
			</Default>
		</RenderOptions>
	</Data>
	<RenderRules>
		<RenderInFront>
			<StopIf>
				<IsVariableBool name="isMannequin">true</IsVariableBool>
				<IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
			</StopIf>
			<SpriteRender name="sonic_eff" offset="5,-10063" flip="1,0"
				drawShadow="false" scale="1.5,2"
				onState="Motion.Idle|Motion.Move|Motion.Jump|Motion.Fall|Motion.Punch" />
			<SpriteRender name="sonic_sprite" offset="0,-10060" drawShadow="true" scale="1,1"
				onState="Motion.Idle|Motion.Move" />
			<SpriteRender name="sonic_sprite" offset="0,-10060" drawShadow="true" scale="1,1"
				onState="Motion.Jump|Motion.Fall|Motion.Punch" />
			<SpriteRender name="sonic_eff" offset="5,-10055"
				drawShadow="false" scale="1.5,2"
				onState="Motion.Idle|Motion.Move|Motion.Jump|Motion.Fall|Motion.Punch" />
		</RenderInFront>
		<RenderShoes>
			<StopIf>
				<IsSitting>true</IsSitting>
				<IsSleepingOnaBed>true</IsSleepingOnaBed>
				<IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
			</StopIf>
		</RenderShoes>
		<OnPunchStart>
		</OnPunchStart>
	</RenderRules>
</ItemRenderer>
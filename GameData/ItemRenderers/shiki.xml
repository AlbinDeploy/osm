<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
        <Sprite name="spiritSprite" fileName="game/shiki_fujin.rttex" textureSize="256" frame="0,0"/>

        <Animations>
			<SpriteSinPulseAnimation name="foot2_Stretch" playOnAction="IDLE|WALK|FALL|JUMP|PUNCH" sprite="spiritSprite">
				<Parameter name="scale.y">
					<Set name="offset">1</Set>
					<Set name="period">2750</Set>
					<Set name="scale">0.07</Set>
				</Parameter>
			</SpriteSinPulseAnimation>
        </Animations>
    </Data>

  <RenderRules>
    <RenderBehind>
		<SpriteRender name="spiritSprite" rotateOffset="true" alignment="CENTER" offset="0,-100" blend="PREMULTIPLIED_ALPHA"/>
    </RenderBehind>
    <OnPunchUpdate>
      <AvatarTransform class="Emotion">
        <Set name="emotion">ANGRY</Set>
      </AvatarTransform>
      <AvatarTransform class="ArmAngle">
        <Set name="armName">arm2Angle</Set>
        <Set name="armAngle">120</Set>
        <Set name="pulseArmScale">5</Set>
        <Set name="pulseArmRate">250</Set>
      </AvatarTransform>
      <AvatarTransform class="ArmAngle">
        <Set name="armName">arm1Angle</Set>
        <Set name="armAngle">-120</Set>
        <Set name="pulseArmScale">5</Set>
        <Set name="pulseArmRate">250</Set>
      </AvatarTransform>
    </OnPunchUpdate>
  </RenderRules>
</ItemRenderer>

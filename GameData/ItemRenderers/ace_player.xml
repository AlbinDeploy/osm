<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
		<Sprite name="samurai_idle" fileName="game/ace_player.rttex" textureSize="208"/>
		<Sprite name="s_punchBubbles" fileName="game/ace_particle.rttex" textureSize="32" frame="5,18"/>
		<Sprite name="s_tileHit" fileName="game/ace_particle.rttex" textureSize="32" />
		<Sprite name="s_DestroyImpact" fileName="game/ace_particle.rttex" textureSize="32" />
		<Sprite name="s_respawn" fileName="game/ace_player.rttex" textureSize="208"/>
		<Sprite name="s_sleep" fileName="game/ace_player.rttex" textureSize="208"/>
		<StateMachines>
		<StateMachine name="Motion">
			<States>
				<State name="Idle" />
				<State name="Move" />
				<State name="Jump" />
				<State name="Fall" />
				<State name="Punch"/>
				<State name="Dance"/>
				<State name="Sleep"/>
			</States>
			<Transitions>
				<Transition to="Idle" from="Fall|Move|Jump|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">true</IsVariableBool>
						<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						<IsVariableBool name="isAttacking">false</IsVariableBool>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Move" from="Jump|Fall|Idle|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">true</IsVariableBool>
						<IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Jump" from="Idle|Move|Fall|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">false</IsVariableBool>
						<IsVariableFloat name="speed.y" operator="Less">-0.1</IsVariableFloat>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Fall" from="Jump|Idle|Move|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">false</IsVariableBool>
						<IsVariableFloat name="speed.y" operator="Greater">0.1</IsVariableFloat>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Punch" from="Idle|Move|Jump|Fall">
					<Condition type="and">
						<IsAction>PUNCH</IsAction>
					</Condition>
				</Transition>
			</Transitions>
		</StateMachine>
		<StateMachine name="IsDying">
			<States>
				<State name="False" />
				<State name="True" />
			</States>
			<Transitions>
				<Transition from="False" to="True">
					<Condition>
						<IsAction>DIE</IsAction>
					</Condition>
				</Transition>
				<Transition from="True" to="False">
					<Condition>
						<IsAction operatorType="NotEqual">DIE</IsAction>
					</Condition>
				</Transition>
			</Transitions>
		</StateMachine>
			<StateMachine name="Facing">
				<States>
					<State name="Left"/>
					<State name="Right"/>
				</States>
				<Transitions>
					<Transition to="Left" from="Right">
						<Condition>
							<IsFacingLeft>true</IsFacingLeft>
						</Condition>
					</Transition>
					<Transition to="Right" from="Left">
						<Condition>
							<IsFacingLeft>false</IsFacingLeft>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>

		</StateMachines>
	<Animations>
		<SpriteAnimation name="a_Attack_particle" sprite="s_punchBubbles" animTime="700" isLoop="false">
			<Frame>0,0</Frame>
			<Frame>1,0</Frame>
			<Frame>2,0</Frame>
		</SpriteAnimation>
		<SpriteAnimation name="a_DestroyImpact" sprite="s_DestroyImpact" animTime="300">
			<Frame>10,0</Frame>
			<Frame>11,0</Frame>
			<Frame>12,0</Frame>
			<Frame>13,0</Frame>
		</SpriteAnimation>
		<SpriteAnimation name="a_hit_particle" sprite="s_tileHit" animTime="500" isLoop="false">
			<Frame>6,0</Frame>
			<Frame>7,0</Frame>
			<Frame>8,0</Frame>
			<Frame>9,0</Frame>
		</SpriteAnimation>
		<SpriteAnimation name="samurai_Idle_Animation" playOnState="Motion.Idle" sprite="samurai_idle" animTime="1000" isLoop="true">
				<Frame>4,1</Frame>
				<Frame>5,1</Frame>
				<Frame>0,2</Frame>
			    <Frame>1,2</Frame>
		</SpriteAnimation>
			<SpriteAnimation name="samurai_Punch_Animation" playOnState="Motion.Punch" sprite="samurai_idle" animTime="300" isLoop="true">
				<Frame>2,2</Frame>
				<Frame>3,2</Frame>
				<Frame>4,2</Frame>
				<Frame>5,2</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="samurai_Jump_Animation" playOnState="Motion.Jump" sprite="samurai_idle" animTime="300">
				<Frame>2,4</Frame>
				<Frame>3,4</Frame>
				<Frame>4,4</Frame>
				<Frame>5,4</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="samurai_Fall_Animation" playOnState="Motion.Fall" sprite="samurai_idle" animTime="400" >
				<Frame>0,5</Frame>
				<Frame>1,5</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="samurai_Walk_Animation" playOnState="Motion.Move" sprite="samurai_idle" animTime="700" isLoop="true">
				<Frame>0,3</Frame>
				<Frame>1,3</Frame>
				<Frame>2,3</Frame>
				<Frame>3,3</Frame>
				<Frame>4,3</Frame>
				<Frame>5,3</Frame>
				<Frame>0,4</Frame>
				<Frame>1,4</Frame>
			</SpriteAnimation>
		<SpriteAnimation name="samurai_Respawn_Animation" sprite="s_respawn" animTime="1200" isLoop="false">
			<Frame>4,0</Frame>
			<Frame>0,0</Frame>
			<Frame>1,0</Frame>
			<Frame>2,0</Frame>
			<Frame>3,0</Frame>
			<Frame>3,0</Frame>

		</SpriteAnimation>
	</Animations>
		<ParticleSystems>
			<ParticleSystem name="ps_destroyImpact">
				<Emitter>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_DestroyImpact</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.3</Set>
					<Random name="initialAngle" min="0" max="0" />
					<Curve name="initialScale">
						<KeyFrame>0, 2,2</KeyFrame>
						<KeyFrame>1, 2,2</KeyFrame>
					</Curve>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="ps_Projectile_Right" updateStage="OnPunchStart" updateState="Facing.Right">
				<Emitter>
					<Set name="offset">8, -10030</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_punchBubbles</Set>
					<Select name="offset" input="punchCount">
						<Item>-8, 0</Item>
						<Item>8, 0</Item>
					</Select>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="rotateWithVelocity">true</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>1, 1</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 1.3, 1.3</KeyFrame>
						<KeyFrame>0, 1.3, 1.3</KeyFrame>
					</Curve>
					<Set name="lifeTime">0.3</Set>
					<VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="1" />
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="ps_Projectile_left" updateStage="OnPunchStart" updateState="Facing.Left">
				<Emitter>
					<Set name="offset">8, -10030</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_punchBubbles</Set>
					<Select name="offset" input="punchCount">
						<Item>-8, 0</Item>
						<Item>8, 0</Item>
					</Select>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="flipY">true</Set>
					<Set name="rotateWithVelocity">true</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>1, 1</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 1.3, 1.3</KeyFrame>
						<KeyFrame>0, 1.3, 1.3</KeyFrame>
					</Curve>
					<Set name="lifeTime">0.3</Set>
					<VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="1" />
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="ps_tileHit" updateStage="OnDamagedTile">
				<Emitter>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_tileHit</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Curve name="initialScale">
						<KeyFrame>0, 1.2, 1.2</KeyFrame>
						<KeyFrame>1, 3.6, 3.6</KeyFrame>
					</Curve>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>0.65, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="lifeTime">0.4</Set>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="DeathParticle">
				<Emitter>
					<Set name="lifeTime">1.1</Set>
					<Set name="emissionInterval">0</Set>
					<Set name="infParticles">false</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_respawn</Set>
					<Set name="offset">0,-30</Set>
					<Set name="renderAlignment">CENTER</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Curve name="initialAlpha">
						<KeyFrame>1, 1.4,1.4</KeyFrame>
						<KeyFrame>1, 1.4,1.4</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>1, 0.5,0.5</KeyFrame>
						<KeyFrame>1, 0.5,0.5</KeyFrame>
					</Curve>
					<Set name="lifeTime">1.1</Set>
				</Particle>
			</ParticleSystem>
		</ParticleSystems>
		<RenderOptions>
			<Default>
				<Set name="JumpEndStateRange">100</Set>
				<Set name="ClothingOffsetFromShoes">10000</Set>
				<Set name="IsRidingBird">true</Set>
				<Set name="IsVehicle">true</Set>
				<Set name="UserNameOffset">35</Set>
				<Set name="RenderShoesWithMermaidTail">true</Set>
				<Set name="ShoesHidesBodyLegs">true</Set>
				<Set name="IsToRenderPants">false</Set>
				<Set name="IgnoreDefaultDamagedTileEffect">true</Set>
				<Set name="IgnoreDefaultDestroyedTileEffect">true</Set>
				<Set name="HasDeathParticles">true</Set>
				<Set name="HideAvatarOnDeath">true</Set>
				<Set name="HideAngelOnDeath">true</Set>
				<Set name="IncludeAllActions">true</Set>
			</Default>
		</RenderOptions>
		<TileStampData>
			<Set name="FileName">game/ace_particle.rttex</Set>
			<Set name="EndFrame">5,0</Set>
			<Set name="FrameCount">3</Set>
		</TileStampData>
	</Data>
	<RenderRules>
		<RenderInFront>
			<StopIf>
				<IsVariableBool name="isMannequin">true</IsVariableBool>
				<IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
			</StopIf>
			<SpriteRender name="samurai_idle" offset="0,-10046" drawShadow="true" onState="Motion.Idle|Motion.Punch|Motion.Move|Motion.Jump|Motion.Fall" scale="0.5,0.5"/>
		</RenderInFront>
		<RenderShoes>
			<StopIf>
				<IsSitting>false</IsSitting>
				<IsSleepingOnaBed>false</IsSleepingOnaBed>
				<IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
			</StopIf>
		</RenderShoes>
		<OnKilled>
			<ParticleSystemUpdate name="DeathParticle" />
		</OnKilled>
		<SwitchOffClothingParticles>
			<ParticleSystemOff name="DeathParticle" />
		</SwitchOffClothingParticles>
		<OnDestroyedTile>
			<ParticleSystemUpdate name="ps_destroyImpact" />
		</OnDestroyedTile>
	</RenderRules>
</ItemRenderer>
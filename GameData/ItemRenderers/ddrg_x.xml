<?xml version="1.0"?>
<ItemRenderer>
	<Data>
		<StateMachines>
			<StateMachine name="Motion">
				<States>
					<State name="Idle" />
					<State name="Move" />
					<State name="Punch" />
				</States>
				<Transitions>
					<Transition to="Idle" from="Move|Punch">
						<Condition type="and">
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition to="Move" from="Idle|Punch">
						<Condition type="and">
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition to="Punch" from="Idle|Move">
						<Condition>
							<IsAction>PUNCH</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>

		<Sprite
			name="s_Pet_head" fileName="game/gtfy_wn.rttex" textureSize="64" frame="13,18" />
		<Sprite
			name="s_Pet_back" fileName="game/gtfy_wn.rttex" textureSize="64" frame="12,18" />

		<Sprite
			name="p_Pet_head" fileName="game/gtfy_wn.rttex" textureSize="64" frame="13,19" />
		<Sprite
			name="p_Pet_back" fileName="game/gtfy_wn.rttex" textureSize="64" frame="12,19" />

		<Sprite
			name="hand" fileName="game/lci_1.rttex" textureSize="64,32" frame="2,7" />
		<Sprite name="hand_eletric" fileName="game/ci_n1.rttex" textureSize="32"
			frame="1,42" />
		<Sprite name="s_fire" fileName="game/ci_n1.rttex" textureSize="32"
			frame="0,42" />
		<Sprite name="s_trail1" fileName="game/ci_n1.rttex" textureSize="32"
			frame="1,43" />
		<Sprite name="s_trail2" fileName="game/ci_n1.rttex" textureSize="32"
			frame="2,43" />

		<Animations>
			<SpriteAnimation name="a_dragon_punch_head" sprite="p_Pet_head" animTime="1000"
				isLoop="true" playOnAction="PUNCH" autoPlay="true">
				<Frame>13,19</Frame>
				<Frame>15,19</Frame>
				<Frame>17,19</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="a_dragon_punch_back" sprite="p_Pet_back" animTime="1000"
				isLoop="true" playOnAction="PUNCH" autoPlay="true">
				<Frame>12,19</Frame>
				<Frame>14,19</Frame>
				<Frame>16,19</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="a_dragon_head" sprite="s_Pet_head" animTime="1000" isLoop="true"
				playOnAction="IDLE|WALK|JUMP|JUMPSTART|FALL" autoPlay="true">
				<Frame>13,18</Frame>
				<Frame>15,18</Frame>
				<Frame>17,18</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="a_dragon_back" sprite="s_Pet_back" animTime="1000" isLoop="true"
				playOnAction="IDLE|WALK|JUMP|JUMPSTART|FALL" autoPlay="true">
				<Frame>12,18</Frame>
				<Frame>14,18</Frame>
				<Frame>16,18</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="a_eletric" sprite="hand_eletric" animTime="500" isLoop="true"
				playOnAction="IDLE|PUNCH|WALK|JUMP|JUMPSTART|FALL" autoPlay="true">
				<Frame>1,42</Frame>
				<Frame>2,42</Frame>
				<Frame>3,42</Frame>
			</SpriteAnimation>
		</Animations>

		<ParticleSystems>
			<ParticleSystem name="ps_punchProjectile" updateStage="RenderPet"
				updateState="Motion.Punch">
				<Emitter usePlayerFacing="true">
					<Random name="emissionInterval" min="0.002" max="0.004" />
					<Set name="infParticles">true</Set>
					<Set name="lifeTime">0.25</Set>
					<Set name="particlesPerEmission">3</Set>
					<Set name="offset">16,-19</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_fire</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Set name="lifeTime">0.15</Set>
					<Set name="initialScale">1,1</Set>
					<Set name="finalScale">2,2</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>1, 1</KeyFrame>
					</Curve>
					<Random name="targetPosOffset" min="-3, -13" max="3, 13" />
					<VectorTo name="initialVelocity" source="targetPos" offset="targetPosOffset"
						duration="lifeTime" x="1" />
					<Set name="rotateWithVelocity">true</Set>
					<OnFinish>
						<ParticleSystemName>ps_punchSmoke</ParticleSystemName>
					</OnFinish>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="ps_punchSmoke">
				<Emitter>
					<Set name="emissionInterval">0.01</Set>
					<Set name="infParticles">true</Set>
					<Set name="lifeTime">0.5</Set>
					<Set name="particlesPerEmission">2</Set>
					<Set name="delay">-0.25</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_fire</Set>
					<Set name="renderAlignment">CENTER</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Random name="offset" min="-8, -8" max="8, 8" />
					<Set name="initialAngle">180</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 0.6, 0.6</KeyFrame>
						<KeyFrame>1, 0.05, 0.05</KeyFrame>
					</Curve>
					<Set name="rotateWithVelocity">true</Set>
					<RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="60,80" />
					<Set name="lifeTime">0.5</Set>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="ps_Trail1" updateStage="RenderPet">
				<Emitter>
					<Random name="offset" min="0, -13" max="-50, -13" />
					<Set name="emissionInterval">0.05</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">2</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_trail1</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>0.2, 1</KeyFrame>
						<KeyFrame>0.6, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="inSpecificOrder">true</Set>
					<Curve name="initialScale">
						<KeyFrame>0, 0.5, 0.5</KeyFrame>
						<KeyFrame>1, 1.5, 1.5</KeyFrame>
					</Curve>
					<Set name="lifeTime">1.5</Set>
					<Random name="initialAngle" min="-180" max="180" />
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="ps_Trail2" updateStage="RenderPet">
				<Emitter>
					<Random name="offset" min="0, -13" max="-50, -13" />
					<Set name="emissionInterval">0.2</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_trail2</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>0.2, 1</KeyFrame>
						<KeyFrame>0.6, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="inSpecificOrder">true</Set>
					<Curve name="initialScale">
						<KeyFrame>0, 0.5, 0.5</KeyFrame>
						<KeyFrame>1, 1.5, 1.5</KeyFrame>
					</Curve>
					<Set name="lifeTime">1.5</Set>
					<Random name="initialAngle" min="-180" max="180" />
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="eletric_particles" updateStage="AddClothingParticles"
				renderStage="RenderBackHandItem">
				<Emitter>
					<Random name="offset" min="14,-5" max="15,-45" />
					<Set name="particlesPerEmission">2</Set>
					<Set name="particlesToEmit">2</Set>
					<Set name="emissionInterval">1</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="useGravity">true</Set>
					<Set name="checkParticleNumToEmit">false</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">hand_eletric</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Set name="relativeToEmitter">true</Set>
					<Set name="lifeTime">0.80</Set>
					<Set name="isBackgroundParticle">false</Set>
					<Set name="gravityVector">0, -25</Set>
					<Set name="initialVelocity">1,1</Set>
					<Curve name="initialScale">
						<KeyFrame>0, 0.3,0.3</KeyFrame>
						<KeyFrame>1, 0.5,0.5</KeyFrame>
					</Curve>
				</Particle>
			</ParticleSystem>
		</ParticleSystems>

		<VariableMap>
			<Set name="projectile_offset">0, 0</Set>
			<Set name="projectile_angle">0</Set>
		</VariableMap>

		
		<TileStampData>
			<Set name="FileName">game/ci_n1.rttex</Set>
			<Set name="EndFrame">4,42</Set>
			<Set name="FrameCount">4</Set>
		</TileStampData>


		<RenderOptions>
			<Default>
				<Set name="DefaultRenderMannequinHandItem">false</Set>
				<Set name="NeedRenderPet">true</Set>
				<Set name="PetOffsetDuplication">-32,0</Set>
				<Set name="IgnoreDefaultDamagedTileEffect">true</Set>
				<Set name="IgnoreDefaultDestroyedTileEffect">true</Set>
				<Set name="HideParticlesOnTransform">false</Set>
				<Set name="PunchSoundOverride">HAND</Set>
				<Set name="RenderBackArmInfected">true</Set>
				<Set name="RenderBackArmBuild">false</Set>
				<Set name="PlayDefaultPunchAudio">false</Set>
			</Default>
		</RenderOptions>
	</Data>

	<RenderRules>
		<RenderBackHandItem>
			<MusicSource onAction="PUNCH">
				<Set name="MusicFile">audio/droar.wav</Set>
				<Set name="FadeOutTimeMs">50</Set>
			</MusicSource>
			<SpriteRender name="hand" offset="19,-3" alignment="DOWN_CENTER"
				blend="PREMULTIPLIED_ALPHA" />
		</RenderBackHandItem>

		<Update>
			<StopIf>
				<IsZombified>true</IsZombified>
			</StopIf>
			<AvatarTransform class="ArmAngle" onAction="IDLE|WALK|JUMP|JUMPSTART|FALL|DANCE|DANCE2|DAB">
				<Set name="armName">arm1Angle</Set>
				<Set name="armAngle">-90</Set>
			</AvatarTransform>
		</Update>
        
		<OnPunchUpdate>
			<AvatarTransform class="Face">
				<Set name="face">MAD</Set>
			</AvatarTransform>
			<AvatarTransform class="ArmAngle">
				<Set name="armName">arm1Angle</Set>
				<Set name="armAngle">-75</Set>
			</AvatarTransform>
		</OnPunchUpdate>

		<RenderPet>
			<SpriteRender name="p_Pet_head" alignment="DOWN_CENTER" onAction="PUNCH" offset="0,10" />
			<SpriteRender name="p_Pet_back" alignment="DOWN_CENTER" onAction="PUNCH"
				offset="-63.5,10" />
			<ParticleSystemRender name="ps_Trail1" />
			<ParticleSystemRender name="ps_Trail2" />
			<SpriteRender name="s_Pet_head" alignment="DOWN_CENTER"
				onAction="IDLE|WALK|JUMP|JUMPSTART|FALL" offset="0,10" />
			<SpriteRender name="s_Pet_back" alignment="DOWN_CENTER"
				onAction="IDLE|WALK|JUMP|JUMPSTART|FALL" offset="-63.5,10" />
		</RenderPet>
	</RenderRules>
</ItemRenderer>
    
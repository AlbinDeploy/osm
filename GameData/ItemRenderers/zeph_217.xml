<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
		<StateMachines>
			<StateMachine name="playerState">
				<States>
					<State name="Idle" />
					<State name="Move" />
					<State name="Fall" />
					<State name="Jump" />
					<State name="DoubleJump" />
					<State name="SpiritGuide" />
				</States>
				<Transitions>
					<Transition from="SpiritGuide|Jump|Fall|Move|DoubleJump" to="Idle">
						<Condition>
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Jump|Fall|Idle|DoubleJump" to="Move">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>WALK</IsAction>
						</Condition>
					</Transition>
					<Transition from="Move|Jump|Fall|Idle|DoubleJump" to="SpiritGuide">
						<Condition type="and">
							<IsWearing slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0</IsVariableFloat>
							<IsAction operatorType="NotEqual">FALL</IsAction>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Fall|Move|Idle" to="Jump">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>JUMP</IsAction>
						</Condition>
					</Transition>
					<Transition from="Jump|Fall" to="DoubleJump">
						<Condition>
							<IsAction>JUMPDOUBLE</IsAction>
						</Condition>
					</Transition>
					<Transition from="DoubleJump|SpiritGuide|Jump|Idle|Move" to="Fall">
						<Condition type="and">
							<IsVariableFloat name="speed.y" operator="Greater" abs="false">0.01</IsVariableFloat>
							<IsAction>FALL</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
			<StateMachine name="Facing">
				<States>
					<State name="Left" />
					<State name="Right" />
				</States>
				<Transitions>
					<Transition to="Left" from="Right">
						<Condition>
							<IsFacingLeft>true</IsFacingLeft>
						</Condition>
					</Transition>
					<Transition to="Right" from="Left">
						<Condition>
							<IsFacingLeft>false</IsFacingLeft>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>

		<Sprite name="left_wing_sprite" fileName="game/kntc_96.rttex" textureSize="96" frame="0,1" />
		<Sprite name="right_wing_sprite" fileName="game/kntc_96.rttex" textureSize="96" frame="0,1" />

		<Sprite name="double_jump_particle_Sprite_left" fileName="game/ci_n1.rttex" textureSize="32"
			frame="1,28" />
		<Sprite name="double_jump_particle_Sprite_right" fileName="game/ci_n1.rttex"
			textureSize="32" frame="2,28" />
		<Sprite name="dj_up" fileName="game/ci_n1.rttex" textureSize="32" frame="3,28" />
		<Sprite name="lightning" fileName="game/gtfy_wn.rttex" textureSize="64" frame="0,23" />

		<Animations>
			<SpriteAnimation name="left_wing_Idle"
				playOnState="playerState.Idle|playerState.SpiritGuide|playerState.Move"
				sprite="left_wing_sprite" isLoop="true" animTime="100">
				<Frame>0,1</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="right_wing_Idle"
				playOnState="playerState.Idle|playerState.SpiritGuide|playerState.Move"
				sprite="right_wing_sprite" isLoop="true" animTime="100">
				<Frame>0,1</Frame>
			</SpriteAnimation>

			<SpriteAnimation name="left_wing_DoubleJ" playOnState="playerState.DoubleJump"
				sprite="left_wing_sprite" isLoop="false" animTime="125">
				<Frame>1,1</Frame>
				<Frame>2,1</Frame>
				<Frame>3,1</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="right_wing_DoubleJ" playOnState="playerState.DoubleJump"
				sprite="right_wing_sprite" isLoop="false" animTime="125">
				<Frame>1,1</Frame>
				<Frame>2,1</Frame>
				<Frame>3,1</Frame>
			</SpriteAnimation>

			<SpriteAnimation name="left_wing_Fall" playOnState="playerState.Fall"
				sprite="left_wing_sprite" isLoop="true" animTime="100">
				<Frame>3,1</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="right_wing_Fall" playOnState="playerState.Fall"
				sprite="right_wing_sprite" isLoop="true" animTime="100">
				<Frame>3,1</Frame>
			</SpriteAnimation>

			<SpriteAnimation name="left_wing_Jump" playOnState="playerState.Jump"
				sprite="left_wing_sprite" isLoop="false" animTime="350">
				<Frame>0,1</Frame>
				<Frame>1,1</Frame>
				<Frame>2,1</Frame>
				<Frame>3,1</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="right_wing_Jump" playOnState="playerState.Jump"
				sprite="right_wing_sprite" isLoop="false" animTime="350">
				<Frame>0,1</Frame>
				<Frame>1,1</Frame>
				<Frame>2,1</Frame>
				<Frame>3,1</Frame>
			</SpriteAnimation>

			<SpriteAnimation name="dj_up" playOnState="playerState.DoubleJump" autoPlay="false"
				isLoop="false" sprite="dj_up" animTime="100">
				<Frame>3,28</Frame>
			</SpriteAnimation>

			<SpriteAnimation name="double_jump_particle_Sprite_left"
				playOnState="playerState.DoubleJump" autoPlay="false" isLoop="false"
				sprite="double_jump_particle_Sprite_left" animTime="100">
				<Frame>1,28</Frame>
			</SpriteAnimation>

			<SpriteAnimation name="double_jump_particle_Sprite_right"
				playOnState="playerState.DoubleJump" autoPlay="false" isLoop="false"
				sprite="double_jump_particle_Sprite_right" animTime="100">
				<Frame>2,28</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="lightning_anim"
				playOnState="playerState.Idle|playerState.SpiritGuide|playerState.Move|playerState.Fall|playerState.Jump|playetState.DoubleJump"
				sprite="lightning" animTime="1200" isLoop="true">
				<Frame>0,23</Frame>
				<Frame>1,23</Frame>
				<Frame>2,23</Frame>
				<Frame>3,23</Frame>
				<Frame>4,23</Frame>
				<Frame>5,23</Frame>
				<Frame>6,23</Frame>
				<Frame>7,23</Frame>
				<Frame>8,23</Frame>
				<Frame>9,23</Frame>
				<Frame>10,23</Frame>
				<Frame>11,23</Frame>
				<Frame>4,23</Frame>
			</SpriteAnimation>
		</Animations>

		<ParticleSystems>
			<ParticleSystem name="dj_up_up">
				<Emitter>
					<Random name="offset" min="0, -4" max="0, -4" />
					<Set name="lifeTime">1</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="emissionInterval">0.1</Set>
					<Set name="particlesToEmit">1</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="delayTimer">0</Set>
				</Emitter>
				<Particle usePlayerFacing="true">
					<Set name="sprite">dj_up</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="isBackgroundParticle">false</Set>
					<Set name="initalRGB">1, 1, 1</Set>
					<Set name="relativeToEmitter">false</Set>
					<Set name="rotateWithVelocity">false</Set>
					<Set name="interpolateScale">true</Set>
					<Set name="interpolateAlpha">true</Set>
					<Set name="lifeTime">1</Set>
					<Set name="initialScale">1.1, 1.1</Set>
					<Set name="finalScale">1.3, 1.3</Set>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="double_jump_particle_left">
				<Emitter>
					<Random name="offset" min="-26, 5" max="-19, 5" />
					<Set name="lifeTime">1</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="checkParticleNumToEmit">true</Set>
					<Set name="particlesToEmit">1</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="delayTimer">0</Set>
				</Emitter>
				<Particle usePlayerFacing="true">
					<Set name="sprite">double_jump_particle_Sprite_left</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="isBackgroundParticle">false</Set>
					<Set name="initalRGB">1, 1, 1</Set>
					<Set name="relativeToEmitter">false</Set>
					<Set name="rotateWithVelocity">false</Set>
					<Set name="interpolateAlpha">true</Set>
					<Set name="interpolateScale">true</Set>
					<Set name="lifeTime">1</Set>
					<Set name="initialScale">1.1, 1.1</Set>
					<Set name="finalScale">2.2, 2.8</Set>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="double_jump_particle_right">
				<Emitter>
					<Random name="offset" min="26, 5" max="19, 5" />
					<Set name="lifeTime">1</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="checkParticleNumToEmit">true</Set>
					<Set name="particlesToEmit">1</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="delayTimer">0</Set>
				</Emitter>
				<Particle usePlayerFacing="true">
					<Set name="sprite">double_jump_particle_Sprite_right</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="isBackgroundParticle">false</Set>
					<Set name="initalRGB">1, 1, 1</Set>
					<Set name="relativeToEmitter">false</Set>
					<Set name="rotateWithVelocity">false</Set>
					<Set name="interpolateAlpha">true</Set>
					<Set name="interpolateScale">true</Set>
					<Set name="lifeTime">1</Set>
					<Set name="initialScale">1.1, 1.1</Set>
					<Set name="finalScale">2.2, 2.8</Set>
				</Particle>
			</ParticleSystem>
		</ParticleSystems>

		<RenderOptions>
			<Default>
				<Set name="PlayDefaultPunchAudio">false</Set>
				<Set name="JumpSoundOverride">BACKPACK</Set>
				<Set name="ShouldHover">true</Set>
				<Set name="UserNameOffset">10</Set>
			</Default>
		</RenderOptions>
	</Data>

	<RenderRules>
		<RenderBackpack>
			<MusicSource onAction="JUMP">
				<Set name="MusicFile">morty_ears.wav</Set>
				<Set name="FadeOutTimeMs">20</Set>
			</MusicSource>
			<ContextUpdate type="SetTintFromSlot">
				<Set name="slot">HAIR</Set>
			</ContextUpdate>
			<SpriteRender name="left_wing_sprite" offset="-48,-16" />
			<SpriteRender name="right_wing_sprite" offset="48,-16" flip="1,0" />
			<AvatarSilhouetteRender color="255,255,255,255" emissionInterval="0.38"
				onState="playerState.Move" />
			<ContextUpdate type="SetTintFromSlot">
				<Set name="slot">HAIR</Set>
				<Set name="seedFG">true</Set>
			</ContextUpdate>
			<StopIf>
				<IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
			</StopIf>
		</RenderBackpack>

		<RenderInFront>
			<StopIf>
				<IsZombified>true</IsZombified>
				<IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
			</StopIf>
			<ContextUpdate type="SetTintFromSlot">
				<Set name="slot">HAIR</Set>
			</ContextUpdate>
			<SpriteRender name="lightning" alignment="DOWN_CENTER"
				onState="playerState.Idle|playerState.SpiritGuide|playerState.Move|playerState.Fall|playerState.Jump|playetState.DoubleJump"
				drawShadow="false" />
			<ContextUpdate type="SetTintFromSlot">
				<Set name="slot">HAIR</Set>
				<Set name="seedFG">true</Set>
			</ContextUpdate>
		</RenderInFront>

		<AddClothingParticles>
			<ContextUpdate type="SetTintFromSlot">
				<Set name="slot">HAIR</Set>
			</ContextUpdate>
			<ParticleSystemUpdate name="dj_up_up" onAction="JUMPDOUBLE" drawShadow="false"
				align="RIGHT_CENTER" />
			<ParticleSystemUpdate name="double_jump_particle_left" onAction="JUMPDOUBLE"
				drawShadow="false" align="LEFT_CENTER" />
			<ParticleSystemUpdate name="double_jump_particle_right" onAction="JUMPDOUBLE"
				drawShadow="false" align="RIGHT_CENTER" />
			<ContextUpdate type="SetTintFromSlot">
				<Set name="slot">HAIR</Set>
				<Set name="seedFG">true</Set>
			</ContextUpdate>
		</AddClothingParticles>

		<SwitchOffClothingParticles>
			<ParticleSystemOff name="dj_up_up" />
			<ParticleSystemOff name="double_jump_particle_left" />
			<ParticleSystemOff name="double_jump_particle_right" />
		</SwitchOffClothingParticles>
	</RenderRules>
</ItemRenderer>
<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
		<Sprite name="samurai_idle" fileName="game/chirby_move.rttex" textureSize="64"/>
		<Sprite name="s_punchBubbles" fileName="game/chirby_move.rttex" textureSize="64"/>
		<Sprite name="s_tileHit" fileName="game/particles11.rttex" textureSize="32"  />
		<Sprite name="s_DestroyImpact" fileName="game/chirby_move.rttex" textureSize="64" />
		<Sprite name="s_respawn" fileName="game/chirby_move.rttex" textureSize="64"/>
		<Sprite name="s_sleep" fileName="game/chirby_move.rttex" textureSize="64"/>
		<StateMachines>
		<StateMachine name="Motion">
			<States>
				<State name="Idle" />
				<State name="Move" />
				<State name="Jump" />
				<State name="Fall" />
				<State name="Punch"/>
				<State name="Dance"/>
				<State name="Sleep"/>
			</States>
			<Transitions>
				<Transition to="Idle" from="Fall|Move|Jump|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">true</IsVariableBool>
						<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						<IsVariableBool name="isAttacking">false</IsVariableBool>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Move" from="Jump|Fall|Idle|Punch|Dance|Sleep" >
					<Condition type="and">
						<IsVariableBool name="onGround">true</IsVariableBool>
						<IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Jump" from="Idle|Move|Fall|Punch|Dance|Sleep" >
					<Condition type="and">
						<IsVariableBool name="onGround">false</IsVariableBool>
						<IsVariableFloat name="speed.y" operator="Less">-0.1</IsVariableFloat>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Fall" from="Jump|Idle|Move|Punch|Dance|Sleep" >
					<Condition type="and">
						<IsVariableBool name="onGround">false</IsVariableBool>
						<IsVariableFloat name="speed.y" operator="Greater">0.1</IsVariableFloat>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Punch" from="Idle|Move|Jump|Fall|Dance|Sleep">
					<Condition type="and">
						<IsAction>PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Sleep" from="Idle|Move|Fall|Jump|Punch|Dance">
					<Condition>
					<IsAction>SLEEP</IsAction>
					</Condition>
				</Transition>
				<Transition to="Dance" from="Move|Idle|Jump|Fall|Punch|Sleep">
					<Condition>
						<IsAction>DANCE</IsAction>
						<IsAction>DANCE_DAB</IsAction>
						<IsAction>DANCE_FLOSS</IsAction>
						<IsAction>DANCE_MARCH</IsAction>
					</Condition>
				</Transition>
			</Transitions>
		</StateMachine>
		<StateMachine name="IsDying">
			<States>
				<State name="False" />
				<State name="True" />
			</States>
			<Transitions>
				<Transition from="False" to="True">
					<Condition>
						<IsAction>DIE</IsAction>
					</Condition>
				</Transition>
				<Transition from="True" to="False">
					<Condition>
						<IsAction operatorType="NotEqual">DIE</IsAction>
					</Condition>
				</Transition>
			</Transitions>
		</StateMachine>
	</StateMachines>
	<Animations>
		<SpriteAnimation name="a_sleep" sprite="s_sleep" animTime="600" isLoop="true" playOnState="Motion.Sleep">
			<Frame>1,1</Frame>
			<Frame>2,1</Frame>
			<Frame>3,1</Frame>
			<Frame>4,1</Frame>
		</SpriteAnimation>
		<SpriteAnimation name="gigi_Dance_Animation" playOnState="Motion.Dance" sprite="samurai_idle" animTime="1000" isLoop="true">
			<Frame>5,6</Frame>
			<Frame>6,6</Frame>
			<Frame>0,7</Frame>
			<Frame>1,7</Frame>
			<Frame>2,7</Frame>
			<Frame>3,7</Frame>
			<Frame>4,7</Frame>
			<Frame>5,7</Frame>
			<Frame>6,7</Frame>
			<Frame>0,8</Frame>
			<Frame>1,8</Frame>
		</SpriteAnimation>
		<SpriteAnimation name="a_DestroyImpact" sprite="s_DestroyImpact" animTime="300">
			<Frame>4,6</Frame>
			<Frame>0,6</Frame>
			<Frame>1,6</Frame>
			<Frame>2,6</Frame>
			<Frame>3,6</Frame>
		</SpriteAnimation>
		<SpriteAnimation name="a_Attack_particle" sprite="s_punchBubbles" animTime="700" isLoop="true">
				<Frame>3,5</Frame>
				<Frame>4,5</Frame>
				<Frame>5,5</Frame>
				<Frame>6,5</Frame>
			</SpriteAnimation>
		<SpriteAnimation name="a_hit_particle" sprite="s_tileHit" animTime="700" isLoop="false">
			<Frame>20,20</Frame>
			<Frame>21,20</Frame>
			<Frame>22,20</Frame>
			<Frame>23,20</Frame>
		</SpriteAnimation>
		<SpriteAnimation name="samurai_Idle_Animation" playOnState="Motion.Idle" sprite="samurai_idle" animTime="1800" isLoop="true">
				<Frame>0,0</Frame>
				<Frame>1,0</Frame>
				<Frame>2,0</Frame>
				<Frame>3,0</Frame>
				<Frame>4,0</Frame>
				<Frame>5,0</Frame>
				<Frame>6,0</Frame>
				<Frame>0,1</Frame>
				<Frame>1,1</Frame>
				<Frame>2,1</Frame>
				<Frame>3,1</Frame>
				<Frame>4,1</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="samurai_Punch_Animation" playOnState="Motion.Punch" sprite="samurai_idle" animTime="200" isLoop="true">
				<Frame>5,3</Frame>
				<Frame>6,3</Frame>
				<Frame>0,4</Frame>
				<Frame>1,4</Frame>
				<Frame>2,4</Frame>
				<Frame>3,4</Frame>
				<Frame>4,4</Frame>
				<Frame>5,4</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="samurai_Jump_Animation" playOnState="Motion.Jump" sprite="samurai_idle" animTime="300">
				<Frame>6,2</Frame>
				<Frame>0,3</Frame>
				<Frame>1,3</Frame>
				<Frame>2,3</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="samurai_Fall_Animation" playOnState="Motion.Fall" sprite="samurai_idle" animTime="400" isLoop="true">
				<Frame>3,3</Frame>
				<Frame>4,3</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="samurai_Walk_Animation" playOnState="Motion.Move" sprite="samurai_idle" animTime="400" isLoop="true">
				<Frame>5,1</Frame>
				<Frame>6,1</Frame>
				<Frame>0,2</Frame>
				<Frame>1,2</Frame>
				<Frame>2,2</Frame>
				<Frame>3,2</Frame>
				<Frame>4,2</Frame>
				<Frame>5,2</Frame>
			</SpriteAnimation>
		<SpriteAnimation name="samurai_Respawn_Animation" sprite="s_respawn" animTime="1200" isLoop="false">
			<Frame>2,5</Frame>
			<Frame>6,4</Frame>
			<Frame>0,5</Frame>
			<Frame>1,5</Frame>
		</SpriteAnimation>
	</Animations>
		<ParticleSystems>
			<ParticleSystem name="ps_destroyImpact">
				<Emitter>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_DestroyImpact</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.3</Set>
					<Random name="initialAngle" min="0" max="0" />
					<Curve name="initialScale">
						<KeyFrame>0, 2,2</KeyFrame>
						<KeyFrame>1, 2,2</KeyFrame>
					</Curve>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="dasdasdas" updateStage="AddClothingParticles" updateState="Motion.Punch">
				<Emitter>
					<Set name="offset">15, -10020</Set>
					<Set name="offsetFacing">true</Set>
					<Set name="emissionInterval">0.3</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_punchBubbles</Set>
					<Set name="renderAlignment">CENTER</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="rotateWithVelocity">true</Set>
					<Set name="initialScale">0.8,0.8</Set>
					<Random name="finalScale" min="0.8" max="0.8"/>
					<Set name="interpolateScale">true</Set>
					<Set name="lifeTime">0.2</Set>
					<Random name="targetPosOffset" min="-12,-11" max="12,11"/>
					<VectorTo name="initialVelocity" source="targetPos" offset="targetPosOffset" duration="lifeTime" x="1" angleOutVar="projectile_angle"/>
					<VectorTo name="finalVelocity" source="targetPos" offset="targetPosOffset" duration="lifeTime" x="1" angleOutVar="projectile_angle"/>
					<Set name="interpolateVelocity">true</Set>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="ps_tileHit" updateStage="OnDamagedTile">
				<Emitter>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_tileHit</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Curve name="initialScale">
						<KeyFrame>0, 1.2, 1.2</KeyFrame>
						<KeyFrame>1, 3.6, 3.6</KeyFrame>
					</Curve>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>0.65, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="lifeTime">0.5</Set>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="DeathParticle">
				<Emitter>
					<Set name="lifeTime">1.1</Set>
					<Set name="emissionInterval">0</Set>
					<Set name="infParticles">false</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_respawn</Set>
					<Set name="offset">0,-30</Set>
					<Set name="renderAlignment">CENTER</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Curve name="initialAlpha">
						<KeyFrame>1, 1.4,1.4</KeyFrame>
						<KeyFrame>1, 1.4,1.4</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>1, 1.4,1.4</KeyFrame>
						<KeyFrame>1, 1.4,1.4</KeyFrame>
					</Curve>
					<Set name="lifeTime">1.1</Set>
				</Particle>
			</ParticleSystem>
		</ParticleSystems>
		<RenderOptions>
			<Default>
				<Set name="JumpEndStateRange">100</Set>
				<Set name="ClothingOffsetFromShoes">10000</Set>
				<Set name="IsRidingBird">true</Set>
				<Set name="IsVehicle">true</Set>
				<Set name="UserNameOffset">20</Set>
				<Set name="RenderShoesWithMermaidTail">true</Set>
				<Set name="ShoesHidesBodyLegs">true</Set>
				<Set name="IsToRenderPants">false</Set>
				<Set name="IgnoreDefaultDamagedTileEffect">true</Set>
				<Set name="IgnoreDefaultDestroyedTileEffect">true</Set>
				<Set name="HasDeathParticles">true</Set>
				<Set name="HideAvatarOnDeath">true</Set>
				<Set name="HideAngelOnDeath">true</Set>
				<Set name="IncludeAllActions">true</Set>
			</Default>
		</RenderOptions>
		<TileStampData>
			<Set name="FileName">game/particles11.rttex</Set>
			<Set name="EndFrame">17,23</Set>
			<Set name="FrameCount">4</Set>
		</TileStampData>
	</Data>
	<RenderRules>
		<Update>
			<AvatarTransform class="FootPosition" onState="Motion.Dance">
				<Set name="foot1dy">0</Set>
				<Set name="foot2dy">0</Set>
				<Set name="foot1y">0</Set>
				<Set name="foot2y">0</Set>
			</AvatarTransform>
			<AvatarTransform class="ActionUpdate" onState="Motion.Dance">
				<Set name="action">NOD</Set>
			</AvatarTransform>
		</Update>
		<RenderInFront>
			<StopIf>
				<IsVariableBool name="isMannequin">true</IsVariableBool>
				<IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
			</StopIf>
			<SpriteRender name="samurai_idle" offset="0,-10040" drawShadow="true" onState="Motion.Idle|Motion.Punch|Motion.Move|Motion.Jump|Motion.Fall|Motion.Dance" scale="1.4,1.4"/>
			<SpriteRender name="s_sleep" offset="0,-10040" drawShadow="true" onState="Motion.Sleep" scale="1.4,1.4"/>
		</RenderInFront>
		<RenderShoes>
			<StopIf>
				<IsSitting>false</IsSitting>
				<IsSleepingOnaBed>false</IsSleepingOnaBed>
				<IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
			</StopIf>
		</RenderShoes>
		<OnKilled>
			<ParticleSystemUpdate name="DeathParticle" />
		</OnKilled>
		<SwitchOffClothingParticles>
			<ParticleSystemOff name="DeathParticle" />
		</SwitchOffClothingParticles>
		<OnDestroyedTile>
			<ParticleSystemUpdate name="ps_destroyImpact" />
		</OnDestroyedTile>
	</RenderRules>
</ItemRenderer>
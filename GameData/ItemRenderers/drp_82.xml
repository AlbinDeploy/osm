<ItemRenderer>
	<Data>
    <StateMachines>
      <StateMachine name="Motion">
        <States>
          <State name="Idle" />
          <State name="Move" />
          <State name="Punch" />
        </States>
        <Transitions>
          <Transition to="Idle" from="Move|Punch">
            <Condition type="and">
              <IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
              <IsAction operatorType="NotEqual">PUNCH</IsAction>
            </Condition>
          </Transition>
          <Transition to="Move" from="Idle|Punch">
            <Condition type="and">
              <IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
              <IsAction operatorType="NotEqual">PUNCH</IsAction>
            </Condition>
          </Transition>
          <Transition to="Punch" from="Idle|Move">
            <Condition>
              <IsAction>PUNCH</IsAction>
            </Condition>
          </Transition>
        </Transitions>
      </StateMachine>
    </StateMachines>    
    
		<Sprite name="s_Pet_head" fileName="game/gtfy_wn.rttex" textureSize="64" frame="13,2"/>
		<Sprite name="s_Pet_back" fileName="game/gtfy_wn.rttex" textureSize="64" frame="12,2"/>
		<Sprite name="hand" fileName="game/ci1.rttex" textureSize="32" frame="10,5" />
		
		<Sprite name="p_Pet_head" fileName="game/gtfy_wn.rttex" textureSize="64" frame="13,3"/>
		<Sprite name="p_Pet_back" fileName="game/gtfy_wn.rttex" textureSize="64" frame="12,3"/>
		
		
		<Sprite name="hand" fileName="game/ci1.rttex" textureSize="32" frame="10,4" />
		
		
    	<Sprite name="s_fire" fileName="game/ci_n1.rttex" textureSize="32" frame="6,37"/>
		       
		<Animations>
			<SpriteAnimation name="a_dragon_punch_head" sprite="p_Pet_head" animTime="1000" isLoop="true" playOnAction="PUNCH" autoPlay="true" >
				<Frame>13,3</Frame>
				<Frame>15,3</Frame>
				<Frame>17,3</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="a_dragon_punch_back" sprite="p_Pet_back" animTime="1000" isLoop="true" playOnAction="PUNCH" autoPlay="true" >
				<Frame>12,3</Frame>
				<Frame>14,3</Frame>
				<Frame>16,3</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="a_dragon_head" sprite="s_Pet_head" animTime="1000" isLoop="true" playOnAction="IDLE|WALK|JUMP|JUMPSTART|FALL" autoPlay="true" >
				<Frame>13,2</Frame>
				<Frame>15,2</Frame>
				<Frame>17,2</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="a_dragon_back" sprite="s_Pet_back" animTime="1000" isLoop="true" playOnAction="IDLE|WALK|JUMP|JUMPSTART|FALL" autoPlay="true" >
				<Frame>12,2</Frame>
				<Frame>14,2</Frame>
				<Frame>16,2</Frame>
			</SpriteAnimation>
			
		</Animations>
        
	<ParticleSystems>
      <ParticleSystem name="ps_punchProjectile" updateStage="RenderPet" updateState="Motion.Punch">
        <Emitter usePlayerFacing="true">
          <Random name="emissionInterval" min="0.002" max="0.004"/>
          <Set name="infParticles">true</Set>
          <Set name="lifeTime">0.25</Set>
          <Set name="particlesPerEmission">3</Set>
		  <Set name="offset">16,-19</Set>
        </Emitter>
        <Particle>
          <Set name="sprite">s_fire</Set>
          <Set name="blendingMode">ADDITIVE</Set>
          <Set name="lifeTime">0.15</Set>
	  	<Set name="initialScale">1,1</Set>
	  	<Set name="finalScale">2,2</Set>
          <Curve name="initialAlpha">
            <KeyFrame>0, 1</KeyFrame>
            <KeyFrame>1, 1</KeyFrame>
          </Curve>
          <Random name="targetPosOffset" min="-3, -13" max="3, 13"/>
          <VectorTo name="initialVelocity" source="targetPos" offset="targetPosOffset" duration="lifeTime" x="1"/>
          <Set name="rotateWithVelocity">true</Set>
          <OnFinish>
            <ParticleSystemName>ps_punchSmoke</ParticleSystemName>
          </OnFinish>
        </Particle>
      </ParticleSystem>
      <ParticleSystem name="ps_punchSmoke">
        <Emitter>
          <Set name="emissionInterval">0.01</Set>
          <Set name="infParticles">true</Set>
          <Set name="lifeTime">0.5</Set>
          <Set name="particlesPerEmission">2</Set>
		  <Set name="delay">-0.25</Set>
        </Emitter>
        <Particle>
          <Set name="sprite">s_fire</Set>
          <Set name="renderAlignment">CENTER</Set>
          <Set name="blendingMode">ADDITIVE</Set>
          <Random name="offset" min="-8, -8" max="8, 8" />
		  <Set name="initialAngle">180</Set>
          <Curve name="initialAlpha">
            <KeyFrame>0, 1</KeyFrame>
            <KeyFrame>1, 0</KeyFrame>
          </Curve>
          <Curve name="initialScale">
            <KeyFrame>0, 0.6, 0.6</KeyFrame>
            <KeyFrame>1, 0.05, 0.05</KeyFrame>
          </Curve>
		  	<Set name="rotateWithVelocity">true</Set>
			<RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="60,80"/>
          <Set name="lifeTime">0.5</Set>
        </Particle>
      </ParticleSystem>  
	</ParticleSystems>
    
		<VariableMap>
			<Set name="projectile_offset">0, 0</Set>
			<Set name="projectile_angle">0</Set>
		</VariableMap>    
        
		<RenderOptions>
			<Default>
		  	<Set name="NeedRenderPet">true</Set>
			  <Set name="PetOffsetDuplication">-32,0</Set>
			  <Set name="IgnoreDefaultDamagedTileEffect">true</Set>
		  	<Set name="IgnoreDefaultDestroyedTileEffect">true</Set>
		  	<Set name="HideParticlesOnTransform">false</Set>
			  <Set name="PunchSoundOverride">HAND</Set>
			  <Set name="PlayDefaultPunchAudio">false</Set>
			</Default>
		</RenderOptions>
	</Data>
    
	<RenderRules>        
		<RenderHandItem>
			<SpriteRender name="hand" rotateOffset="true" offset="0,32" alignment="DOWN_CENTER" blend="PREMULTIPLIED_ALPHA"/>
		</RenderHandItem>
		<Update>
			<StopIf>
				<IsZombified>true</IsZombified>
			</StopIf>
			<AvatarTransform class="ArmAngle" onAction="PUNCH">
				<Set name="armName">arm2Angle</Set>
				<Set name="armAngle">1700</Set>
				<Set name="isAdditive">true</Set>
				<Set name="pointTowardsPunchTarget">true</Set>
			</AvatarTransform>
		</Update>
		
        
		<OnPunchUpdate>
			<AvatarTransform class="Face">
				<Set name="face">MAD</Set>
			</AvatarTransform>
		</OnPunchUpdate>
        
		<RenderPet>
      <MusicSource onAction="PUNCH">
        <Set name="MusicFile">audio/droar.wav</Set>
        <Set name="FadeOutTimeMs">30</Set>
      </MusicSource>   
			<SpriteRender name="p_Pet_head" alignment="DOWN_CENTER" onAction="PUNCH" offset="0,10"/>
			<SpriteRender name="p_Pet_back" alignment="DOWN_CENTER" onAction="PUNCH" offset="-63.5,10"/>            
        	<SpriteRender name="s_Pet_head" alignment="DOWN_CENTER" onAction="IDLE|WALK|JUMP|JUMPSTART|FALL" offset="0,10"/>
			<SpriteRender name="s_Pet_back" alignment="DOWN_CENTER" onAction="IDLE|WALK|JUMP|JUMPSTART|FALL" offset="-63.5,10"/>
		</RenderPet>
	</RenderRules>
</ItemRenderer>
    
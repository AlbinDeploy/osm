<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
		<Sprite name="sprite" fileName="game/nami.rttex" textureSize="128"/>
		<Sprite name="s_projectile" fileName="game/nami.rttex" textureSize="128"/>
		<Sprite name="s_projectileTrail" fileName="game/nami.rttex" textureSize="128"/>
		
		<VariableMap>
    	  <Set name="context.pos">0,-10030</Set>
    	  <Set name="target.pos">0,-10030</Set>
   	   <Set name="calculatedPos">0,-10030</Set>
     	 <Set name="boomerangAngle">0</Set>
   	   <Set name="boomerang.Offset">0,-10030</Set>
  	  </VariableMap>
    
		<StateMachines>
		<StateMachine name="Motion">
			<States>
				<State name="Idle" />
				<State name="Move" />
				<State name="Jump" />
				<State name="Fall" />
				<State name="Punch"/>
				<State name="Respawn"/>
			</States>
			<Transitions>
				<Transition to="Idle" from="Fall|Move|Jump|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">true</IsVariableBool>
						<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						<IsVariableBool name="isAttacking">false</IsVariableBool>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Move" from="Jump|Fall|Idle|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">true</IsVariableBool>
						<IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Jump" from="Idle|Move|Fall|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">false</IsVariableBool>
						<IsVariableFloat name="speed.y" operator="Less">-0.1</IsVariableFloat>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Fall" from="Jump|Idle|Move|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">false</IsVariableBool>
						<IsVariableFloat name="speed.y" operator="Greater">0.1</IsVariableFloat>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Punch" from="Idle|Move|Jump|Fall">
					<Condition type="and">
						<IsAction>PUNCH</IsAction>
					</Condition>
				</Transition>
			</Transitions>
		</StateMachine>
		<StateMachine name="PunchAnim">
        <States>
          <State name="Off"/>
          <State name="Start" ExitTime="0.5" />
          <State name="Continue"/>
          <State name="End" ExitTime="0.25" />
        </States>
        <Transitions>
          <Transition from="Off" to="Start">
            <Condition type="and">
              <IsAction>PUNCH</IsAction>
              <IsZombified>false</IsZombified>
            </Condition>
          </Transition>
          <Transition from="Start" to="Continue"/>
          <Transition from="Continue" to="End">
            <Condition>
              <IsAction operatorType="NotEqual">PUNCH</IsAction>
            </Condition>
          </Transition>
          <Transition from="End" to="Off"/>
        </Transitions>
      </StateMachine>
	</StateMachines>
		
		<Animations>
			<SpriteAnimation name="punch_eff" sprite="s_projectile" animTime="120" isLoop="true">
			<Frame>4,3</Frame>
			<Frame>5,3</Frame>
			<Frame>6,3</Frame>
			<Frame>7,3</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="punch_ef" sprite="s_projectileTrail" animTime="120" isLoop="true">
			<Frame>4,3</Frame>
			<Frame>5,3</Frame>
			<Frame>6,3</Frame>
			<Frame>7,3</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="Idle_Animation" playOnState="Motion.Idle" sprite="sprite" animTime="800" isLoop="true">
			<Frame>0,0</Frame>
			<Frame>1,0</Frame>
			<Frame>2,0</Frame>
			<Frame>3,0</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="Punch_Animation" playOnState="Motion.Punch" sprite="sprite" animTime="400" isLoop="true">
			<Frame>0,3</Frame>
			<Frame>1,3</Frame>
			<Frame>2,3</Frame>
			<Frame>3,3</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="Jump_Animation" playOnState="Motion.Jump" sprite="sprite" animTime="600">
				<Frame>0,1</Frame>
				<Frame>1,1</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="Fall_Animation" playOnState="Motion.Fall" sprite="sprite" animTime="600">
				<Frame>2,1</Frame>
				<Frame>3,1</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="Walk_Animation" playOnState="Motion.Move" sprite="sprite" animTime="600" isLoop="true">
				<Frame>0,2</Frame>
				<Frame>1,2</Frame>
				<Frame>2,2</Frame>
				<Frame>3,2</Frame>
				<Frame>4,2</Frame>
				<Frame>5,2</Frame>
				<Frame>6,2</Frame>
			</SpriteAnimation>
		<InterpolationVec2Animation name="a_punchStart" variableName="calculatedPos" targetVariableName="target.pos" animTime="500" playOnState="PunchAnim.Start"/>
      <InterpolationVec2Animation name="a_punchContinue" variableName="calculatedPos" targetVariableName="target.pos" animTime="30" isLoop="true" playOnState="PunchAnim.Continue"/>
      <InterpolationVec2Animation name="a_punchEnd" variableName="calculatedPos" targetVariableName="context.pos" animTime="250" playOnState="PunchAnim.End"/>

      <InterpolationVec2Animation name="a_asdfStart" variableName="boomerang.Offset" targetValue="0,-10030" animTime="500" playOnState="PunchAnim.Start"/>
      <InterpolationVec2Animation name="a_dfyjrtEnd" variableName="boomerang.Offset" targetValue="0,-10038" animTime="250" playOnState="PunchAnim.End"/>

      <CurveAnimationFloat name="a_boomerangRotationRight" playOnState="PunchAnim.Start|PunchAnim.Continue|PunchAnim.End" isLoop="true" useFacing="RIGHT" animTime="350">
        <Curve name="boomerangAngle">
          <KeyFrame>0, 0</KeyFrame>
          <KeyFrame>1, 360</KeyFrame>
        </Curve>
      </CurveAnimationFloat>
      <CurveAnimationFloat name="a_boomerangRotationLeft" playOnState="PunchAnim.Start|PunchAnim.Continue|PunchAnim.End" isLoop="true" useFacing="LEFT" animTime="350">
        <Curve name="boomerangAngle">
          <KeyFrame>0, 0</KeyFrame>
          <KeyFrame>1, -360</KeyFrame>
        </Curve>
      </CurveAnimationFloat>
		</Animations>
		
		<ParticleSystems>
      <ParticleSystem name="punch_particle" secondary="punch_particle_trail">
        <Emitter>
          <Set name="lifeTime">0.02</Set>
          <Set name="particlesPerEmission">1</Set>
          <Set name="particlesToEmit">1</Set>
          <Set name="emissionInterval">0.02</Set>
        </Emitter>
        <Particle>
          <Set name="sprite">s_projectile</Set>
          <Set name="relativeToEmitter">false</Set>
          <Set name="offset" source="boomerang.Offset"/>
          <Set name="worldPos" source="calculatedPos"/>
          <Set name="initialAngle" source="boomerangAngle"/>
          <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          <Set name="lifeTime">0.04</Set>
          <Set name="initialScale">1,1</Set>
        </Particle>
      </ParticleSystem>
      <ParticleSystem name="punch_particle_trail">
        <Emitter>
          <Set name="lifeTime">1</Set>
          <Set name="particlesPerEmission">1</Set>
          <Set name="particlesToEmit">2</Set>
          <Set name="emissionInterval">0.2</Set>
          <Set name="checkParticleNumToEmit">true</Set>
        </Emitter>
        <Particle>
          <Set name="sprite">s_projectileTrail</Set>
          <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          <Set name="lifeTime">0.35</Set>
          <Random name="initialScale" min="0.25" max="0.75"/>
          <Random name="initialVelocity" min="-5,-5" max="5,5" />
          <Set name="rotateWithVelocity">true</Set>
          <Set name="isBackgroundParticle">true</Set>
          <Curve name="initialAlpha">
            <KeyFrame>0, 0</KeyFrame>
            <KeyFrame>0, 0.2</KeyFrame>
            <KeyFrame>1, 0</KeyFrame>
          </Curve>
        </Particle>
      </ParticleSystem>
      <ParticleSystem name="punch_smoke">
        <Emitter>
          <Set name="particlesPerEmission">1</Set>
          <Set name="particlesToEmit">1</Set>
        </Emitter>
        <Particle>
          <Set name="sprite">s_projectileTrail</Set>
          <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          <Set name="lifeTime">0.5</Set>
          <Set name="initialRotationRate">360</Set>
        </Particle>
      </ParticleSystem>
    </ParticleSystems>
    
		<RenderOptions>
			<Default>
				<Set name="JumpEndStateRange">100</Set>
				<Set name="ClothingOffsetFromShoes">10000</Set>
				<Set name="IsRidingBird">true</Set>
				<Set name="IsVehicle">true</Set>
				<Set name="UserNameOffset">30</Set>
				<Set name="RenderShoesWithMermaidTail">true</Set>
				<Set name="ShoesHidesBodyLegs">true</Set>
				<Set name="IsToRenderPants">false</Set>
			</Default>
		</RenderOptions>
	</Data>
	<RenderRules>
		<RenderInFront>
			<StopIf>
				<IsVariableBool name="isMannequin">true</IsVariableBool>
				<IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
			</StopIf>
			<SpriteRender name="sprite" offset="0,-10060" drawShadow="true" scale="1,1" onState="Motion.Idle|Motion.Move|Motion.Jump|Motion.Fall|Motion.Punch"/>
			<ParticleSystemUpdate name="punch_particle" onState="PunchAnim.Start|PunchAnim.Continue|PunchAnim.End"/>
		</RenderInFront>
		<RenderShoes>
			<StopIf>
				<IsSitting>true</IsSitting>
				<IsSleepingOnaBed>true</IsSleepingOnaBed>
				<IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
			</StopIf>
		</RenderShoes>
		<OnPunchStart>
		</OnPunchStart>
	</RenderRules>
</ItemRenderer>
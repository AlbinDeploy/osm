<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
		<StateMachines>
			<StateMachine name="playerState">
				<States>
					<State name="Idle" />
					<State name="Punch" />
					<State name="ZombiePunch" />
				</States>
				<Transitions>
					<Transition from="ZombiePunch|Punch" to="Idle">
						<Condition>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition from="ZombiePunch|Idle" to="Punch">
						<Condition type="and">
							<IsAction>PUNCH</IsAction>
							<IsZombified>false</IsZombified>
						</Condition>
					</Transition>
					<Transition from="Idle|Punch" to="ZombiePunch">
						<Condition type="and">
							<IsAction>PUNCH</IsAction>
							<IsZombified>true</IsZombified>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>
		<Sprite name="item_Sprite_1" fileName="game/gtfy_wn.rttex" textureSize="64" frame="5,15" />
		<Sprite name="slash_sprite" fileName="game/gtfy_wn.rttex" textureSize="64" />
		<Sprite name="Lightning" fileName="game/gtfy_wn.rttex" textureSize="64" frame="0,22" />
		<Sprite name="s_punch" fileName="game/gtfy_wn.rttex" textureSize="64" frame="7,21" />
		<Sprite name="s_hit" fileName="game/particles.rttex" textureSize="32" frame="8,3" />

		<Animations>
			<SpriteAnimation name="slash_animation" sprite="slash_sprite" animTime="175"
				isLoop="true" playOnState="playerState.Punch">
				<Frame>1,20</Frame>
				<Frame>2,20</Frame>
				<Frame>3,20</Frame>
				<Frame>4,20</Frame>
				<Frame>5,20</Frame>
				<Frame>6,20</Frame>
				<Frame>7,20</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="s_punch_frame" autoPlay="false" sprite="s_punch">
				<Frame>7,21</Frame>
				<Frame>8,21</Frame>
			</SpriteAnimation>

			<SpriteAnimation name="Lightning_Anim" playOnAction="IDLE|PUNCH|WALK|JUMP|FALL"
				sprite="Lightning" autoPlay="true" animTime="910" isLoop="true">
				<Frame>0,22</Frame>
				<Frame>1,22</Frame>
				<Frame>2,22</Frame>
				<Frame>3,22</Frame>
				<Frame>4,22</Frame>
				<Frame>5,22</Frame>
				<Frame>6,22</Frame>
				<Frame>7,22</Frame>
				<Frame>8,22</Frame>
				<Frame>9,22</Frame>
				<Frame>10,22</Frame>
				<Frame>11,22</Frame>
				<Frame>4,22</Frame>
			</SpriteAnimation>
		</Animations>

		<ParticleSystems>
			<ParticleSystem name="slash_particle">
				<Emitter>
					<Set name="offset">9,-18</Set>
					<Set name="emissionInterval">0.25</Set>
					<Set name="lifeTime">0.25</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">1</Set>
				</Emitter>
				<Particle alternateSpriteFrameWithPunch="true">
					<Set name="sprite">s_punch</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.4</Set>
					<Set name="rotateWithVelocity">true</Set>
					<Set name="interpolateAlpha">false</Set>
					<Set name="initialScale">1.4,1.4</Set>
					<Set name="initialAlpha">1</Set>
					<Set name="finalAlpha">1</Set>
					<Set name="interpolateVelocity">true</Set>
					<VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="0.8"
						angle="0" />
					<VectorTo name="finalVelocity" source="targetPos" duration="lifeTime" x="0.8"
						angle="0" />
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="hit_particle">
				<Emitter>
					<Set name="offset">0,0</Set>
					<Set name="lifeTime">2</Set>
					<Set name="particlesPerEmission">15</Set>
					<Set name="particlesToEmit">1</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">s_hit</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Set name="isBackgroundParticle">false</Set>
					<Set name="useGravity">true</Set>
					<Set name="lifeTime">1</Set>
					<Set name="gravityVector">0, 100</Set>
					<Set name="initalRGB">1,1,1</Set>
					<Set name="initialRotationRate">15</Set>
					<Set name="finalRotationRate">5</Set>
					<Set name="initialAlpha">1</Set>
					<Set name="finalAlpha">0</Set>
					<Set name="interpolateAlpha">true</Set>
					<Set name="interpolateScale">true</Set>
					<Set name="initialScale">1,1</Set>
					<Random name="finalScale" min="0.2, 0.2" max="0.5, 0.5" />
					<Set name="interpolateAngle">true</Set>
					<Random name="initialAngle" min="-360" max="360" />
					<Random name="finalAngle" min="-360" max="360" />
					<RandomRadial name="initialVelocity" angleRange="30,330" radiusRange="13.5,150" />
					<Random name="posOffset" min="0, 0" max="20,20" />
				</Particle>
			</ParticleSystem>
		</ParticleSystems>

		<TileStampData>
			<Set name="FileName">game/ci_n1.rttex</Set>
			<Set name="EndFrame">7,32</Set>
			<Set name="FrameCount">4</Set>
		</TileStampData>

		<RenderOptions>
			<Default>
				<Set name="DefaultRenderMannequinHandItem">false</Set>
			</Default>
		</RenderOptions>
	</Data>

	<RenderRules>
		<RenderHandItem>
			<SpriteRender name="item_Sprite_1" rotateOffset="true" offset="18,4" alignment="CENTER" />
		</RenderHandItem>

		<RenderInFront>
			<StopIf>
				<IsZombified>true</IsZombified>
			</StopIf>
			<SpriteRender name="slash_sprite" offset="12,-16" scale="1.25,1.25" alignment="CENTER"
				rotateOffset="true" blend="PREMULTIPLIED_ALPHA" onState="playerState.Punch"
				drawShadow="false" tintOverride="255,255,255,255" />
			<SpriteRender name="Lightning" alignment="DOWN_CENTER"
				onAction="IDLE|PUNCH|WALK|JUMP|FALL" drawShadow="false" />
		</RenderInFront>

		<OnPunchUpdate>
			<AvatarTransform class="Face">
				<Set name="face">MAD</Set>
			</AvatarTransform>
			<AvatarTransform class="ArmAngle">
				<Set name="armName">arm2Angle</Set>
				<Set name="armAngle">1000</Set>
				<Set name="isAdditive">true</Set>
				<Set name="pointTowardsPunchTarget">false</Set>
			</AvatarTransform>
		</OnPunchUpdate>

		<OnPunchStart>
			<ParticleSystemUpdate name="slash_particle" />
		</OnPunchStart>

		<OnDamagedTile>
			<ParticleSystemUpdate name="hit_particle" />
		</OnDamagedTile>

		<OnDestroyedTile>
			<ParticleSystemUpdate name="hit_particle" />
			<ParticleSystemUpdate name="hit_particle" />
		</OnDestroyedTile>

		<SwitchOffClothingParticles>
			<ParticleSystemOff name="slash_particle" />
			<ParticleSystemOff name="hit_particle" />
		</SwitchOffClothingParticles>
	</RenderRules>
</ItemRenderer>
<?xml version="1.0"?>
<ItemRenderer>
	<Data>
		<Sprite name="chestBackgroundSprite" fileName="game/ci_n1.rttex" textureSize="32" frame="0,17" />
		<Sprite name="chestForegroundSprite" fileName="game/ci_n1.rttex" textureSize="32" frame="0,16" />
		<Sprite name="eletricSprite" fileName="game/ci_n1.rttex" textureSize="32" frame="3,16" />
		<StateMachines>
			<StateMachine name="IsPunching">
				<States>
					<State name="False" />
					<State name="True" />
				</States>
				<Transitions>
					<Transition from="False" to="True">
						<Condition>
							<IsAction>PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition from="True" to="False">
						<Condition>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
			<StateMachine name="IsDying">
				<States>
					<State name="False" />
					<State name="True" />
				</States>
				<Transitions>
					<Transition from="False" to="True">
						<Condition>
							<IsAction>DIE</IsAction>
						</Condition>
					</Transition>
					<Transition from="True" to="False">
						<Condition>
							<IsAction operatorType="NotEqual">DIE</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>
		<Animations>
        	<SpriteAnimation name="ScarfAnimation" sprite="chestForegroundSprite" animTime="300" autoPlay="true" isLoop="true">
				<Frame>0,16</Frame>
				<Frame>1,16</Frame>
				<Frame>2,16</Frame>
        	</SpriteAnimation>
			<SpriteAnimation name="BackScarfAnimation" sprite="chestBackgroundSprite" animTime="700" autoPlay="true" isLoop="true">
				<Frame>0,17</Frame>
				<Frame>1,17</Frame>
				<Frame>2,17</Frame>
				<Frame>3,17</Frame>
				<Frame>4,17</Frame>
				<Frame>5,17</Frame>
				<Frame>6,17</Frame>
				<Frame>7,17</Frame>
			</SpriteAnimation>
		</Animations>
		<ParticleSystems>
			<ParticleSystem name="DeathParticle">
				<Emitter>
					<Set name="lifeTime">1.5</Set>
					<Set name="emissionInterval">0.3</Set>
					<Set name="infParticles">true</Set>
					<Set name="particlesPerEmission">6</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">eletricSprite</Set>
					<Random name="offset" min="-30, -31" max="30, 31" />
					<Set name="renderAlignment">CENTER</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 0.75, 0.75</KeyFrame>
						<KeyFrame>1, 2, 2</KeyFrame>
					</Curve>
					<Set name="lifeTime">0.4</Set>
					<Random name="initialVelocity" min="-25, -75" max="25, 20" />
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="SpawnParticle">
				<Emitter>
					<Set name="offset">160, -320</Set>
					<Set name="lifeTime">1</Set>
					<Set name="infParticles">true</Set>
					<Set name="checkParticleNumToEmit">true</Set>
					<Set name="particlesPerEmission">24</Set>
					<Set name="particlesToEmit">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">eletricSprite</Set>
					<Random name="offset" min="-30, -20" max="30, 20" />
					<Set name="renderAlignment">CENTER</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>0.5, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 2, 2</KeyFrame>
						<KeyFrame>1, 3, 3</KeyFrame>
					</Curve>
					<Set name="lifeTime">1</Set>
					<RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="25,50" />
				</Particle>
			</ParticleSystem>
		</ParticleSystems>
		<RenderOptions>
			<Default>
				<Set name="IgnorePunchTypeCheck">true</Set>
				<Set name="HideParticlesOnTransform">false</Set>
				<Set name="HideParticlesOnTheaterSeat">false</Set>
				<Set name="HasDeathParticles">true</Set>
				<Set name="IncludeAllActions">true</Set>
				<Set name="HideAvatarOnDeath">true</Set>
			</Default>
		</RenderOptions>
	</Data>
	<RenderRules>
		<RenderChestBackItem>
			<SpriteRender name="chestBackgroundSprite" offset="-19, 12" drawShadow="false" blend="PREMULTIPLIED_ALPHA" alignment="DOWN_CENTER" />
		</RenderChestBackItem>
		<RenderChestItem>
			<SpriteRender name="chestForegroundSprite" blend="PREMULTIPLIED_ALPHA" alignment="DOWN_CENTER" />
		</RenderChestItem>
		<OnRespawned>
			<ParticleSystemUpdate name="SpawnParticle" />
		</OnRespawned>
		<OnKilled>
			<ParticleSystemUpdate name="DeathParticle" />
		</OnKilled>
		<SwitchOffClothingParticles>
			<ParticleSystemOff name="SpawnParticle" />
			<ParticleSystemOff name="DeathParticle" />
		</SwitchOffClothingParticles>
	</RenderRules>
</ItemRenderer>
    
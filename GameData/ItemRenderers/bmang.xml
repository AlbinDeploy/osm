<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
		<Sprite name="item_Sprite" fileName="game/kntc_96.rttex" textureSize="96" frame="0,6"/>
    	<Sprite name="punch_Sprite" fileName="game/ci_n1.rttex" textureSize="32" frame="0,44"/>
    	<Sprite name="fire_Sprite" fileName="game/ci_n1.rttex" textureSize="32" frame="1,44"/>
		
		<Animations>
			<SpriteAnimation name="a_sprite" sprite="item_Sprite" playOnAction="IDLE|WALK|JUMP|FALL" isLoop="true" animTime="900" >
				<Frame>2,6</Frame>
				<Frame>3,6</Frame>
				<Frame>4,6</Frame>
			</SpriteAnimation> 
			<SpriteAnimation name="a_punch" sprite="item_Sprite" playOnAction="PUNCH" isLoop="true" animTime="700" >
				<Frame>2,6</Frame>
				<Frame>3,6</Frame>
				<Frame>4,6</Frame>
			</SpriteAnimation>  
		</Animations>                   
        
		<ParticleSystems>
			<ParticleSystem name="punch_particle">
				<Emitter attachment="targetPos">
					<Set name="lifeTime">3</Set>
					<Set name="particlesToEmit">1</Set>
					<Set name="particlesPerEmission">4</Set>
				</Emitter>
				<Particle>
						<Curve name="initialAngle">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>1, 360</KeyFrame>
					</Curve>
					<Set name="sprite">punch_Sprite</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">1</Set>
						<Curve name="initialScale">
						<KeyFrame>0, 0.5,0.5</KeyFrame>
						<KeyFrame>0.5, 0.7,0.7</KeyFrame>
						<KeyFrame>0.8, 1.0,1.0</KeyFrame>
						<KeyFrame>1, 1.5,1.5</KeyFrame>
					</Curve>
						<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="initialRotationRate">360</Set>
				</Particle>
			</ParticleSystem>
      <ParticleSystem name="TileHitFire">
        <Emitter>
          <Random name="emissionInterval" min="0.05" max="0.1" />
          <Set name="infParticles">true</Set>
          <Set name="infLifeTime">true</Set>
          <Set name="particlesPerEmission">1</Set>
        </Emitter>
        <Particle>
          <Set name="sprite">fire_Sprite</Set>
          <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          <Set name="lifeTime">0.6</Set>
          <Set name="initialVelocity">0,-32</Set>
          <Curve name="initialAlpha">
            <KeyFrame>0, 1</KeyFrame>
            <KeyFrame>0.5, 1</KeyFrame>
            <KeyFrame>1, 0</KeyFrame>
          </Curve>
          <Random name="initialScale" min="0.4" max="1.2" />
          <Random name="offset" min="-8, -7" max="8, 7" />
        </Particle>
      </ParticleSystem>            
    	</ParticleSystems>   
        
    <RenderOptions>
      <Default>
        <Set name="PunchSoundOverride">FACEITEM</Set>
        <Set name="PlayDefaultPunchAudio">true</Set>
        <Set name="IncludeAllActions">true</Set>
        <Set name="IgnoreDefaultDamagedTileEffect">true</Set>
      </Default>
    </RenderOptions>        
             
	</Data>

	<RenderRules>
		<RenderFaceItem>
			<SpriteRender name="item_Sprite" offset="-0.3,-15.5" scale="0.35,0.35" alignment="DOWN_CENTER"/>
   	</RenderFaceItem>
        
		<OnPunchStart>
			<ParticleSystemUpdate name="punch_particle"/>
		</OnPunchStart>
        
		<OnDamagedTile>
			<ParticleSystemUpdate name="TileHitFire" />
		</OnDamagedTile>        
        
		<SwitchOffClothingParticles>
			<ParticleSystemOff name="punch_particle"/>
		</SwitchOffClothingParticles>                
	</RenderRules>
</ItemRenderer>
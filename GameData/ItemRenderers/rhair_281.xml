<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
		<Sprite name="wyss" fileName="game/ci_n1.rttex" textureSize="32" frame="3,25" />
		<Sprite name="hh" fileName="game/ci_n1.rttex" textureSize="32" frame="4,23" />
		<Sprite name="wys" fileName="game/ci_n1.rttex" textureSize="32" frame="3,24" />
		<Sprite name="wysssss" fileName="game/ci_n1.rttex" textureSize="32" frame="5,26" />
		<Sprite name="wysss" fileName="game/ci_n1.rttex" textureSize="32" frame="6,24" />
		<StateMachines>
			<StateMachine name="WYSKEE">
				<States>
					<State name="KEE" />
					<State name="WYS" />
				</States>
				<Transitions>
					<Transition from="KEE" to="WYS">
						<Condition>
							<IsAction>PUNCH</IsAction>
						</Condition>
					</Transition><!--WYSKEE-->
					<Transition from="WYS" to="KEE">
						<Condition>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>
		<Animations>
			<SpriteAnimation name="?EEKSYW" isLoop="true" sprite="wyss" animTime="1600">
				<Frame>3,25</Frame>
				<Frame>4,25</Frame>
				<Frame>5,25</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="WYS-" sprite="hh" isLoop="true" playOnState="WYSKEE.KEE"
				animTime="100">
				<Frame>4,23</Frame>
			</SpriteAnimation><!--WYSKEE-->
			<SpriteAnimation name="WYSKEE?" sprite="wysssss" animTime="150">
				<Frame>3,26</Frame>
				<Frame>4,26</Frame>
				<Frame>5,26</Frame>
				<Frame>6,26</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="SYW-" sprite="wysss" animTime="1600">
				<Frame>6,24</Frame>
				<Frame>6,25</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="@KEE" sprite="hh" isLoop="true" playOnState="WYSKEE.WYS"

					<Set name="initalRGB">10, 10, 10</Set>
					<Set name="lifeTime">0.75</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>0.4, 0.75</KeyFrame>

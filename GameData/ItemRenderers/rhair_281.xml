				<Frame>5,23</Frame>
				<Frame>6,23</Frame>
			</SpriteAnimation><!--WYSKEE-->
			<SpriteAnimation name="+WYS" sprite="wys" animTime="1600">
				<Frame>3,24</Frame>
				<Frame>4,24</Frame>
				<Frame>5,24</Frame>
				<Frame>3,25</Frame>
				<Frame>4,25</Frame>
				<Frame>5,25</Frame>
			</SpriteAnimation>
		</Animations>

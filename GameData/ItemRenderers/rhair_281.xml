					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="isBackgroundParticle">true</Set>
					<Set name="relativeToEmitter">true</Set><!--WYSKEE-->
					<Set name="initalRGB">1, 1, 1</Set>

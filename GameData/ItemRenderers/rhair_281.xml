				<Emitter>
					<Set name="emissionInterval">0.25</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">2</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">wysssss</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set><!--WYSKEE-->
					<Set name="relativeToEmitter">true</Set>
					<Set name="inSpecificOrder">true</Set>
					<Set name="initalRGB">0,0,0</Set>
					<Set name="interpolateScale">true</Set>
					<Set name="initialScale">7, 2.5</Set>
					<Set name="finalScale">0.45, 0.20</Set>
					<Set name="initialAngle">0</Set>
					<Set name="initialRotationRate">10</Set>
					<Set name="interpolateAlpha">true</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>0.4, 0.5</KeyFrame>
						<KeyFrame>0.65, 1</KeyFrame>
						<KeyFrame>1, 0.2</KeyFrame>

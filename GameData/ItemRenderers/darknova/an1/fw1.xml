<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<RenderRules>
    <OnDrawCustomOutline>
      <AvatarTransform class="Scale">
        <Set name="targetScale">getCurrent</Set>
      </AvatarTransform>
      <AvatarTransform class="RenderData">
        <Set name="saturation">3</Set>
        <Set name="brightness">1</Set>
        <Set name="contrast">0.5</Set>
      </AvatarTransform>
      <AvatarOutline duration="1500" startScale="1,1" endScale="1.1,1.1">
        <Colours>
          <Colour>255,200,244,196</Colour>
          <Colour>255,200,244,196</Colour>
          <Colour>255,200,244,196</Colour>
        </Colours>
      </AvatarOutline>
      <AvatarTransform class="RenderData">
        <Set name="saturation">1</Set>
        <Set name="brightness">0.5</Set>
        <Set name="contrast">0.1</Set>
      </AvatarTransform>
      <AvatarTransform class="Scale">
        <Set name="targetScale">reset</Set>
      </AvatarTransform>
    </OnDrawCustomOutline>        
    
		<RenderBackpack>
	  	<SpriteRender name="left_wing" scale="0.75,0.75" offset="-78,-26"/>
	  	<SpriteRender name="right_wing" scale="0.75,0.75" offset="78,-26" flip="1,0"/>
		</RenderBackpack>

		<RenderBehind>
		</RenderBehind>

		<AddClothingParticles>
		</AddClothingParticles>
	</RenderRules>

	<Data>
		<Sprite name="left_wing" fileName="game/darknova/an1/x196.rttex" textureSize="196" frame="0,2"/>
		<Sprite name="right_wing" fileName="game/darknova/an1/x196.rttex" textureSize="196" frame="0,2"/>
		<Sprite name="s_particles" fileName="game/darknova/an1/ci_n1.rttex" textureSize="32" frame="21,47"/>

    	<Animations>
			<SpriteAnimation name="left_wing_anim" isLoop="true" sprite="left_wing" autoPlay="true" animTime="1000">
				<Frame>0,2</Frame>
				<Frame>1,2</Frame>
				<Frame>2,2</Frame>
				<Frame>3,2</Frame>
				<Frame>4,2</Frame>
				<Frame>5,2</Frame>
				<Frame>0,3</Frame>
				<Frame>1,3</Frame>
				<Frame>2,3</Frame>
				<Frame>3,3</Frame>
				<Frame>4,3</Frame>                
			</SpriteAnimation>
			<SpriteAnimation name="right_wing_anim" isLoop="true" sprite="right_wing" autoPlay="true" animTime="1000">
				<Frame>0,2</Frame>
				<Frame>1,2</Frame>
				<Frame>2,2</Frame>
				<Frame>3,2</Frame>
				<Frame>4,2</Frame>
				<Frame>5,2</Frame>
				<Frame>0,3</Frame>
				<Frame>1,3</Frame>
				<Frame>2,3</Frame>
				<Frame>3,3</Frame>
				<Frame>4,3</Frame>                
			</SpriteAnimation>
            
	        <SpriteAnimation name="a_particles" sprite="s_particles" animTime="1600">
	        	<Frame>21,47</Frame>
	        	<Frame>22,47</Frame>
        	</SpriteAnimation>              
		</Animations>

		<ParticleSystems>
			<ParticleSystem name="ps_right" updateStage="AddClothingParticles" renderStage="RenderInFront">
				<Emitter>
					<Set name="randomizeInterval">true</Set>
					<Set name="intervalMin">0.1</Set>
					<Set name="intervalMax">0.2</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">3</Set>
				</Emitter>
				<Particle velocityRelativeToPlayerSpeed="true" randomSpriteFrame="true">
					<Set name="sprite">s_particles</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="inSpecificOrder">true</Set>
					<Set name="initalRGB">10,10,10</Set>
					<Set name="interpolateScale">true</Set>
					<Set name="initialScale">0.45, 0.20</Set>
					<Set name="finalScale">0, 1.5</Set>
					<Set name="interpolateAlpha">true</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>0.4, 0.75</KeyFrame>
						<KeyFrame>0.6, 0.75</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Random name="initialRotationRate" min="-30" max="30" />
					<Random name="lifeTime" min="0.8" max="1.5" />
					<Random name="initialVelocity" min="-10,-60" max="10,-70" />
					<Random name="offset" min="20,-10" max="40,-45" />
					<Set name="useGravity">true</Set>
					<Set name="gravityVector">10, -65</Set>
				</Particle>
			</ParticleSystem>         
			<ParticleSystem name="ps_left" updateStage="AddClothingParticles" renderStage="RenderInFront">
				<Emitter>
					<Set name="randomizeInterval">true</Set>
					<Set name="intervalMin">0.1</Set>
					<Set name="intervalMax">0.2</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">3</Set>
				</Emitter>
				<Particle velocityRelativeToPlayerSpeed="true" randomSpriteFrame="true">
					<Set name="sprite">s_particles</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="inSpecificOrder">true</Set>
					<Set name="initalRGB">10,10,10</Set>
					<Set name="interpolateScale">true</Set>
					<Set name="initialScale">0.45, 0.20</Set>
					<Set name="finalScale">0, 1.5</Set>
					<Set name="interpolateAlpha">true</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>0.4, 0.75</KeyFrame>
						<KeyFrame>0.6, 0.75</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Random name="initialRotationRate" min="-30" max="30" />
					<Random name="lifeTime" min="0.8" max="1.5" />
					<Random name="initialVelocity" min="-10,-60" max="10,-70" />
					<Random name="offset" min="-20,-6" max="-30,-35" />
					<Set name="useGravity">true</Set>
					<Set name="gravityVector">-10, -65</Set>
				</Particle>
			</ParticleSystem>            
      <ParticleSystem name="particle_crack" updateStage="AddClothingParticles">
        <Emitter>
          <Set name="infLifeTime">true</Set>
          <Set name="infParticles">true</Set>
          <Set name="particlesPerEmission">1</Set>
          <Set name="emissionInterval">0.15</Set>
          <Set name="useCharacterPos">true</Set>
        </Emitter>
        <Particle>
          <Set name="useAvatarShadow">true</Set>
	  	<Set name="relativeToEmitter">true</Set>          
          <Set name="lifeTime">0.8</Set>
	  	<Set name="initalRGB">80, 50, 255</Set>          
          <Set name="isBackgroundParticle">true</Set>
          <Curve name="initialAlpha">
            <KeyFrame>0, 1</KeyFrame>
            <KeyFrame>0.5, 0.8</KeyFrame>
            <KeyFrame>1, 0</KeyFrame>
          </Curve>
	  	<Curve name="initialVelocity">
			<KeyFrame>0, 0,0</KeyFrame>
			<KeyFrame>0.2, -10, 10</KeyFrame>
			<KeyFrame>0.4, 20, -20</KeyFrame>
			<KeyFrame>0.6, -25, 25</KeyFrame>
			<KeyFrame>0.8, 30, -30</KeyFrame>
			<KeyFrame>1, -35, 35</KeyFrame>
	  	</Curve>          
        </Particle>
      </ParticleSystem>                                        
		</ParticleSystems>

		<VariableMap>
		</VariableMap>

		<RenderOptions>
			<Default>
				<Set name="PlayDefaultPunchAudio">false</Set>
				<Set name="PunchSoundOverride">BACKPACK</Set>
			</Default>
		</RenderOptions>

		<StateMachines>
			<StateMachine name="State">
				<States>
					<State name="Idle" />
					<State name="Move" />
					<State name="Fall" />
					<State name="Jump" />
					<State name="DoubleJump" />
					<State name="SpiritGuide" />
				</States>
				<Transitions>
					<Transition from="SpiritGuide|Jump|Fall|Move|DoubleJump" to="Idle">
						<Condition>
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Jump|Fall|Idle|DoubleJump" to="Move">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>WALK</IsAction>
						</Condition>
					</Transition>
					<Transition from="Move|Jump|Fall|Idle|DoubleJump" to="SpiritGuide">
						<Condition type="and">
							<IsWearing slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0</IsVariableFloat>
							<IsAction operatorType="NotEqual">FALL</IsAction>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Fall|Move|Idle" to="Jump">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>JUMP</IsAction>
						</Condition>
					</Transition>
					<Transition from="Jump|Fall" to="DoubleJump">
						<Condition>
							<IsAction>JUMPDOUBLE</IsAction>
						</Condition>
					</Transition>
					<Transition from="DoubleJump|SpiritGuide|Jump|Idle|Move" to="Fall">
						<Condition type="and">
							<IsVariableFloat name="speed.y" operator="Greater" abs="false">0.01</IsVariableFloat>
							<IsAction>FALL</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>
	</Data>
</ItemRenderer>
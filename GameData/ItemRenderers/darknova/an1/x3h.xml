<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<RenderRules>
		<RenderBehind>
			<SpriteRender name="item_Sprite_1" offset="158,-65" blend="PREMULTIPLIED_ALPHA"
				alignmentLeft="LEFT_CENTER" alignmentRight="RIGHT_CENTER" scale="1.2,1.2" />

			<StopIf>
				<IsVariableBool name="isMannequin">true</IsVariableBool>
				<IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
			</StopIf>
			<AvatarSilhouetteRender color="255,255,255,255" emissionInterval="0.35"
				onState="playerState.Move|playerState.Idle|playerState.Jump|playerState.DoubleJump|playerState.Fall" />
		</RenderBehind>

		<RenderInFront>
			<StopIf>
				<IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
			</StopIf>
			<ParticleSystemRender name="ps_orbit" />
		</RenderInFront>

		<AddClothingParticles>
			<StopIf>
				<IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
			</StopIf>
			<ParticleSystemUpdate name="ps_orbit" />
		</AddClothingParticles>
	</RenderRules>

	<Data>
		<Sprite name="item_Sprite_1" fileName="game/darknova/an1/x256.rttex" textureSize="256,256" />
		<Sprite name="s_sparkles" fileName="game/darknova/an1/ci_n1.rttex" textureSize="32,32" frame="24,14" />
		<Sprite name="s_orbit" fileName="game/darknova/an1/gtfy_wn2.rttex" textureSize="64,64" frame="13,2" />
		<Sprite name="s_jump1" fileName="game/darknova/an1/gtfy_wn2.rttex" textureSize="64,64" frame="14,3" />
		<Sprite name="s_jump2" fileName="game/darknova/an1/gtfy_wn2.rttex" textureSize="64,64" frame="13,3" />

		<Animations>
			<SpriteAnimation name="be_idle2" sprite="item_Sprite_1" animTime="750" autoPlay="true"
				isLoop="true">
				<Frame>0,8</Frame>
				<Frame>1,8</Frame>
				<Frame>2,8</Frame>
				<Frame>3,8</Frame>
				<Frame>4,8</Frame>
				<Frame>5,8</Frame>
				<Frame>6,8</Frame>
				<Frame>7,8</Frame>
				<Frame>8,8</Frame>
				<Frame>9,8</Frame>
				<Frame>10,8</Frame>
				<Frame>11,8</Frame>
				<Frame>12,8</Frame>
				<Frame>13,8</Frame>
				<Frame>14,8</Frame>
				<Frame>15,8</Frame>
				<Frame>16,8</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="orbit_anim" autoPlay="true" isLoop="true" sprite="s_orbit"
				animTime="300">
				<Frame>13,2</Frame>
				<Frame>14,2</Frame>
				<Frame>15,2</Frame>
				<Frame>16,2</Frame>
			</SpriteAnimation>
		</Animations>

		<ParticleSystems>
			<ParticleSystem name="ps_Sparkles" updateStage="AddClothingParticles"
				renderStage="RenderBehind">
				<Emitter>
					<Random name="emissionInterval" min="0.03" max="0.06" />
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>
					<Random name="offset" min="-32, -32" max="24, -6" />
				</Emitter>
				<Particle>
					<Set name="sprite">s_sparkles</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>0.3, 1</KeyFrame>
						<KeyFrame>0.8, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 0.2,0.2</KeyFrame>
						<KeyFrame>0.05, 1,1</KeyFrame>
						<KeyFrame>0.1, 0.2,0.2</KeyFrame>
						<KeyFrame>0.15, 1,1</KeyFrame>
						<KeyFrame>0.2, 0.2,0.2</KeyFrame>
						<KeyFrame>0.25, 1,1</KeyFrame>
						<KeyFrame>0.3, 0.2,0.2</KeyFrame>
						<KeyFrame>0.35, 1,1</KeyFrame>
						<KeyFrame>0.4, 0.2,0.2</KeyFrame>
						<KeyFrame>0.45, 1,1</KeyFrame>
						<KeyFrame>0.5, 0.2,0.2</KeyFrame>
						<KeyFrame>0.55, 1,1</KeyFrame>
						<KeyFrame>0.6, 0.2,0.2</KeyFrame>
						<KeyFrame>0.65, 1,1</KeyFrame>
						<KeyFrame>0.7, 0.2,0.2</KeyFrame>
						<KeyFrame>0.75, 0.75,0.75</KeyFrame>
						<KeyFrame>0.8, 0.15,0.15</KeyFrame>
						<KeyFrame>0.85, 0.5,0.5</KeyFrame>
						<KeyFrame>0.9, 0.1,0.1</KeyFrame>
						<KeyFrame>0.95, 0.25,0.25</KeyFrame>
						<KeyFrame>1, 0.05,0.05</KeyFrame>
					</Curve>
					<Set name="lifeTime">1.25</Set>
					<Random name="initialVelocity" min="0, -25" max="0, -50" />
					<Random name="initialRotationRate" min="-60" max="60" />
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="ps_orbit">
				<Emitter>
					<Set name="offset">0, -16</Set>
					<Set name="emissionInterval">0.04</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>
					<OrbitOffset>
						<Set name="maxScale">0.7f</Set>
						<Set name="hasOrbit">true</Set>
						<Set name="hOrbitPeriod">6000</Set>
						<Set name="hAmplitude">25</Set>
						<Set name="hTimeOffset">0</Set>
						<Set name="vAmplitude">6</Set>
						<Set name="vOrbitPeriod">4000</Set>
						<Set name="vTimeOffset">0</Set>
						<Set name="minScale">0.4</Set>
					</OrbitOffset>
				</Emitter>
				<Particle>
					<Set name="sprite">s_orbit</Set>
					<Set name="relativeToEmitter">true</Set>
					<Set name="inSpecificOrder">false</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.06</Set>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="p_jump_center1" updateStage="AddClothingParticles"
				updateState="playerState.DoubleJump">
				<Emitter>
					<Set name="offset">0, -10</Set>
					<Random name="emissionInterval" min="5" max="5" />
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter><!--DEAD-->
				<Particle>
					<Set name="sprite">s_jump1</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>0.5, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 1.3,1.3</KeyFrame>
						<KeyFrame>1, 1.3,1.3</KeyFrame>
					</Curve>
					<Set name="lifeTime">1</Set>
				</Particle>
			</ParticleSystem><!--DEAD-->
			<ParticleSystem name="p_jump_center2" updateStage="AddClothingParticles"
				updateState="playerState.DoubleJump">
				<Emitter>
					<Set name="offset">0, -10</Set>
					<Random name="emissionInterval" min="5" max="5" />
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter><!--DEAD-->
				<Particle>
					<Set name="sprite">s_jump2</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>0.5, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 1.3,1.3</KeyFrame>
						<KeyFrame>1, 1.3,1.3</KeyFrame>
					</Curve>
					<Set name="lifeTime">3</Set>
				</Particle>
			</ParticleSystem><!--DEAD-->
		</ParticleSystems>

		<StateMachines>
			<StateMachine name="playerState">
				<States>
					<State name="Idle" />
					<State name="Move" />
					<State name="Fall" />
					<State name="Jump" />
					<State name="DoubleJump" />
					<State name="SpiritGuide" />
				</States>
				<Transitions>
					<Transition from="SpiritGuide|Jump|Fall|Move|DoubleJump" to="Idle">
						<Condition>
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Jump|Fall|Idle|DoubleJump" to="Move">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>WALK</IsAction>
						</Condition>
					</Transition>
					<Transition from="Move|Jump|Fall|Idle|DoubleJump" to="SpiritGuide">
						<Condition type="and">
							<IsWearing slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0</IsVariableFloat>
							<IsAction operatorType="NotEqual">FALL</IsAction>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Fall|Move|Idle" to="Jump">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>JUMP</IsAction>
						</Condition>
					</Transition>
					<Transition from="Jump|Fall" to="DoubleJump">
						<Condition>
							<IsAction>JUMPDOUBLE</IsAction>
						</Condition>
					</Transition>
					<Transition from="DoubleJump|SpiritGuide|Jump|Idle|Move" to="Fall">
						<Condition type="and">
							<IsVariableFloat name="speed.y" operator="Greater" abs="false">0.01</IsVariableFloat>
							<IsAction>FALL</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>
	</Data>
</ItemRenderer>
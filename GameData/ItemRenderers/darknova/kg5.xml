<?xml version="1.0"?>
<ItemRenderer>
	<RenderRules>
		<RenderInFront>
			<SpriteRender name="p_item" offset="2,-9984" scale="0.8,0.8" alignment="DOWN_CENTER" onState="Action1.Punch"/>
			<StopIf type="and">
				<IsAction>PUNCH</IsAction>
			</StopIf>        
			<SpriteRender name="item" offset="2,-9984" scale="0.8,0.8" alignment="DOWN_CENTER"/>
		</RenderInFront>

		<OnDestroyedTile>
			<ParticleSystemUpdate name="ps_break" />
		</OnDestroyedTile>  
        
    	<RenderBehind>
	    	<ParticleSystemRender name="particle_fire" />
    	</RenderBehind>                  
        
		<OnPunchStart>
			<ParticleSystemUpdate name="punch_particle" />
		</OnPunchStart>
        
		<AddClothingParticles>
            <ParticleSystemUpdate name="particle_trail" onAction="WALK|JUMP|FALL"/>        
            <ParticleSystemUpdate name="afterfallparticle" onState="Motion.FallToGround"/>
    	</AddClothingParticles>                       
	</RenderRules>
    
    	<Data>
		<Sprite name="item" fileName="game/darknova/x128.rttex" textureSize="128,128"/>
		<Sprite name="p_item" fileName="game/darknova/x128.rttex" textureSize="128,128" frame="7,13"/>
		<Sprite name="s_punch" fileName="game/darknova/x196.rttex" textureSize="196,196" frame="0,0"/>
		<Sprite name="s_break" fileName="game/darknova/x196.rttex" textureSize="196,196" frame="3,0"/>

		<Sprite name="s_fallground" fileName="game/darknova/x196.rttex" textureSize="196,196" frame="5,0"/>
		<Sprite name="s_afterfall" fileName="game/darknova/x196.rttex" textureSize="196,196" frame="4,0"/>
		<Sprite name="s_trail" fileName="game/darknova/x196.rttex" textureSize="196,196" frame="6,0"/>
		<Sprite name="s_fire" fileName="game/darknova/ci_n1.rttex" textureSize="32,32" frame="23,42"/>

		<Animations>
			<SpriteAnimation name="idle" isLoop="true" playOnState="Motion.Idle" sprite="item" animTime="1500">
                <Frame>6,12</Frame>
                <Frame>7,12</Frame>
                <Frame>8,12</Frame>
            </SpriteAnimation>
			<SpriteAnimation name="walk" isLoop="false" playOnState="Motion.Walk" sprite="item" animTime="880">
                <Frame>9,12</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="jump" isLoop="false" sprite="item" playOnState="Motion.Jump">
                <Frame>10,12</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="fall" isLoop="false" sprite="item" playOnState="Motion.Fall">
				<Frame>6,13</Frame>
			</SpriteAnimation>
            <SpriteAnimation name="punch" isLoop="true" playOnState="Action1.Punch" sprite="p_item" animTime="280">
                <Frame>7,13</Frame>
                <Frame>8,13</Frame>
                <Frame>9,13</Frame>
                <Frame>10,13</Frame>                
            </SpriteAnimation>  
            <SpriteAnimation name="anim_punch" isLoop="true" sprite="s_punch" animTime="200">
                <Frame>0,0</Frame>
                <Frame>1,0</Frame>
                <Frame>2,0</Frame>
            </SpriteAnimation>        
            
			<SpriteAnimation name="fall_ground" isLoop="false" sprite="s_fallground" playOnState="Motion.FallToGround">
				<Frame>5,0</Frame>
			</SpriteAnimation> 
			<SpriteAnimation name="ground_fall" isLoop="false" sprite="s_fallground" playOnState="Motion.GroundToFall">
				<Frame>5,0</Frame>
			</SpriteAnimation>                      
		</Animations>
         
		<ParticleSystems>
			<ParticleSystem name="punch_particle">
				<Emitter>
					<Set name="offset">15,-10028</Set>
					<Set name="emissionInterval">8</Set>
					<Set name="lifeTime">1</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_punch</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">1</Set>
					<Set name="rotateWithVelocity">true</Set>
					<Curve name="initialScale">
						<KeyFrame>0, 0.35,0.35</KeyFrame>
						<KeyFrame>1, 0.5,0.5</KeyFrame>
					</Curve>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1,1</KeyFrame>
						<KeyFrame>1, 0,0</KeyFrame>
					</Curve>                           
					<Set name="interpolateVelocity">true</Set>
					<VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="1"
						angle="0" />
					<VectorTo name="finalVelocity" source="targetPos" duration="lifeTime" x="1"
						angle="0" />
				</Particle>
			</ParticleSystem>    
			<ParticleSystem name="ps_break">
				<Emitter>
					<Set name="offset">0,0</Set>
					<Set name="lifeTime">2</Set>
					<Set name="particlesPerEmission">16</Set>
					<Set name="particlesToEmit">1</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">s_break</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Set name="isBackgroundParticle">false</Set>
					<Set name="useGravity">true</Set>
					<Set name="lifeTime">1</Set>
					<Set name="gravityVector">0, 100</Set>
					<Set name="initalRGB">1,1,1</Set>
					<Set name="initialRotationRate">15</Set>
					<Set name="finalRotationRate">5</Set>
					<Set name="initialAlpha">1</Set>
					<Set name="finalAlpha">0</Set>
					<Set name="interpolateAlpha">true</Set>
					<Set name="interpolateScale">true</Set>
					<Set name="initialScale">0.35,0.35</Set>
					<Random name="finalScale" min="0, 0" max="0.05, 0.05"/>
					<Set name="interpolateAngle">true</Set>
					<Random name="initialAngle" min="-360" max="360"/>
					<Random name="finalAngle" min="-360" max="360"/>
					<RandomRadial name="initialVelocity" angleRange="30,330" radiusRange="13.5,150"/>
					<Random name="posOffset" min="0, 0" max="16,16"/>
				</Particle>
			</ParticleSystem>             
            <ParticleSystem name="afterfallparticle">
               <Emitter>
	    			<Set name="offset">2,-10000</Set>
                    <Set name="particlesPerEmission">1</Set>
               </Emitter>
               <Particle>
                    <Set name="sprite">s_afterfall</Set>
		    		<Set name="relativeToEmitter">true</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Set name="lifeTime">0.3</Set>
                    <Curve name="initialScale">
                     <KeyFrame>0, 0.78,0.78</KeyFrame>
                     <KeyFrame>1, 0.8,0.8</KeyFrame>
                    </Curve>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1,1</KeyFrame>
						<KeyFrame>1, 0,0</KeyFrame>
					</Curve>                     
               </Particle>
            </ParticleSystem>           
		<ParticleSystem name="particle_trail">
			<Emitter>
				<Set name="offset">-3,-5010</Set>
				<Set name="infLifeTime">true</Set>
				<Set name="infParticles">true</Set>
				<Set name="particlesPerEmission">4</Set>
				<Set name="intervalMin">.05</Set>
				<Set name="intervalMax">.15</Set>
				<Set name="randomizeInterval">true</Set>
			</Emitter>
			<Particle angleRelativeToPlayerSpeed="true" randomSpriteFrame="true">
				<Set name="sprite">s_trail</Set>
				<Random name="offset" min="-8,-5010" max="8,-4996"/>
				<Set name="lifeTime">0.7</Set>
				<Set name="isBackgroundParticle">true</Set>
				<Set name="useGravity">false</Set>
				<Set name="gravityVector">0,25</Set>
				<Set name="interpolateScale">true</Set>
				<Set name="initialScale">0.78, 0.98</Set>
				<Set name="finalScale">2, 0</Set>
				<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
				<Curve name="initialAlpha">
					<KeyFrame>0, 0.8</KeyFrame>
					<KeyFrame>1, 0</KeyFrame>
				</Curve>
			</Particle>
		</ParticleSystem>           
			<ParticleSystem name="particle_fire" updateStage="AddClothingParticles" updateState="Motion.Idle">
				<Emitter>
					<Set name="offset">0, -5005</Set>
					<Set name="offsetFacing">false</Set>
					<Random name="emissionInterval" min="0.2" max="0.4" />
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">6</Set>
				</Emitter>
				<Particle usePlayerFacing="true">
					<Set name="sprite">s_fire</Set>
					<Set name="relativeToEmitter">true</Set>
					<Random name="offset" min="-18, -5005" max="18, -5005" />
					<Set name="inSpecificOrder">true</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>0.1, 0.65</KeyFrame>
						<KeyFrame>0.5, 0.65</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 1, 1</KeyFrame>
						<KeyFrame>0.5, 1, 1.9</KeyFrame>
						<KeyFrame>1, 1, 2.5</KeyFrame>
					</Curve>					
                    <Random name="lifeTime" min="0.8" max="1" />
					<Set name="initialVelocity">0, -30</Set>
				</Particle>
			</ParticleSystem>                                      
		</ParticleSystems>                 
         
		<RenderOptions>
			<Default>
				<Set name="UserNameOffset">13</Set>
				<Set name="IgnoreDefaultDamagedTileEffect">true</Set>
				<Set name="IgnoreDefaultDestroyedTileEffect">true</Set>
				<Set name="IgnorePunchTypeCheck">true</Set>
				<Set name="IncludeAllActions">true</Set>
				<Set name="PlayDefaultPunchAudio">true</Set>
				<Set name="PunchSoundOverride">SHOES</Set>
				<Set name="JumpEndStateRange">100</Set>
				<Set name="ClothingOffsetFromShoes">10000</Set>
				<Set name="IsRidingBird">true</Set>
				<Set name="IsVehicle">true</Set>
				<Set name="RenderShoesWithMermaidTail">true</Set>
				<Set name="ShoesHidesBodyLegs">true</Set>
				<Set name="IsToRenderPants">false</Set>
			</Default>
   	</RenderOptions>
    
		<StateMachines>
      <StateMachine name="Motion">
        <States>
          <State name="Idle"/>
          <State name="Walk"/>
          <State name="Jump"/>
          <State name="Fall"/>
          <State name="FallToGround"/>
          <State name="GroundToFall"/>
        </States>
        <Transitions>
          <Transition from="Idle|Jump" to="Walk">
            <Condition type="and">
              <IsVariableFloat name="speed.x" operator="Greater" abs="true">0.1</IsVariableFloat>
              <IsVariableBool name="onGround">true</IsVariableBool>
            </Condition>
          </Transition>
          <Transition from="Walk|Jump" to="Idle">
            <Condition type="and">
              <IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
              <IsVariableBool name="onGround">true</IsVariableBool>
            </Condition>
          </Transition>
          <Transition from="Walk|Idle|Fall|FallToGround" to="Jump">
            <Condition type="and">
              <IsAction>JUMP</IsAction>
            </Condition>
          </Transition>
          <Transition from="Jump|FallToGround" to="Fall">
            <Condition type="and">
              <IsAction>FALL</IsAction>
            </Condition>
          </Transition>
          <Transition from="Walk|Idle" to="GroundToFall">
            <Condition type="and">
              <IsAction>FALL</IsAction>
            </Condition>
          </Transition>
          <Transition from="GroundToFall" to="Fall">
            <Condition type="and">
              <IsAction>FALL</IsAction>
              <IsAnimationFinished>ground_fall</IsAnimationFinished>
            </Condition>
          </Transition>
          <Transition from="Fall" to="FallToGround">
            <Condition>
              <IsVariableBool name="onGround">true</IsVariableBool>
            </Condition>
          </Transition>
          <Transition from="FallToGround" to="Walk">
            <Condition type="and">
              <IsVariableFloat name="speed.x" operator="Greater" abs="true">0.1</IsVariableFloat>
              <IsVariableBool name="onGround">true</IsVariableBool>
              <IsAnimationFinished>fall_ground</IsAnimationFinished>
            </Condition>
          </Transition>
          <Transition from="FallToGround" to="Idle">
            <Condition type="and">
              <IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
              <IsVariableBool name="onGround">true</IsVariableBool>
              <IsAnimationFinished>fall_ground</IsAnimationFinished>
            </Condition>
          </Transition>
          <Transition from="GroundToFall" to="FallToGround">
            <Condition type="and">
              <IsVariableBool name="onGround">true</IsVariableBool>
              <IsAnimationFinished>ground_fall</IsAnimationFinished>
            </Condition>
          </Transition>
        </Transitions>
      </StateMachine>        
			<StateMachine name="Action1">
				<States>
					<State name="Idle"/>
					<State name="Punch"/>
					<State name="ZombiePunch"/>
				</States>
				<Transitions>
					<Transition from="ZombiePunch|Punch" to="Idle" >
						<Condition>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition from="ZombiePunch|Idle" to="Punch">
						<Condition type="and">
							<IsAction>PUNCH</IsAction>
							<IsZombified>false</IsZombified>
						</Condition>
					</Transition>
					<Transition from="Idle|Punch" to="ZombiePunch">
						<Condition type="and">
							<IsAction>PUNCH</IsAction>
							<IsZombified>true</IsZombified>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>     
	</Data>        
</ItemRenderer>
<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
  <Data>
	<StateMachines>
		<StateMachine name="playerState">
			<States>
				<State name="Idle"/>
				<State name="Punch"/>
				<State name="ZombiePunch"/>
			</States>
			<Transitions>
				<Transition from="ZombiePunch|Punch" to="Idle" >
					<Condition>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition from="ZombiePunch|Idle" to="Punch">
					<Condition type="and">
						<IsAction>PUNCH</IsAction>
						<IsZombified>false</IsZombified>
					</Condition>
				</Transition>
				<Transition from="Idle|Punch" to="ZombiePunch">
					<Condition type="and">
						<IsAction>PUNCH</IsAction>
						<IsZombified>true</IsZombified>
					</Condition>
				</Transition>
			</Transitions>
		</StateMachine>
	</StateMachines>
	<Sprite name="s_buster" fileName="game/lci_1.rttex" textureSize="64,32" frame="1,9"/>
    
	<Sprite name="p_buster" fileName="game/gtfy_wn.rttex" textureSize="64" frame="14,1"/>
	<Sprite name="s_hit" fileName="game/ci_n1.rttex" textureSize="32" frame="4,34"/>            
    
	<Animations>
	<SpriteAnimation name="Anim" playOnAction="IDLE|WALK|JUMP|FALL"
				sprite="s_buster" autoPlay="true" animTime="910" isLoop="true">
				<Frame>1,9</Frame>
				<Frame>2,9</Frame>
				<Frame>3,9</Frame>
				<Frame>4,9</Frame>
				<Frame>5,9</Frame>
				<Frame>6,9</Frame>
				<Frame>7,9</Frame>
				<Frame>8,9</Frame>
				<Frame>9,9</Frame>
			</SpriteAnimation>
    </Animations>
    
	<ParticleSystems>
			<ParticleSystem name="punch_buster">
				<Emitter>
					<Set name="offset">6,-18</Set>
					<Set name="emissionInterval">0.25</Set>
					<Set name="lifeTime">0.25</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">1</Set>
				</Emitter>
				<Particle alternateSpriteFrameWithPunch="true">
					<Set name="sprite">p_buster</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.4</Set>
					<Set name="rotateWithVelocity">true</Set>
					<Set name="interpolateAlpha">false</Set>
					<Set name="initialScale">1,1</Set>
					<Set name="initialAlpha">1</Set>
					<Set name="finalAlpha">1</Set>
					<Set name="interpolateVelocity">true</Set>
					<VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="0.7" angle="0"/>
					<VectorTo name="finalVelocity" source="targetPos" duration="lifeTime" x="0.7" angle="0"/>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="hit_particle">
				<Emitter>
					<Set name="lifeTime">1</Set>
					<Set name="particlesToEmit">1</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Random name="initialAngle" min="-360" max="360"/>
					<Set name="sprite">s_hit</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.5</Set>
					<Curve name="initialScale">
						<KeyFrame>0, 0.4,0.4</KeyFrame>
						<KeyFrame>1, 1.3,1.3</KeyFrame>
					</Curve>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
				</Particle>
			</ParticleSystem>
	</ParticleSystems>
  </Data>

  <RenderRules>
    <RenderHandItem>
	  <SpriteRender name="s_buster" rotateOffset="true" offset="0,9" alignment="CENTER"/>  
    </RenderHandItem>
    
	<OnPunchUpdate>
		<AvatarTransform class="Face">
			<Set name="face">MAD</Set>
		</AvatarTransform>
		<AvatarTransform class="ArmAngle">
			<Set name="armName">arm2Angle</Set>
			<Set name="armAngle">1400</Set>
			<Set name="isAdditive">true</Set>
			<Set name="pointTowardsPunchTarget">false</Set>
		</AvatarTransform>
	</OnPunchUpdate>
    
	<OnPunchStart>
		<ParticleSystemUpdate name="punch_buster"/>           
	</OnPunchStart>
    
		<OnDamagedTile>
			<ParticleSystemUpdate name="hit_particle"/>
		</OnDamagedTile>    
    
	<SwitchOffClothingParticles>
		<ParticleSystemOff name="punch_buster"/>
 	   <ParticleSystemOff name="hit_particle"/>            
	</SwitchOffClothingParticles>
    
  </RenderRules>
</ItemRenderer>
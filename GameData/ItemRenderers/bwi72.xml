<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
		<StateMachines>
			<StateMachine name="State">
				<States>
					<State name="Idle" />
					<State name="Move" />
					<State name="Fall" />
					<State name="Jump" />
					<State name="DoubleJump" />
					<State name="SpiritGuide" />
				</States>
				<Transitions>
					<Transition from="SpiritGuide|Jump|Fall|Move|DoubleJump" to="Idle">
						<Condition>
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Jump|Fall|Idle|DoubleJump" to="Move">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>WALK</IsAction>
						</Condition>
					</Transition>
					<Transition from="Move|Jump|Fall|Idle|DoubleJump" to="SpiritGuide">
						<Condition type="and">
							<IsWearing slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0</IsVariableFloat>
							<IsAction operatorType="NotEqual">FALL</IsAction>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Fall|Move|Idle" to="Jump">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>JUMP</IsAction>
						</Condition>
					</Transition>
					<Transition from="Jump|Fall" to="DoubleJump">
						<Condition>
							<IsAction>JUMPDOUBLE</IsAction>
						</Condition>
					</Transition>
					<Transition from="DoubleJump|SpiritGuide|Jump|Idle|Move" to="Fall">
						<Condition type="and">
							<IsVariableFloat name="speed.y" operator="Greater" abs="false">0.01</IsVariableFloat>
							<IsAction>FALL</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
			<StateMachine name="Move">
				<States>
					<State name="False" />
					<State name="True" />
				</States>
				<Transitions>
					<Transition to="False" from="True">
						<Condition>
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						</Condition>
					</Transition>
					<Transition to="True" from="False">
						<Condition>
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>

		<Sprite name="left_wing_sprite" fileName="game/gtfy_wn.rttex" textureSize="64" frame="0,21" />
		<Sprite name="right_wing_sprite" fileName="game/gtfy_wn.rttex" textureSize="64" frame="0,21" />

		<Sprite name="lightning" fileName="game/gtfy_wn.rttex" textureSize="64" frame="8,15" />
		<Sprite name="p_fire" fileName="game/ci_n1rttex" textureSize="32" frame="2,44" />
		<Sprite name="left_particle" fileName="game/gtfy_wn.rttex" textureSize="64" frame="8,20" />
		<Sprite name="right_particle" fileName="game/gtfy_wn.rttex" textureSize="64" frame="8,20" />

		<Animations>
			<SpriteAnimation name="left_wing_Idle"
				playOnState="State.Idle|State.SpiritGuide|State.Move" sprite="left_wing_sprite"
				isLoop="true" animTime="100">
				<Frame>0,21</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="right_wing_Idle"
				playOnState="State.Idle|State.SpiritGuide|State.Move" sprite="right_wing_sprite"
				isLoop="true" animTime="100">
				<Frame>0,21</Frame>
			</SpriteAnimation>

			<SpriteAnimation name="left_wing_DoubleJ" playOnState="State.DoubleJump"
				sprite="left_wing_sprite" isLoop="false" animTime="125">
				<Frame>1,21</Frame>
				<Frame>2,21</Frame>
				<Frame>3,21</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="right_wing_DoubleJ" playOnState="State.DoubleJump"
				sprite="right_wing_sprite" isLoop="false" animTime="125">
				<Frame>1,21</Frame>
				<Frame>2,21</Frame>
				<Frame>3,21</Frame>
			</SpriteAnimation>

			<SpriteAnimation name="left_wing_Fall" playOnState="State.Fall"
				sprite="left_wing_sprite" isLoop="true" animTime="100">
				<Frame>3,21</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="right_wing_Fall" playOnState="State.Fall"
				sprite="right_wing_sprite" isLoop="true" animTime="100">
				<Frame>3,21</Frame>
			</SpriteAnimation>

			<SpriteAnimation name="left_wing_Jump" playOnState="State.Jump"
				sprite="left_wing_sprite" isLoop="false" animTime="350">
				<Frame>0,21</Frame>
				<Frame>1,21</Frame>
				<Frame>2,21</Frame>
				<Frame>3,21</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="right_wing_Jump" playOnState="State.Jump"
				sprite="right_wing_sprite" isLoop="false" animTime="350">
				<Frame>0,21</Frame>
				<Frame>1,21</Frame>
				<Frame>2,21</Frame>
				<Frame>3,21</Frame>
			</SpriteAnimation>

			<SpriteAnimation name="lightning_anim"
				playOnState="State.Idle|State.SpiritGuide|State.Move|State.Fall|State.Jump|State.DoubleJump"
				sprite="lightning" animTime="600" isLoop="true">
				<Frame>8,15</Frame>
				<Frame>9,15</Frame>
				<Frame>10,15</Frame>
				<Frame>11,15</Frame>
				<Frame>12,15</Frame>
				<Frame>13,15</Frame>
				<Frame>14,15</Frame>
				<Frame>15,15</Frame>
				<Frame>16,15</Frame>
				<Frame>17,15</Frame>
				<Frame>18,15</Frame>
				<Frame>19,15</Frame>
				<Frame>8,15</Frame>
			</SpriteAnimation>

			<SpriteAnimation name="particle_left" sprite="left_particle"
				playOnState="State.Idle|State.SpiritGuide|State.Move|State.Fall|State.Jump|State.DoubleJump"
				animTime="1200" isLoop="true">
				<Frame>8,20</Frame>
				<Frame>9,20</Frame>
				<Frame>10,20</Frame>
				<Frame>11,20</Frame>
				<Frame>12,20</Frame>
				<Frame>13,20</Frame>
				<Frame>14,20</Frame>
				<Frame>15,20</Frame>
				<Frame>16,20</Frame>
				<Frame>17,20</Frame>
				<Frame>18,20</Frame>
				<Frame>19,20</Frame>
				<Frame>20,20</Frame>
				<Frame>21,20</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="particle_right" sprite="right_particle"
				playOnState="State.Idle|State.SpiritGuide|State.Move|State.Fall|State.Jump|State.DoubleJump"
				animTime="1200" isLoop="true">
				<Frame>8,20</Frame>
				<Frame>9,20</Frame>
				<Frame>10,20</Frame>
				<Frame>11,20</Frame>
				<Frame>12,20</Frame>
				<Frame>13,20</Frame>
				<Frame>14,20</Frame>
				<Frame>15,20</Frame>
				<Frame>16,20</Frame>
				<Frame>17,20</Frame>
				<Frame>18,20</Frame>
				<Frame>19,20</Frame>
				<Frame>20,20</Frame>
				<Frame>21,20</Frame>
			</SpriteAnimation>
		</Animations>

		<ParticleSystems>
			<ParticleSystem name="particle_trail" updateStage="AddClothingParticles"
				updateState="Move.True">
				<Emitter>
					<Set name="infLifeTime">true</Set>
					<Set name="infParticles">true</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="emissionInterval">0.15</Set>
					<Set name="useCharacterPos">true</Set>
				</Emitter>
				<Particle>
					<Set name="useAvatarShadow">true</Set>
					<Set name="lifeTime">1</Set>
					<Set name="isBackgroundParticle">true</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>0.5, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="fire_right">
				<Emitter>
					<Random name="offset" min="20, -10" max="35, -40" />
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="emissionInterval">0.25</Set>
					<Set name="particlesPerEmission">5</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">p_fire</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.75</Set>
					<Set name="initialAlpha">1</Set>
					<Set name="finalAlpha">0</Set>
					<Set name="interpolateAlpha">true</Set>
					<Set name="interpolateScale">true</Set>
					<Set name="initialScale">0.5, 0.5</Set>
					<Set name="finalScale">0.7, 1</Set>
					<Random name="initialVelocity" min="0,-16" max="0,-14" />
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="fire_left">
				<Emitter>
					<Random name="offset" min="-20, -10" max="-35, -40" />
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="emissionInterval">0.25</Set>
					<Set name="particlesPerEmission">5</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">p_fire</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.75</Set>
					<Set name="initialAlpha">1</Set>
					<Set name="finalAlpha">0</Set>
					<Set name="interpolateAlpha">true</Set>
					<Set name="interpolateScale">true</Set>
					<Set name="initialScale">0.5, 0.5</Set>
					<Set name="finalScale">0.7, 1</Set>
					<Random name="initialVelocity" min="0,-16" max="0,-14" />
				</Particle>
			</ParticleSystem>
		</ParticleSystems>

		<RenderOptions>
			<Default>
				<Set name="PlayDefaultPunchAudio">false</Set>
				<Set name="PunchSoundOverride">BACKPACK</Set>
			</Default>
		</RenderOptions>
	</Data>

	<RenderRules>
		<RenderBackpack>
			<ContextUpdate type="SetTintFromSlot">
				<Set name="slot">HAIR</Set>
			</ContextUpdate>
			<SpriteRender name="left_particle" offset="-35,-25" scale="1.5,2.5" />
			<SpriteRender name="right_particle" offset="35,-25" scale="1.5,2.5" flip="1,0" />
			<SpriteRender name="left_wing_sprite" offset="-50,-14" scale="1.5,1.5" />
			<SpriteRender name="right_wing_sprite" offset="50,-14" scale="1.5,1.5" flip="1,0" />
			<ContextUpdate type="SetTintFromSlot">
				<Set name="slot">HAIR</Set>
				<Set name="seedFG">true</Set>
			</ContextUpdate>
			<StopIf>
				<IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
			</StopIf>
		</RenderBackpack>

		<RenderInFront>
			<StopIf>
				<IsZombified>true</IsZombified>
				<IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
			</StopIf>
			<ContextUpdate type="SetTintFromSlot">
				<Set name="slot">HAIR</Set>
			</ContextUpdate>
			<SpriteRender name="lightning" alignment="DOWN_CENTER" offset="0,10"
				onState="State.Idle|State.SpiritGuide|State.Move|State.Fall|State.Jump|State.DoubleJump"
				drawShadow="false" />
			<ContextUpdate type="SetTintFromSlot">
				<Set name="slot">HAIR</Set>
				<Set name="seedFG">true</Set>
			</ContextUpdate>
		</RenderInFront>

		<AddClothingParticles>
			<ContextUpdate type="SetTintFromSlot">
				<Set name="slot">HAIR</Set>
			</ContextUpdate>
			<ParticleSystemUpdate name="fire_left" onAction="IDLE|WALK|PUNCH|FALL|JUMP|JUMPDOUBLE"
				drawShadow="false" align="LEFT_CENTER" />
			<ParticleSystemUpdate name="fire_right" onAction="IDLE|WALK|PUNCH|FALL|JUMP|JUMPDOUBLE"
				drawShadow="false" align="RIGHT_CENTER" />
			<ContextUpdate type="SetTintFromSlot">
				<Set name="slot">HAIR</Set>
				<Set name="seedFG">true</Set>
			</ContextUpdate>
		</AddClothingParticles>

		<SwitchOffClothingParticles>
			<ParticleSystemOff name="fire_left" />
			<ParticleSystemOff name="fire_right" />
		</SwitchOffClothingParticles>
	</RenderRules>
</ItemRenderer>
<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
  <Data>
    <Sprite name="coronation_idle" fileName="game/coronation_peach_p1.rttex" textureSize="256,404" />
    <Sprite name="coronation_walk" fileName="game/coronation_peach_p2.rttex" textureSize="256,357" />
    <Sprite name="coronation_jump" fileName="game/coronation_peach_p2.rttex" textureSize="256,357" />
    <Sprite name="coronation_fall" fileName="game/coronation_peach_p2.rttex" textureSize="256,357" />

    <StateMachines>
      <StateMachine name="Motion">
        <States>
          <State name="Idle" />
          <State name="Move" />
          <State name="Jump" />
          <State name="Fall" />
        </States>
        <Transitions>
          <Transition to="Idle" from="Fall|Move|Jump">
            <Condition type="and">
              <IsVariableBool name="onGround">true</IsVariableBool>
              <IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
              <IsVariableBool name="isAttacking">false</IsVariableBool>
            </Condition>
          </Transition>
          <Transition to="Move" from="Jump|Fall|Idle">
            <Condition type="and">
              <IsVariableBool name="onGround">true</IsVariableBool>
              <IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
            </Condition>
          </Transition>
          <Transition to="Jump" from="Idle|Move|Fall">
            <Condition type="and">
              <IsVariableBool name="onGround">false</IsVariableBool>
              <IsVariableFloat name="speed.y" operator="Less">-0.1</IsVariableFloat>
            </Condition>
          </Transition>
          <Transition to="Fall" from="Jump|Idle|Move">
            <Condition type="and">
              <IsVariableBool name="onGround">false</IsVariableBool>
              <IsVariableFloat name="speed.y" operator="Greater">0.1</IsVariableFloat>
            </Condition>
          </Transition>
        </Transitions>
      </StateMachine>
    </StateMachines>

    <Animations>
      <SpriteAnimation
        name="coronation_Idle_Animation"
        playOnState="Motion.Idle"
        sprite="coronation_idle"
        animTime="550"
        isLoop="true">
        <Frame>0,0</Frame>
        <Frame>1,0</Frame>
        <Frame>2,0</Frame>
        <Frame>3,0</Frame>
        <Frame>4,0</Frame>
        <Frame>5,0</Frame>
        <Frame>6,0</Frame>
        <Frame>7,0</Frame>
        <Frame>8,0</Frame>
      </SpriteAnimation>

      <SpriteAnimation
        name="coronation_Jump_Animation"
        playOnState="Motion.Jump"
        sprite="coronation_jump"
        animTime="550"
        isLoop="true">
        <Frame>0,3</Frame>
        <Frame>1,3</Frame>
        <Frame>2,3</Frame>
        <Frame>3,3</Frame>
        <Frame>4,3</Frame>
        <Frame>5,3</Frame>
        <Frame>6,3</Frame>
      </SpriteAnimation>

      <SpriteAnimation
        name="coronation_Fall_Animation"
        playOnState="Motion.Fall"
        sprite="coronation_fall"
        animTime="550"
        isLoop="true">
        <Frame>0,2</Frame>
        <Frame>1,2</Frame>
        <Frame>2,2</Frame>
        <Frame>3,2</Frame>
        <Frame>4,2</Frame>
        <Frame>5,2</Frame>
        <Frame>6,2</Frame>
      </SpriteAnimation>

      <SpriteAnimation
        name="coronation_Walk_Animation"
        playOnState="Motion.Move"
        sprite="coronation_walk"
        animTime="550"
        isLoop="true">
        <Frame>0,4</Frame>
        <Frame>1,4</Frame>
        <Frame>2,4</Frame>
        <Frame>3,4</Frame>
        <Frame>4,4</Frame>
        <Frame>5,4</Frame>
        <Frame>6,4</Frame>
        <Frame>7,4</Frame>
        <Frame>8,4</Frame>
      </SpriteAnimation>
    </Animations>

    <ParticleSystems>
    </ParticleSystems>

    <RenderOptions>
      <Default>
        <Set name="JumpEndStateRange">100</Set>
        <Set name="ClothingOffsetFromShoes">10000</Set>
        <Set name="IsRidingBird">true</Set>
        <Set name="IsVehicle">true</Set>
        <Set name="UserNameOffset">38</Set>
        <Set name="RenderShoesWithMermaidTail">true</Set>
        <Set name="ShoesHidesBodyLegs">true</Set>
        <Set name="IsToRenderPants">false</Set>
        <Set name="IncludeAllActions">true</Set>
        <Set name="IgnoreDefaultDamagedTileEffect">true</Set>
        <Set name="IgnoreDefaultDestroyedTileEffect">true</Set>
      </Default>
    </RenderOptions>
  </Data>

  <RenderRules>
    <RenderInFront>
      <StopIf>
        <IsVariableBool name="isMannequin">true</IsVariableBool>
        <IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
      </StopIf>

      <SpriteRender
        name="coronation_idle"
        offset="0,-10030"
        drawShadow="true"
        onState="Motion.Idle"
        scale="0.18,0.18" />

      <SpriteRender
        name="coronation_walk"
        offset="0,-10040"
        drawShadow="true"
        onState="Motion.Move"
        scale="0.35,0.35" />

      <SpriteRender
        name="coronation_jump"
        offset="0,-10055"
        drawShadow="true"
        onState="Motion.Jump"
        scale="0.35,0.35" />

      <SpriteRender
        name="coronation_fall"
        offset="0,-10055"
        drawShadow="true"
        onState="Motion.Fall"
        scale="0.35,0.35" />
    </RenderInFront>

    <RenderShoes>
      <StopIf>
        <IsSitting>true</IsSitting>
        <IsSleepingOnaBed>true</IsSleepingOnaBed>
        <IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
      </StopIf>
    </RenderShoes>
  </RenderRules>
</ItemRenderer>